// --- CHECKLIST SUMMARY (COMPLETELY CLEANED VERSION) ---
if (y > pageHeight - 60) {
    doc.addPage();
    y = margin + 5;
    addFooter(doc, inspection, pageWidth, pageHeight, margin);
}
addTitle('CHECKLIST SUMMARY', 16);
drawLine();
y += 4;

// Use clean plain text strings - NO special characters or HTML
const sections = [
    { 
        title: 'General Site Conditions', 
        items: [
            ['Verified site location and boundaries', inspection.siteLocation],
            ['Assessed accessibility and entry points', inspection.accessibility],
            ['Evaluated site conditions (topography, soil, vegetation, drainage)', inspection.siteConditions],
            ['Identified existing infrastructure or features', inspection.infrastructure]
        ]
    },
    { 
        title: 'Environmental Considerations', 
        items: [
            ['Assessed presence of protected flora or fauna', inspection.protectedSpecies],
            ['Evaluated potential environmental impacts', inspection.environmentalImpacts],
            ['Verified compliance with environmental regulations', inspection.compliance],
            ['Noted areas of conservation significance', inspection.conservation]
        ]
    },
    { 
        title: 'Work Practices and Procedures', 
        items: [
            ['Observed and evaluated work practices', inspection.workPractices],
            ['Assessed compliance with health and safety regulations', inspection.healthSafety],
            ['Identified potential risks and hazards', inspection.risksHazards],
            ['Reviewed implementation of control measures', inspection.controlMeasures]
        ]
    },
    { 
        title: 'Equipment and Machinery', 
        items: [
            ['Inspected equipment and machinery', inspection.equipmentInspected],
            ['Ensured equipment in safe working condition', inspection.safeCondition],
            ['Checked maintenance and service records', inspection.maintenanceRecords],
            ['Verified compliance with industry standards', inspection.industryStandards]
        ]
    }
];

sections.forEach(section => {
    if (y > pageHeight - 50) { 
        doc.addPage(); 
        y = margin + 5; 
        addFooter(doc, inspection, pageWidth, pageHeight, margin); 
    }
    doc.setFontSize(11); 
    doc.setTextColor(colour);
    doc.text(section.title, margin, y);
    y += 5;
    doc.setFontSize(8); 
    section.items.forEach(([label, done]) => {
        const status = done ? '\u2713' : '\u2717'; // Unicode checkmark and cross
        const color = done ? '#10b981' : '#dc2626';
        doc.setTextColor(color);
        // Use the label as-is - it's already clean plain text
        doc.text(`${status}  ${label}`, margin + 4, y);
        y += 5;
    });
    y += 4;
});
