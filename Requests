        const html = `
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:10px;margin-bottom:14px;">
                <div class="stat-card" style="background:white;padding:12px;border-radius:var(--radius);border:1px solid var(--gray-200);">
                    <div style="font-size:1.4rem;font-weight:700;color:var(--gray-800);">${total}</div>
                    <div style="font-size:0.6rem;text-transform:uppercase;color:var(--gray-500);">Total Inspections</div>
                </div>
                <div class="stat-card" style="background:white;padding:12px;border-radius:var(--radius);border:1px solid var(--gray-200);">
                    <div style="font-size:1.4rem;font-weight:700;color:var(--gray-800);">${drafts.length}</div>
                    <div style="font-size:0.6rem;text-transform:uppercase;color:var(--gray-500);">Drafts</div>
                </div>
                <div class="stat-card" style="background:white;padding:12px;border-radius:var(--radius);border:1px solid var(--gray-200);">
                    <div style="font-size:1.4rem;font-weight:700;color:var(--gray-800);">${heritageCount}</div>
                    <div style="font-size:0.6rem;text-transform:uppercase;color:var(--gray-500);">Heritage Sites</div>
                </div>
            </div>
            <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:8px;">
                <button class="btn btn-primary" onclick="app.newInspection()"><i class="fas fa-plus"></i> New Inspection</button>
                <button class="btn btn-secondary" onclick="app.showInspections()"><i class="fas fa-folder-open"></i> View Reports</button>
            </div>
            <div style="padding:6px 10px;background:var(--gray-50);border-radius:var(--radius-sm);border:1px solid var(--gray-200);">
                <div class="flex-between text-xs text-muted">
                    <span><i class="fas fa-code-branch"></i> v4.0</span>
                    <span><i class="fas fa-check-double"></i> Full Checklist</span>
                    <span><i class="fas fa-hand-peace"></i> Aboriginal Heritage</span>
                </div>
            </div>
        `;
        this.setPanel(html, 'Dashboard');
    }

    async showInspections() {
        const inspections = await this.db.getAll('inspections');
        if (inspections.length === 0) {
            this.setPanel(`<div class="text-center" style="padding:30px;"><i class="fas fa-folder-open" style="font-size:36px;opacity:0.3;"></i><h3>No Inspections</h3><button class="btn btn-primary mt-3" onclick="app.newInspection()">Start New</button></div>`, 'Inspections');
            return;
        }
        inspections.sort((a,b) => new Date(b.dateTime) - new Date(a.dateTime));
        let html = `<div class="flex-between mb-2"><span><strong>${inspections.length}</strong> inspections</span><button class="btn btn-primary btn-sm" onclick="app.newInspection()"><i class="fas fa-plus"></i> New</button></div>`;
        inspections.forEach(ins => {
            const heritage = ins.heritageSignificance || 'Not Assessed';
            html += `
                <div class="inspection-card" style="border-left-color:var(--primary);">
                    <div class="card-title">${Utils.escapeHtml(ins.siteName || 'Unnamed')}</div>
                    <div class="card-meta"><span><i class="fas fa-calendar"></i> ${Utils.formatDate(ins.dateTime)}</span><span><i class="fas fa-user"></i> ${ins.inspector || 'Unknown'}</span></div>
                    <div class="flex gap-2" style="margin:4px 0;">
                        <span class="text-muted text-sm"><i class="fas fa-hand-peace"></i> ${heritage}</span>
                        <span class="text-muted text-sm"><i class="fas fa-camera"></i> ${ins.photos?.length || 0} photos</span>
                    </div>
                    <div class="card-actions">
                        <button class="btn btn-secondary btn-sm view-insp" data-id="${ins.id}"><i class="fas fa-eye"></i> View</button>
                        <button class="btn btn-primary btn-sm pdf-insp" data-id="${ins.id}"><i class="fas fa-file-pdf"></i> Report</button>
                        <button class="btn btn-danger btn-sm del-insp" data-id="${ins.id}"><i class="fas fa-trash"></i></button>
                    </div>
                    <div class="card-badge" style="background:var(--primary)20;color:var(--primary);">Final</div>
                </div>
            `;
        });
        this.setPanel(html, 'Inspections');
        document.querySelectorAll('.view-insp').forEach(el => el.onclick = () => this.loadInspection(el.dataset.id, false));
        document.querySelectorAll('.pdf-insp').forEach(el => el.onclick = async () => { const ins = await this.db.get(el.dataset.id, false); if (ins) this.generateReport(ins); });
        document.querySelectorAll('.del-insp').forEach(el => el.onclick = async () => { if (confirm('Delete?')) { await this.db.delete(el.dataset.id, false); Toast.success('Deleted'); await this.updateStatus(); this.showInspections(); } });
    }

    async showDrafts() {
        const drafts = await this.db.getAll('drafts');
        if (drafts.length === 0) {
            this.setPanel(`<div class="text-center" style="padding:30px;"><i class="fas fa-save" style="font-size:36px;opacity:0.3;"></i><h3>No Drafts</h3><button class="btn btn-primary mt-3" onclick="app.newInspection()">Start New</button></div>`, 'Drafts');
            return;
        }
        drafts.sort((a,b) => new Date(b.updatedAt) - new Date(a.updatedAt));
        let html = `<div class="flex-between mb-2"><span><strong>${drafts.length}</strong> drafts</span><button class="btn btn-primary btn-sm" onclick="app.newInspection()"><i class="fas fa-plus"></i> New</button></div>`;
        drafts.forEach(d => {
            html += `
                <div class="inspection-card" style="border-left-color:var(--warning);">
                    <div class="card-title">${Utils.escapeHtml(d.siteName || 'Unnamed Draft')}</div>
                    <div class="card-meta"><span><i class="fas fa-clock"></i> ${Math.round((Date.now() - new Date(d.updatedAt).getTime()) / (1000*60*60*24))}d ago</span><span><i class="fas fa-user"></i> ${d.inspector || 'No inspector'}</span></div>
                    <div class="card-actions">
                        <button class="btn btn-secondary btn-sm resume-draft" data-id="${d.id}"><i class="fas fa-pen"></i> Resume</button>
                        <button class="btn btn-danger btn-sm del-draft" data-id="${d.id}"><i class="fas fa-trash"></i></button>
                    </div>
                    <div class="card-badge" style="background:rgba(212,168,67,0.15);color:var(--warning);">Draft</div>
                </div>
            `;
        });
        this.setPanel(html, 'Drafts');
        document.querySelectorAll('.resume-draft').forEach(el => el.onclick = () => this.loadInspection(el.dataset.id, true));
        document.querySelectorAll('.del-draft').forEach(el => el.onclick = async () => { if (confirm('Delete draft?')) { await this.db.delete(el.dataset.id, true); Toast.success('Deleted'); await this.updateStatus(); this.showDrafts(); } });
    }

    async showDataManager() {
        const insp = await this.db.count('inspections');
        const drafts = await this.db.count('drafts');
        const html = `
            <div style="max-width:420px;margin:0 auto;">
                <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:12px;">
                    <div class="stat-card" style="background:white;padding:12px;border-radius:var(--radius);border:1px solid var(--gray-200);text-align:center;">
                        <div style="font-size:1.4rem;font-weight:700;">${insp}</div>
                        <div style="font-size:0.6rem;text-transform:uppercase;color:var(--gray-500);">Reports</div>
                    </div>
                    <div class="stat-card" style="background:white;padding:12px;border-radius:var(--radius);border:1px solid var(--gray-200);text-align:center;">
                        <div style="font-size:1.4rem;font-weight:700;">${drafts}</div>
                        <div style="font-size:0.6rem;text-transform:uppercase;color:var(--gray-500);">Drafts</div>
                    </div>
                    <div class="stat-card" style="background:white;padding:12px;border-radius:var(--radius);border:1px solid var(--gray-200);text-align:center;">
                        <div style="font-size:1.4rem;font-weight:700;">${(await this.db.getAll('inspections')).reduce((s,i) => s + (i.photos?.length||0), 0)}</div>
                        <div style="font-size:0.6rem;text-transform:uppercase;color:var(--gray-500);">Photos</div>
                    </div>
                </div>
                <button class="btn btn-primary w-full mb-2" onclick="app.exportCSV()"><i class="fas fa-file-excel"></i> Export Excel</button>
                <button class="btn btn-secondary w-full mb-2" onclick="app.exportJSON()"><i class="fas fa-code"></i> Export JSON</button>
                <input type="file" id="importFile" accept=".json" style="margin-bottom:4px;">
                <button class="btn btn-secondary w-full mb-4" onclick="app.importJSON()"><i class="fas fa-upload"></i> Import JSON</button>
                <hr style="margin:10px 0;border-color:var(--gray-200);">
                <button class="btn btn-danger w-full" onclick="app.clearAll()"><i class="fas fa-trash"></i> Clear All Data</button>
            </div>
        `;
        this.setPanel(html, 'Data Manager');
    }

    async exportCSV() {
        const insp = await this.db.getAll('inspections');
        if (!insp.length) { Toast.warning('No data'); return; }
        const data = insp.map(i => ({
            'ID': i.id, 'Site': i.siteName, 'Inspector': i.inspector, 'Date': i.dateTime,
            'Location Verified': i.siteLocation ? 'Yes' : 'No',
            'Accessibility': i.accessibility ? 'Yes' : 'No',
            'Site Conditions': i.siteConditions ? 'Yes' : 'No',
            'Infrastructure': i.infrastructure ? 'Yes' : 'No',
            'Protected Species': i.protectedSpecies ? 'Yes' : 'No',
            'Env Impacts': i.environmentalImpacts ? 'Yes' : 'No',
            'Compliance': i.compliance ? 'Yes' : 'No',
            'Conservation': i.conservation ? 'Yes' : 'No',
            'Work Practices': i.workPractices ? 'Yes' : 'No',
            'Health & Safety': i.healthSafety ? 'Yes' : 'No',
            'Risks': i.risksHazards ? 'Yes' : 'No',
            'Control Measures': i.controlMeasures ? 'Yes' : 'No',
            'Equipment Inspected': i.equipmentInspected ? 'Yes' : 'No',
            'Safe Condition': i.safeCondition ? 'Yes' : 'No',
            'Maintenance': i.maintenanceRecords ? 'Yes' : 'No',
            'Industry Standards': i.industryStandards ? 'Yes' : 'No',
            'Heritage Significance': i.heritageSignificance || '',
            'Cultural Sites': i.culturalSites || '',
            'Photos': i.photos?.length || 0
        }));
        const ws = XLSX.utils.json_to_sheet(data);
        const wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, 'Inspections');
        XLSX.writeFile(wb, `SiteInspection_${new Date().toISOString().slice(0,10)}.xlsx`);
        Toast.success('Excel exported');
    }

    async exportJSON() {
        const insp = await this.db.getAll('inspections');
        const drafts = await this.db.getAll('drafts');
        const data = { exportDate: new Date().toISOString(), version: 'Site Inspection 4.0', inspections: insp, drafts: drafts };
        const blob = new Blob([JSON.stringify(data, null, 2)], { type:'application/json' });
        const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = `SiteInspection_Data_${new Date().toISOString().slice(0,10)}.json`; a.click(); URL.revokeObjectURL(a.href);
        Toast.success('JSON exported');
    }

    async importJSON() {
        const file = document.getElementById('importFile')?.files[0];
        if (!file) { Toast.warning('Select a JSON file'); return; }
        const reader = new FileReader();
        reader.onload = async (e) => {
            try {
                const data = JSON.parse(e.target.result);
                let count = 0;
                if (data.inspections) { for (const insp of data.inspections) { await this.db.save(insp, false); count++; } }
                if (data.drafts) { for (const draft of data.drafts) { await this.db.save(draft, true); count++; } }
                Toast.success(`Imported ${count} records`);
                await this.updateStatus();
                this.showDataManager();
            } catch { Toast.error('Invalid JSON'); }
        };
        reader.readAsText(file);
    }

    async clearAll() {
        if (!confirm('⚠️ Delete ALL data? This cannot be undone.')) return;
        if (!confirm('Are you absolutely sure?')) return;
        await this.db.clear('inspections');
        await this.db.clear('drafts');
        Toast.success('All data cleared');
        await this.updateStatus();
        this.showDashboard();
    }

    // ============================================================
    // EVENTS
    // ============================================================
    bindEvents() {
        document.querySelectorAll('.nav-item').forEach(item => {
            item.addEventListener('click', () => {
                document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
                item.classList.add('active');
                const view = item.dataset.view;
                if (view === 'dashboard') this.showDashboard();
                else if (view === 'inspections') this.showInspections();
                else if (view === 'new') this.newInspection();
                else if (view === 'mapview') this.closePanel();
                else if (view === 'drafts') this.showDrafts();
                else if (view === 'data') this.showDataManager();
            });
        });

        document.getElementById('searchBtn').addEventListener('click', () => { const q = document.getElementById('searchAddress').value; if (q.trim()) this.searchAddress(q); });
        document.getElementById('searchAddress').addEventListener('keydown', (e) => { if (e.key === 'Enter') { const q = document.getElementById('searchAddress').value; if (q.trim()) this.searchAddress(q); } });
        document.getElementById('newInspectionBtn').addEventListener('click', () => this.newInspection());
        document.getElementById('listInspectionsBtn').addEventListener('click', () => this.showInspections());
        document.getElementById('closePanelBtn').addEventListener('click', () => this.closePanel());
        document.getElementById('clearMapBtn').addEventListener('click', () => this.clearMap());
        document.getElementById('measureBtn').addEventListener('click', () => this.startMeasure());
        document.getElementById('locateBtn').addEventListener('click', () => this.locateUser());
        document.getElementById('resetMapBtn').addEventListener('click', () => this.resetView());
        document.getElementById('fullscreenBtn').addEventListener('click', () => this.toggleFullscreen());
        document.getElementById('sidebarToggle').addEventListener('click', () => document.getElementById('sidebar').classList.toggle('open'));

        document.querySelectorAll('.layer-item').forEach(el => {
            el.addEventListener('click', () => this.switchLayer(el.dataset.layer));
        });

        document.querySelector('.main').addEventListener('click', () => { if (window.innerWidth <= 768) document.getElementById('sidebar').classList.remove('open'); });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') this.closePanel(); });
    }
}

