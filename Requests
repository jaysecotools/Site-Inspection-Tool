    bindForm() {
        const input = document.getElementById('photoInput');
        const drop = document.getElementById('photoDropZone');
        if (input) { input.onchange = (e) => this.handlePhotos(e.target.files); }
        if (drop) {
            drop.onclick = () => input?.click();
            drop.ondragover = (e) => { e.preventDefault(); drop.classList.add('dragover'); };
            drop.ondragleave = () => { drop.classList.remove('dragover'); };
            drop.ondrop = (e) => { e.preventDefault(); drop.classList.remove('dragover'); if (e.dataTransfer.files.length) this.handlePhotos(e.dataTransfer.files); };
        }
        this.renderGallery();

        document.getElementById('saveDraftBtn')?.addEventListener('click', () => this.saveDraft());
        document.getElementById('finaliseBtn')?.addEventListener('click', () => this.finalise());
        document.getElementById('cancelBtn')?.addEventListener('click', () => this.closePanel());

        document.querySelectorAll('.section-header').forEach(h => {
            h.onclick = () => { h.classList.toggle('collapsed'); if (h.nextElementSibling) h.nextElementSibling.classList.toggle('collapsed'); };
        });

        ['vegHealth','speciesRichness','regeneration','weedCover','habitatQuality','disturbance'].forEach(id => {
            const el = document.getElementById(id);
            if (el) {
                el.oninput = () => {
                    const valSpan = document.getElementById(id + 'Val');
                    if (valSpan) valSpan.textContent = el.value;
                };
            }
        });

        // Update checklist count display
        this.updateChecklistDisplay();
        document.querySelectorAll('.checkbox-group input[type="checkbox"]').forEach(cb => {
            cb.addEventListener('change', () => this.updateChecklistDisplay());
        });
    }

    updateChecklistDisplay() {
        const { total, done } = this.getChecklistCount();
        const summary = document.getElementById('checklistSummary');
        if (summary) {
            summary.innerHTML = `<span class="done">✓ ${done}/${total} completed</span> <span class="pending">${total - done} remaining</span>`;
        }
        const progress = document.getElementById('checklistProgress');
        if (progress) {
            const pct = total > 0 ? (done / total) * 100 : 0;
            progress.style.width = pct + '%';
            progress.style.background = pct >= 80 ? 'var(--success)' : pct >= 50 ? 'var(--warning)' : 'var(--danger)';
        }
    }

    async handlePhotos(files) {
        const maxPhotos = 20;
        const remaining = maxPhotos - this.currentPhotos.length;
        const toProcess = Array.from(files).slice(0, remaining);
        if (Array.from(files).length > remaining) Toast.warning(`Only ${remaining} more photos can be added`);
        let added=0, errors=0;
        for (const file of toProcess) {
            try {
                const reader = new FileReader();
                const data = await new Promise((resolve) => {
                    reader.onload = async (e) => { const compressed = await Utils.compressImage(e.target.result, 800, 800, 0.85); resolve(compressed); };
                    reader.onerror = () => resolve(null);
                    reader.readAsDataURL(file);
                });
                if (!data) { errors++; continue; }
                this.currentPhotos.push({ id:Utils.uuid(), dataURL:data, timestamp:new Date().toISOString(), lat:this.currentLat, lng:this.currentLng, isHero:this.currentPhotos.length===0, filename:file.name });
                added++;
            } catch { errors++; }
        }
        this.renderGallery();
        const countEl = document.querySelector('.photo-count');
        if (countEl) countEl.textContent = `${this.currentPhotos.length} photos`;
        if (added > 0) Toast.success(`${added} photo(s) added`);
        if (errors > 0) Toast.warning(`${errors} photo(s) failed`);
    }

    renderGallery() {
        const g = document.getElementById('photoGallery');
        if (!g) return;
        if (this.currentPhotos.length === 0) {
            g.innerHTML = `<div style="padding:16px;text-align:center;color:var(--gray-400);grid-column:1/-1;"><i class="fas fa-camera" style="font-size:18px;display:block;margin-bottom:2px;"></i> No photos</div>`;
            return;
        }
        g.innerHTML = this.currentPhotos.map((p, i) => `
            <div class="photo-item" data-idx="${i}">
                <img src="${p.dataURL}" alt="Photo ${i+1}" loading="lazy">
                <button class="remove-photo" data-idx="${i}" title="Remove">×</button>
                ${p.isHero ? '<div class="hero-badge">Cover</div>' : ''}
            </div>
        `).join('');
        document.querySelectorAll('.remove-photo').forEach(el => {
            el.onclick = (e) => {
                e.stopPropagation();
                const idx = parseInt(el.dataset.idx);
                this.currentPhotos.splice(idx, 1);
                if (this.currentPhotos.length > 0 && !this.currentPhotos.some(p => p.isHero)) this.currentPhotos[0].isHero = true;
                this.renderGallery();
                const countEl = document.querySelector('.photo-count');
                if (countEl) countEl.textContent = `${this.currentPhotos.length} photos`;
            };
        });
        document.querySelectorAll('.photo-item').forEach((el, idx) => {
            el.onclick = () => { this.currentPhotos.forEach((p,i) => p.isHero = (i===idx)); this.renderGallery(); Toast.success('Cover photo set'); };
        });
    }

    // ============================================================
    // CRUD OPERATIONS
    // ============================================================
    async newInspection() {
        this.currentId = Utils.uuid();
        this.currentPhotos = [];
        this.isDraft = false;
        this.clearMap();
        this.setPanel(this.renderForm({ id: this.currentId }), 'New Site Inspection');
        this.bindForm();
    }

    async loadInspection(id, draft = false) {
        const data = await this.db.get(id, draft);
        if (!data) { Toast.error('Not found'); return; }
        this.currentId = data.id;
        this.currentPhotos = data.photos || [];
        this.isDraft = draft;
        this.clearMap();
        this.loadGeometry(data.geometry || []);
        (data.waypoints || []).forEach(w => { this.drawnItems.addLayer(L.marker([w.lat, w.lng]).bindPopup(`<strong>${Utils.escapeHtml(w.label)}</strong>`)); });
        this.setPanel(this.renderForm(data), draft ? 'Edit Draft' : 'View Inspection');
        this.bindForm();
        const countEl = document.querySelector('.photo-count');
        if (countEl) countEl.textContent = `${this.currentPhotos.length} photos`;
    }

    loadGeometry(geojson) {
        if (!geojson || !geojson.length) return;
        geojson.forEach(g => {
            try {
                const layer = L.geoJSON(g, { style: { color:'#1a5f4a', weight:3, opacity:0.7 } });
                this.drawnItems.addLayer(layer);
                if (g.geometry?.type === 'Polygon' || g.geometry?.type === 'MultiPolygon') this.polygonCount++;
                else if (g.geometry?.type === 'Point') this.waypointCount++;
            } catch {}
        });
        document.getElementById('polygonCount').textContent = this.polygonCount;
        document.getElementById('waypointCount').textContent = this.waypointCount;
    }

    async saveDraft() {
        const data = this.collectForm();
        if (!data.siteName) { Toast.warning('Site name required'); return; }
        data.status = 'draft';
        await this.db.save(data, true);
        this.isDraft = true;
        Toast.success('Draft saved');
        await this.updateStatus();
    }

    async finalise() {
        const data = this.collectForm();
        if (!data.siteName) { Toast.warning('Site name required'); return; }
        data.status = 'finalised';
        await this.db.save(data, false);
        await this.db.delete(data.id, true);
        await this.generateReport(data);
        this.closePanel();
        await this.updateStatus();
        this.showInspections();
    }

    // ============================================================
    // REPORT GENERATION
    // ============================================================
    async generateReport(inspection) {
        try {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF('p', 'mm', 'a4');
            const pageWidth = 210, pageHeight = 297, margin = 18;
            let y = margin;
            const colour = '#1a5f4a';

            const addText = (text, size=10, color='#333') => {
                if (!text) return;
                const clean = Utils.cleanText(text);
                if (!clean) return;
                doc.setFontSize(size);
                doc.setTextColor(color);
                const lines = doc.splitTextToSize(clean, pageWidth - 2 * margin);
                const lineHeight = size * 0.45;
                const totalHeight = lines.length * lineHeight + 1.5;
                if (y + totalHeight > pageHeight - margin - 8) { doc.addPage(); y = margin + 5; addFooter(doc,inspection,pageWidth,pageHeight,margin); }
                doc.text(lines, margin, y);
                y += totalHeight;
            };
            const addTitle = (text, size=18, color=colour) => {
                const clean = Utils.cleanText(text);
                if (!clean) return;
                doc.setFontSize(size);
                doc.setTextColor(color);
                doc.text(clean, margin, y);
                y += size * 0.4 + 2;
            };
            const drawLine = () => { doc.setDrawColor(colour); doc.setLineWidth(0.5); doc.line(margin, y, pageWidth - margin, y); y += 5; };
            const addFooter = (doc, inspection, pageWidth, pageHeight, margin) => {
                doc.setDrawColor(colour); doc.setLineWidth(0.3);
                doc.line(margin, pageHeight - 12, pageWidth - margin, pageHeight - 12);
                doc.setFontSize(7); doc.setTextColor('#aaa');
                doc.text(inspection.id, margin, pageHeight - 5);
                doc.text(Utils.formatDate(inspection.dateTime), pageWidth - margin, pageHeight - 5, { align:'right' });
                doc.text(`Page ${doc.internal.getCurrentPageInfo().pageNumber}`, pageWidth/2, pageHeight - 5, { align:'center' });
            };

            // Cover
            doc.setFillColor(colour); doc.rect(0,0,pageWidth,6,'F');
            y = 30;
            doc.setFontSize(28); doc.setTextColor(colour);
            doc.text('SITE INSPECTION', margin, y);
            y += 14;
            doc.text('REPORT', margin, y);
            y += 12;
            drawLine();
            y += 6;
            doc.setFontSize(20); doc.setTextColor('#222');
            doc.text(Utils.cleanText(inspection.siteName || 'Site Assessment'), margin, y);
            y += 12;
            doc.setFontSize(11); doc.setTextColor('#555');
            doc.text(`Inspector: ${Utils.cleanText(inspection.inspector || 'Not specified')}`, margin, y);
            y += 6;
            doc.text(`Date: ${Utils.formatDate(inspection.dateTime)}`, margin, y);
            y += 6;
            doc.text(`Report ID: ${inspection.id}`, margin, y);
            y += 10;

            if (inspection.photos && inspection.photos.length > 0) {
                const hero = inspection.photos.find(p => p.isHero) || inspection.photos[0];
                try {
                    const img = new Image();
                    const imgData = await new Promise((resolve) => { img.onload = () => resolve({ width:img.width, height:img.height }); img.onerror = () => resolve(null); img.src = hero.dataURL; });
                    if (imgData) {
                        const maxImgWidth = pageWidth - 2*margin - 20, maxImgHeight = 70;
                        let imgWidth = maxImgWidth, imgHeight = (imgData.height / imgData.width) * maxImgWidth;
                        if (imgHeight > maxImgHeight) { imgHeight = maxImgHeight; imgWidth = (imgData.width / imgData.height) * maxImgHeight; }
                        const xOffset = margin + 10 + (maxImgWidth - imgWidth) / 2;
                        doc.addImage(hero.dataURL, 'JPEG', xOffset, y, imgWidth, imgHeight);
                        y += imgHeight + 8;
                        doc.setFontSize(7); doc.setTextColor('#999');
                        doc.text(`Cover Photo: ${Utils.cleanText(inspection.siteName)}`, margin + 10, y);
                        y += 6;
                    } else { doc.setFillColor('#f5f5f5'); doc.roundedRect(margin+10, y, pageWidth-2*margin-20, 45, 4, 4, 'F'); doc.setFontSize(10); doc.setTextColor('#999'); doc.text('Project Photograph', pageWidth/2, y+22, { align:'center' }); y += 50; }
                } catch { doc.setFillColor('#f5f5f5'); doc.roundedRect(margin+10, y, pageWidth-2*margin-20, 45, 4, 4, 'F'); doc.setFontSize(10); doc.setTextColor('#999'); doc.text('Project Photograph', pageWidth/2, y+22, { align:'center' }); y += 50; }
            }
            doc.setFillColor(colour); doc.rect(0, pageHeight-6, pageWidth, 3, 'F');
            doc.setFontSize(7); doc.setTextColor('#999');
            doc.text('© Site Inspection Tool v4.0', margin, pageHeight-3);
            doc.text('Site Inspection Report', pageWidth/2, pageHeight-3, { align:'center' });
            doc.text('Page 1', pageWidth - margin, pageHeight-3, { align:'right' });

            // Checklist Summary
            doc.addPage(); y = margin + 5; addFooter(doc, inspection, pageWidth, pageHeight, margin);
            addTitle('CHECKLIST SUMMARY', 18); drawLine(); y += 4;

            const sections = [
                { title: 'General Site Conditions', items: [
                    ['Verified site location and boundaries', inspection.siteLocation],
                    ['Assessed accessibility and entry points', inspection.accessibility],
                    ['Evaluated site conditions (topography, soil, vegetation, drainage)', inspection.siteConditions],
                    ['Identified existing infrastructure or features', inspection.infrastructure]
                ]},
                { title: 'Environmental Considerations', items: [
                    ['Assessed presence of protected flora or fauna', inspection.protectedSpecies],
                    ['Evaluated potential environmental impacts', inspection.environmentalImpacts],
                    ['Verified compliance with environmental regulations', inspection.compliance],
                    ['Noted areas of conservation significance', inspection.conservation]
                ]},
                { title: 'Work Practices & Procedures', items: [
                    ['Observed and evaluated work practices', inspection.workPractices],
                    ['Assessed compliance with health and safety regulations', inspection.healthSafety],
                    ['Identified potential risks and hazards', inspection.risksHazards],
                    ['Reviewed implementation of control measures', inspection.controlMeasures]
                ]},
                { title: 'Equipment & Machinery', items: [
                    ['Inspected equipment and machinery', inspection.equipmentInspected],
                    ['Ensured equipment in safe working condition', inspection.safeCondition],
                    ['Checked maintenance and service records', inspection.maintenanceRecords],
                    ['Verified compliance with industry standards', inspection.industryStandards]
                ]}
            ];

            sections.forEach(section => {
                if (y > pageHeight - 50) { doc.addPage(); y = margin + 5; addFooter(doc, inspection, pageWidth, pageHeight, margin); }
                doc.setFontSize(12); doc.setTextColor(colour);
                doc.text(section.title, margin, y);
                y += 5;
                doc.setFontSize(8); doc.setTextColor('#333');
                section.items.forEach(([label, done]) => {
                    const status = done ? '✓' : '✗';
                    const color = done ? '#10b981' : '#dc2626';
                    doc.setTextColor(color);
                    doc.text(`${status}  ${label}`, margin + 4, y);
                    y += 5;
                });
                y += 4;
            });

            // Aboriginal Heritage
            if (y > pageHeight - 40) { doc.addPage(); y = margin + 5; addFooter(doc, inspection, pageWidth, pageHeight, margin); }
            addTitle('ABORIGINAL HERITAGE', 16); drawLine(); y += 4;
            doc.setFontSize(10); doc.setTextColor('#333');
            doc.text(`Heritage Significance: ${inspection.heritageSignificance || 'Not Assessed'}`, margin, y);
            y += 6;
            doc.text('Cultural Sites / Artefacts:', margin, y);
            y += 4;
            addText(inspection.culturalSites || 'No cultural sites recorded.', 9);
            y += 4;
            doc.text('Heritage Management Notes:', margin, y);
            y += 4;
            addText(inspection.aboriginalHeritage || 'No heritage management notes.', 9);

            // Observations & Recommendations
            if (y > pageHeight - 40) { doc.addPage(); y = margin + 5; addFooter(doc, inspection, pageWidth, pageHeight, margin); }
            addTitle('OBSERVATIONS', 14); drawLine(); y += 4;
            addText(inspection.observations || 'No observations recorded.', 10);
            y += 4;
            if (y > pageHeight - 40) { doc.addPage(); y = margin + 5; addFooter(doc, inspection, pageWidth, pageHeight, margin); }
            addTitle('RECOMMENDATIONS', 14); drawLine(); y += 4;
            addText(inspection.recommendations || 'No specific recommendations recorded.', 10);

            // Photos
            if (inspection.photos && inspection.photos.length > 0) {
                doc.addPage(); y = margin + 5; addFooter(doc, inspection, pageWidth, pageHeight, margin);
                addTitle('PHOTO DOCUMENTATION', 18); drawLine(); y += 6;
                const photos = inspection.photos.slice(0, 15);
                const photoSize = 50, gap = 5;
                const maxCols = Math.floor((pageWidth - 2 * margin + gap) / (photoSize + gap));
                let row = 0, col = 0;
                for (let i = 0; i < photos.length; i++) {
                    const p = photos[i];
                    const px = margin + col * (photoSize + gap);
                    const py = y + row * (photoSize + gap + 8);
                    if (py + photoSize + 10 > pageHeight - margin - 15) {
                        doc.addPage(); y = margin + 5; addFooter(doc, inspection, pageWidth, pageHeight, margin);
                        addTitle('PHOTO DOCUMENTATION (continued)', 14); drawLine(); y += 6;
                        row = 0; col = 0;
                    }
                    try {
                        const img = new Image();
                        const imgData = await new Promise((resolve) => { img.onload = () => resolve({ width:img.width, height:img.height }); img.onerror = () => resolve(null); img.src = p.dataURL; });
                        let imgWidth = photoSize, imgHeight = photoSize * 0.75;
                        if (imgData) {
                            const aspect = imgData.width / imgData.height;
                            if (aspect > 1) { imgWidth = photoSize; imgHeight = photoSize / aspect; } else { imgHeight = photoSize; imgWidth = photoSize * aspect; }
                        }
                        const xOff = px + (photoSize - imgWidth) / 2;
                        const yOff = py + (photoSize * 0.75 - imgHeight) / 2;
                        doc.addImage(p.dataURL, 'JPEG', xOff, yOff, imgWidth, imgHeight);
                        doc.setFontSize(6); doc.setTextColor('#666');
                        doc.text(`Photo ${i+1}`, px + 2, py + photoSize * 0.75 + 4);
                    } catch { doc.setFillColor('#f0f0f0'); doc.roundedRect(px, py, photoSize, photoSize * 0.75, 2, 2, 'F'); doc.setFontSize(8); doc.setTextColor('#999'); doc.text(`Photo ${i+1}`, px + photoSize/2 - 10, py + photoSize * 0.375); }
                    col++; if (col >= maxCols) { col = 0; row++; }
                }
            }

            doc.save(`SiteInspection_${inspection.id}.pdf`);
            Toast.success('Report generated successfully');
        } catch (e) { console.error(e); Toast.error('Report error: ' + e.message); }
    }

