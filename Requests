<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Site Inspection - Cultural Heritage & Ecology</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet-draw@1.0.4/dist/leaflet.draw.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet-draw@1.0.4/dist/leaflet.draw.js"></script>
    <script src="https://unpkg.com/turf@6.5.0/turf.min.js"></script>
    <script src="https://cdn.sheetjs.com/xlsx-0.20.2/package/dist/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.31/jspdf.plugin.autotable.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --primary: #1a5f4a;
            --primary-dark: #0f3b2e;
            --primary-light: #2d8a6e;
            --gold: #d4a843;
            --gray-50: #f8fafc;
            --gray-100: #f1f5f9;
            --gray-200: #e2e8f0;
            --gray-300: #cbd5e1;
            --gray-400: #94a3b8;
            --gray-500: #64748b;
            --gray-600: #475569;
            --gray-700: #334155;
            --gray-800: #1e293b;
            --gray-900: #0f172a;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #dc2626;
            --info: #3b82f6;
            --shadow: 0 4px 16px rgba(0,0,0,0.10);
            --shadow-lg: 0 12px 40px rgba(0,0,0,0.15);
            --radius: 10px;
            --radius-sm: 6px;
            --transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: var(--gray-100); height: 100vh; overflow: hidden; }
        .app { display: flex; height: 100vh; width: 100vw; overflow: hidden; }

        .sidebar {
            width: 240px;
            background: linear-gradient(180deg, var(--primary-dark) 0%, #0a241f 100%);
            color: #e8f0ed;
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
            z-index: 200;
            box-shadow: 2px 0 20px rgba(0,0,0,0.15);
            transition: transform var(--transition);
        }
        .sidebar-brand { padding: 16px 18px; border-bottom: 1px solid rgba(255,255,255,0.06); }
        .sidebar-brand h1 { font-size: 1.1rem; font-weight: 700; display: flex; align-items: center; gap: 10px; }
        .sidebar-brand h1 i { color: var(--primary-light); }
        .sidebar-brand .version { font-size: 0.5rem; opacity: 0.4; margin-top: 2px; text-transform: uppercase; letter-spacing: 1px; }
        .sidebar-nav { flex: 1; padding: 8px; overflow-y: auto; }
        .sidebar-nav::-webkit-scrollbar { width: 3px; }
        .sidebar-nav::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 10px; }
        .nav-item {
            padding: 9px 12px;
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            border-radius: var(--radius-sm);
            margin: 1px 0;
            transition: all var(--transition);
            font-size: 0.8rem;
            color: rgba(255,255,255,0.65);
            border: none;
            background: transparent;
            width: 100%;
            text-align: left;
            font-family: inherit;
        }
        .nav-item:hover { background: rgba(255,255,255,0.06); color: #fff; }
        .nav-item.active { background: rgba(45, 138, 110, 0.25); color: #fff; border-left: 3px solid var(--primary-light); }
        .nav-item i { width: 18px; text-align: center; font-size: 0.85rem; }
        .nav-item .badge { margin-left: auto; background: rgba(255,255,255,0.12); padding: 0px 7px; border-radius: 20px; font-size: 0.5rem; font-weight: 600; }

        .main { flex: 1; display: flex; flex-direction: column; overflow: hidden; background: var(--gray-50); }

        .toolbar {
            background: rgba(255,255,255,0.9);
            backdrop-filter: blur(12px);
            padding: 5px 14px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 4px;
            border-bottom: 1px solid var(--gray-200);
            z-index: 150;
            flex-shrink: 0;
            min-height: 44px;
        }
        .toolbar-left, .toolbar-right { display: flex; align-items: center; gap: 4px; flex-wrap: wrap; }
        .toolbar-divider { width: 1px; height: 20px; background: var(--gray-200); margin: 0 4px; }
        .btn {
            padding: 5px 10px;
            border-radius: var(--radius-sm);
            border: none;
            font-weight: 600;
            font-size: 0.65rem;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            transition: all var(--transition);
            font-family: inherit;
            white-space: nowrap;
        }
        .btn:active { transform: scale(0.95); }
        .btn-primary { background: var(--primary); color: white; }
        .btn-primary:hover { background: var(--primary-dark); box-shadow: var(--shadow); }
        .btn-secondary { background: var(--gray-100); color: var(--gray-700); border: 1px solid var(--gray-200); }
        .btn-secondary:hover { background: var(--gray-200); }
        .btn-success { background: var(--success); color: white; }
        .btn-success:hover { background: #059669; }
        .btn-danger { background: var(--danger); color: white; }
        .btn-danger:hover { background: #b91c1c; }
        .btn-sm { padding: 2px 7px; font-size: 0.55rem; }

        .search-box {
            display: flex;
            align-items: center;
            gap: 4px;
            background: white;
            border: 1px solid var(--gray-200);
            border-radius: var(--radius-sm);
            padding: 2px 4px;
        }
        .search-box input { border: none; padding: 3px 6px; font-size: 0.65rem; width: 140px; outline: none; background: transparent; }

        .map-wrapper { flex: 1; position: relative; min-height: 0; overflow: hidden; }
        #map { height: 100%; width: 100%; position: absolute; top: 0; left: 0; }

        .map-status {
            position: absolute;
            bottom: 10px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0,0,0,0.75);
            backdrop-filter: blur(8px);
            color: white;
            padding: 3px 12px;
            border-radius: 30px;
            font-size: 0.55rem;
            z-index: 100;
            display: flex;
            gap: 10px;
            align-items: center;
            pointer-events: none;
            font-weight: 500;
        }
        .map-status .dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; margin-right: 3px; }
        .map-status .dot.green { background: var(--success); }

        .map-tools {
            position: absolute;
            top: 70px;
            right: 10px;
            display: flex;
            flex-direction: column;
            gap: 4px;
            z-index: 300;
        }
        .map-tools .tool-btn {
            background: white;
            border: none;
            border-radius: var(--radius-sm);
            padding: 6px;
            box-shadow: var(--shadow);
            cursor: pointer;
            transition: all var(--transition);
            color: var(--gray-600);
            font-size: 0.75rem;
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .map-tools .tool-btn:hover { background: var(--primary); color: white; }

        .layer-control {
            position: absolute;
            top: 70px;
            left: 10px;
            background: white;
            border-radius: var(--radius-sm);
            padding: 4px;
            box-shadow: var(--shadow);
            z-index: 250;
            min-width: 90px;
        }
        .layer-control .layer-item {
            padding: 5px 10px;
            font-size: 0.6rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 6px;
            border-radius: var(--radius-sm);
            transition: all var(--transition);
            font-weight: 500;
            color: var(--gray-600);
            border: none;
            background: transparent;
            width: 100%;
            text-align: left;
            font-family: inherit;
        }
        .layer-control .layer-item:hover { background: var(--gray-100); }
        .layer-control .layer-item.active { background: var(--primary); color: white; }
        .layer-control .layer-item .indicator {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            border: 2px solid var(--gray-300);
            flex-shrink: 0;
        }
        .layer-control .layer-item.active .indicator { border-color: white; background: var(--primary-light); }

        .panel {
            position: fixed;
            top: 0;
            right: 0;
            width: 720px;
            max-width: 94vw;
            height: 100vh;
            background: white;
            box-shadow: var(--shadow-lg);
            transform: translateX(100%);
            transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
            z-index: 1000;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        .panel.open { transform: translateX(0); }
        .panel-header {
            padding: 12px 18px;
            border-bottom: 1px solid var(--gray-200);
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: white;
            flex-shrink: 0;
            min-height: 50px;
        }
        .panel-header h3 { font-size: 0.9rem; font-weight: 700; color: var(--gray-800); display: flex; align-items: center; gap: 8px; }
        .panel-header h3 i { color: var(--primary); }
        .panel-body {
            flex: 1;
            overflow-y: auto;
            padding: 14px 18px 20px;
        }
        .panel-body::-webkit-scrollbar { width: 4px; }
        .panel-body::-webkit-scrollbar-thumb { background: var(--gray-300); border-radius: 10px; }

        .form-section {
            margin-bottom: 12px;
            border: 1px solid var(--gray-200);
            border-radius: var(--radius);
            overflow: hidden;
            background: white;
        }
        .section-header {
            background: var(--gray-50);
            padding: 8px 12px;
            font-weight: 700;
            font-size: 0.65rem;
            color: var(--primary);
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: none;
            width: 100%;
            font-family: inherit;
            text-align: left;
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }
        .section-header:hover { background: var(--gray-100); }
        .section-header.collapsed i:last-child { transform: rotate(-90deg); }
        .section-content { padding: 12px; border-top: 1px solid var(--gray-200); }
        .section-content.collapsed { display: none; }
        .form-group { margin-bottom: 10px; }
        .form-group:last-child { margin-bottom: 0; }
        .form-group label {
            display: block;
            font-size: 0.6rem;
            font-weight: 700;
            text-transform: uppercase;
            color: var(--gray-600);
            margin-bottom: 2px;
            letter-spacing: 0.3px;
        }
        .form-group label .required { color: var(--danger); }
        input, select, textarea {
            width: 100%;
            padding: 6px 9px;
            border: 1.5px solid var(--gray-200);
            border-radius: var(--radius-sm);
            font-size: 0.75rem;
            font-family: inherit;
            transition: all var(--transition);
            background: white;
            color: var(--gray-800);
        }
        input:focus, select:focus, textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(26, 95, 74, 0.1);
        }
        textarea { resize: vertical; min-height: 40px; }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .checkbox-group {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4px 10px;
            padding: 4px 0;
        }
        .checkbox-group label {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.7rem;
            font-weight: 500;
            color: var(--gray-700);
            cursor: pointer;
            padding: 2px 4px;
            border-radius: 4px;
            transition: background var(--transition);
        }
        .checkbox-group label:hover { background: var(--gray-50); }
        .checkbox-group input[type="checkbox"] {
            width: 14px;
            height: 14px;
            flex-shrink: 0;
            cursor: pointer;
        }
        .checklist-summary {
            font-size: 0.6rem;
            color: var(--gray-500);
            padding: 4px 0;
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }
        .checklist-summary .done { color: var(--success); }
        .checklist-summary .pending { color: var(--gray-400); }
        @media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } .checkbox-group { grid-template-columns: 1fr; } }

        .photo-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
            gap: 6px;
            margin-top: 6px;
            max-height: 200px;
            overflow-y: auto;
            padding: 2px;
        }
        .photo-item {
            position: relative;
            aspect-ratio: 1;
            border-radius: var(--radius-sm);
            overflow: hidden;
            border: 2px solid var(--gray-200);
            cursor: pointer;
            background: var(--gray-100);
        }
        .photo-item:hover { border-color: var(--primary); transform: scale(1.03); }
        .photo-item img { width: 100%; height: 100%; object-fit: cover; }
        .photo-item .remove-photo {
            position: absolute;
            top: 2px;
            right: 2px;
            background: rgba(220,38,38,0.9);
            color: white;
            border-radius: 50%;
            width: 18px;
            height: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 10px;
            border: none;
        }
        .photo-item .hero-badge {
            position: absolute;
            top: 2px;
            left: 2px;
            background: var(--warning);
            color: var(--gray-900);
            padding: 0px 5px;
            border-radius: 20px;
            font-size: 0.45rem;
            font-weight: 700;
        }
        .photo-upload-area {
            border: 2px dashed var(--gray-300);
            border-radius: var(--radius);
            padding: 16px;
            text-align: center;
            cursor: pointer;
            transition: all var(--transition);
            background: var(--gray-50);
        }
        .photo-upload-area:hover { border-color: var(--primary); background: rgba(26,95,74,0.04); }
        .photo-upload-area.dragover { border-color: var(--primary); background: rgba(26,95,74,0.08); }
        .photo-upload-area i { font-size: 1.4rem; color: var(--gray-400); display: block; margin-bottom: 2px; }
        .photo-upload-area p { font-size: 0.65rem; color: var(--gray-500); }

        .rating-badge {
            display: inline-block;
            padding: 1px 7px;
            border-radius: 20px;
            font-size: 0.5rem;
            font-weight: 700;
            text-transform: uppercase;
        }
        .rating-badge.excellent { background: rgba(16,185,129,0.15); color: var(--success); }
        .rating-badge.good { background: rgba(59,130,246,0.15); color: var(--info); }
        .rating-badge.moderate { background: rgba(245,158,11,0.15); color: var(--warning); }
        .rating-badge.poor { background: rgba(220,38,38,0.12); color: var(--danger); }

        .inspection-card {
            border: 1px solid var(--gray-200);
            border-radius: var(--radius);
            padding: 12px;
            margin-bottom: 8px;
            background: white;
            transition: all var(--transition);
            position: relative;
            overflow: hidden;
        }
        .inspection-card::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 4px;
        }
        .inspection-card:hover { box-shadow: var(--shadow); transform: translateY(-2px); border-color: var(--primary); }
        .inspection-card .card-title { font-weight: 700; font-size: 0.85rem; color: var(--gray-800); }
        .inspection-card .card-meta { font-size: 0.6rem; color: var(--gray-500); margin-top: 2px; display: flex; gap: 8px; flex-wrap: wrap; }
        .inspection-card .card-actions { display: flex; gap: 4px; margin-top: 6px; flex-wrap: wrap; }
        .inspection-card .card-badge {
            position: absolute;
            top: 8px;
            right: 8px;
            font-size: 0.5rem;
            font-weight: 700;
            padding: 1px 7px;
            border-radius: 20px;
            text-transform: uppercase;
        }
        .health-meter {
            background: var(--gray-200);
            border-radius: 20px;
            height: 4px;
            overflow: hidden;
            margin: 4px 0;
        }
        .health-fill { height: 100%; border-radius: 20px; transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1); }

        .toast-container {
            position: fixed;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 9999;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            pointer-events: none;
            max-width: 90vw;
        }
        .toast {
            background: var(--gray-800);
            color: white;
            padding: 8px 18px;
            border-radius: 30px;
            font-size: 0.7rem;
            font-weight: 500;
            box-shadow: var(--shadow-lg);
            pointer-events: auto;
            animation: toastIn 0.3s cubic-bezier(0.22,1,0.36,1), toastOut 0.3s 2.7s cubic-bezier(0.22,1,0.36,1) forwards;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .toast.success { background: var(--primary); }
        .toast.warning { background: var(--warning); color: var(--gray-900); }
        .toast.error { background: var(--danger); }
        .toast.info { background: var(--info); }
        @keyframes toastIn { from { opacity:0; transform:translateY(16px) scale(0.95); } to { opacity:1; transform:translateY(0) scale(1); } }
        @keyframes toastOut { from { opacity:1; transform:translateY(0) scale(1); } to { opacity:0; transform:translateY(-16px) scale(0.95); } }

        .storage-status {
            position: fixed;
            bottom: 10px;
            left: 10px;
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(8px);
            color: white;
            padding: 2px 10px;
            border-radius: 20px;
            font-size: 0.5rem;
            font-family: monospace;
            z-index: 100;
            pointer-events: none;
            display: flex;
            align-items: center;
            gap: 4px;
        }
        .storage-status .dot { width: 5px; height: 5px; border-radius: 50%; display: inline-block; background: var(--success); }

        @media (max-width: 768px) {
            .sidebar {
                position: fixed;
                left: 0; top: 0; bottom: 0;
                width: 260px;
                transform: translateX(-100%);
                z-index: 300;
                box-shadow: 2px 0 30px rgba(0,0,0,0.3);
            }
            .sidebar.open { transform: translateX(0); }
            .sidebar-toggle {
                display: flex !important;
                position: fixed;
                top: 8px; left: 8px;
                z-index: 250;
                background: white;
                border: none;
                padding: 5px 8px;
                border-radius: var(--radius-sm);
                box-shadow: var(--shadow);
                cursor: pointer;
                font-size: 0.9rem;
                color: var(--gray-700);
            }
            .toolbar-left .btn span { display: none; }
            .panel { width: 100vw; max-width: 100vw; }
        }
        @media (prefers-color-scheme: dark) {
            :root {
                --gray-50: #1a242b;
                --gray-100: #1f2a33;
                --gray-200: #2d3a42;
                --gray-300: #4a5a66;
                --gray-400: #6b7d8a;
                --gray-500: #8a9ba8;
                --gray-600: #b8c4cc;
                --gray-700: #dce3e8;
                --gray-800: #f0f3f5;
                --gray-900: #fafbfc;
            }
            body { background: var(--gray-100); }
            .panel, .panel-header, .form-section, .inspection-card, .layer-control { background: var(--gray-50); border-color: var(--gray-200); }
            input, select, textarea { background: var(--gray-100); border-color: var(--gray-200); color: var(--gray-800); }
            .btn-secondary { background: var(--gray-100); border-color: var(--gray-200); color: var(--gray-700); }
            .toolbar { background: rgba(26,36,43,0.9); backdrop-filter: blur(12px); border-color: var(--gray-200); }
            .map-tools .tool-btn { background: var(--gray-50); color: var(--gray-600); }
            .photo-upload-area { background: var(--gray-100); border-color: var(--gray-200); }
        }
        .text-muted { color: var(--gray-400); font-size: 0.65rem; }
        .text-sm { font-size: 0.65rem; }
        .text-xs { font-size: 0.55rem; }
        .mt-2 { margin-top: 4px; }
        .mt-3 { margin-top: 8px; }
        .mb-2 { margin-bottom: 4px; }
        .mb-4 { margin-bottom: 12px; }
        .flex { display: flex; }
        .flex-between { display: flex; justify-content: space-between; align-items: center; }
        .gap-2 { gap: 4px; }
        .w-full { width: 100%; }
    </style>
</head>
<body>

<div class="app">
    <nav class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <h1><i class="fas fa-clipboard-check"></i> InspectPro</h1>
            <div class="version">Site Inspection v4.0</div>
        </div>
        <div class="sidebar-nav">
            <button class="nav-item active" data-view="dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</button>
            <button class="nav-item" data-view="inspections"><i class="fas fa-clipboard-list"></i> Inspections <span class="badge" id="inspCount">0</span></button>
            <button class="nav-item" data-view="new"><i class="fas fa-plus-circle"></i> New Inspection</button>
            <button class="nav-item" data-view="mapview"><i class="fas fa-map"></i> Map View</button>
            <button class="nav-item" data-view="drafts"><i class="fas fa-save"></i> Drafts <span class="badge" id="draftCount">0</span></button>
            <button class="nav-item" data-view="data"><i class="fas fa-database"></i> Data Manager</button>
        </div>
    </nav>

    <div class="main">
        <header class="toolbar">
            <div class="toolbar-left">
                <button class="sidebar-toggle" id="sidebarToggle"><i class="fas fa-bars"></i></button>
                <div class="toolbar-divider"></div>
                <div class="search-box">
                    <input type="text" id="searchAddress" placeholder="Search address...">
