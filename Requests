<script>
// ============================================================
// UTILITIES
// ============================================================
const Utils = {
    uuid() { return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => { const r = Math.random()*16|0; return (c==='x'?r:(r&0x3|0x8)).toString(16); }); },
    escapeHtml(str) { if (!str) return ''; return str.replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'})[m]); },
    cleanText(str) { if (!str) return ''; return str.replace(/[^\w\s.,!?\-()'"]/g, ' ').trim(); },
    formatDate(isoStr) { if (!isoStr) return '—'; try { const d = new Date(isoStr); return d.toLocaleDateString('en-AU', { year:'numeric', month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' }); } catch { return isoStr; } },
    truncate(str, len=40) { return str && str.length > len ? str.slice(0,len)+'…' : str||''; },
    clamp(val, min, max) { return Math.max(min, Math.min(max, val)); },
    round(val, d=1) { return Number(val.toFixed(d)); },
    compressImage(dataURL, maxWidth=800, maxHeight=800, quality=0.85) {
        return new Promise((resolve) => {
            const img = new Image();
            img.onload = () => {
                const canvas = document.createElement('canvas');
                let w = img.width, h = img.height;
                if (w > maxWidth) { h = (h * maxWidth) / w; w = maxWidth; }
                if (h > maxHeight) { w = (w * maxHeight) / h; h = maxHeight; }
                canvas.width = Math.round(w); canvas.height = Math.round(h);
                const ctx = canvas.getContext('2d');
                ctx.imageSmoothingEnabled = true; ctx.imageSmoothingQuality = 'high';
                ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
                resolve(canvas.toDataURL('image/jpeg', quality));
            };
            img.onerror = () => resolve(dataURL);
            img.src = dataURL;
        });
    }
};

const Toast = {
    show(msg, type='info', duration=3000) {
        const container = document.getElementById('toastContainer');
        const toast = document.createElement('div');
        const icons = { success:'fa-check-circle', warning:'fa-exclamation-triangle', error:'fa-times-circle', info:'fa-info-circle' };
        toast.className = `toast ${type}`;
        toast.innerHTML = `<i class="fas ${icons[type] || icons.info}"></i> ${Utils.escapeHtml(msg)}`;
        container.appendChild(toast);
        setTimeout(() => { if (toast.parentNode) toast.remove(); }, duration);
    },
    success(msg) { this.show(msg,'success'); },
    warning(msg) { this.show(msg,'warning'); },
    error(msg) { this.show(msg,'error'); },
    info(msg) { this.show(msg,'info'); }
};

// ============================================================
// DATABASE
// ============================================================
class Database {
    constructor() { this.data = { inspections:[], drafts:[] }; this._loadFromStorage(); }
    _loadFromStorage() { try { const saved = localStorage.getItem('InspectionData'); if (saved) this.data = JSON.parse(saved); } catch {} }
    _saveToStorage() { try { localStorage.setItem('InspectionData', JSON.stringify(this.data)); } catch {} }
    async save(item, isDraft=false) {
        const store = isDraft ? 'drafts' : 'inspections';
        const existing = this.data[store].findIndex(i => i.id === item.id);
        if (existing >= 0) this.data[store][existing] = item;
        else this.data[store].push(item);
        this._saveToStorage();
        return item;
    }
    async getAll(store='inspections') { return this.data[store] || []; }
    async get(id, isDraft=false) {
        const store = isDraft ? 'drafts' : 'inspections';
        return this.data[store].find(i => i.id === id) || null;
    }
    async delete(id, isDraft=false) {
        const store = isDraft ? 'drafts' : 'inspections';
        this.data[store] = this.data[store].filter(i => i.id !== id);
        this._saveToStorage();
    }
    async count(store='inspections') { return (this.data[store] || []).length; }
    async clear(store='inspections') { this.data[store] = []; this._saveToStorage(); }
}

// ============================================================
// APP
// ============================================================
class App {
    constructor() {
        this.db = new Database();
        this.map = null;
        this.drawnItems = null;
        this.currentId = null;
        this.currentPhotos = [];
        this.isDraft = false;
        this.currentLat = -42.8806;
        this.currentLng = 147.3250;
        this.polygonCount = 0;
        this.waypointCount = 0;
        this.measureMode = false;
        this.measurePoints = [];
        this.measureLine = null;
        this.measureMarkers = [];
        this.gpsMarker = null;
        this.initialized = false;
        this.currentLayer = 'streets';
        this.layers = {};
        this.searchMarker = null;
        this.checklistState = {
            general: { siteLocation: false, accessibility: false, siteConditions: false, infrastructure: false },
            environmental: { protectedSpecies: false, environmentalImpacts: false, compliance: false, conservation: false },
            workPractices: { workPractices: false, healthSafety: false, risksHazards: false, controlMeasures: false },
            equipment: { equipmentInspected: false, safeCondition: false, maintenanceRecords: false, industryStandards: false }
        };
    }

    init() {
        if (this.initialized) return;
        this.initMap();
        this.initGPS();
        this.updateStatus();
        this.bindEvents();
        this.showDashboard();
        this.initialized = true;
        Toast.success('Site Inspection Tool Ready');
    }

    initMap() {
        this.map = L.map('map', { center: [-42.8806, 147.3250], zoom: 10, zoomControl: false });
        this.layers = {
            streets: L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', { attribution: '&copy; OpenStreetMap' }),
            satellite: L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', { attribution: '&copy; Esri' }),
            topo: L.tileLayer('https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png', { attribution: '&copy; OpenTopoMap' })
        };
        this.layers.streets.addTo(this.map);
        L.control.zoom({ position: 'bottomright' }).addTo(this.map);

        this.drawnItems = L.featureGroup().addTo(this.map);
        const drawControl = new L.Control.Draw({
            position: 'topleft',
            draw: { polygon: { shapeOptions: { color: '#1a5f4a', weight: 3, opacity: 0.7 }, showArea: true }, rectangle: { shapeOptions: { color: '#1a5f4a', weight: 3 } }, marker: true, circle: false, polyline: false },
            edit: { featureGroup: this.drawnItems, remove: true }
        });
        this.map.addControl(drawControl);

        this.map.on(L.Draw.Event.CREATED, (e) => {
            const layer = e.layer;
            if (e.layerType === 'polygon' || e.layerType === 'rectangle') {
                this.polygonCount++;
                document.getElementById('polygonCount').textContent = this.polygonCount;
                try { const area = turf.area(layer.toGeoJSON()) / 10000; Toast.success(`Polygon: ${area.toFixed(2)} ha`); } catch {}
            } else if (e.layerType === 'marker') {
                this.waypointCount++;
                document.getElementById('waypointCount').textContent = this.waypointCount;
                Toast.success(`Waypoint ${this.waypointCount}`);
            }
            this.drawnItems.addLayer(layer);
        });
        this.map.on('click', (e) => { this.currentLat = e.latlng.lat; this.currentLng = e.latlng.lng; });
        document.getElementById('polygonCount').textContent = '0';
        document.getElementById('waypointCount').textContent = '0';
    }

    switchLayer(name) {
        if (this.currentLayer === name) return;
        Object.values(this.layers).forEach(layer => { if (this.map.hasLayer(layer)) this.map.removeLayer(layer); });
        this.currentLayer = name;
        const layer = this.layers[name];
        if (layer) {
            layer.addTo(this.map);
            setTimeout(() => this.map.invalidateSize(true), 100);
            document.querySelectorAll('.layer-item').forEach(el => el.classList.toggle('active', el.dataset.layer === name));
        }
    }

    async searchAddress(query) {
        if (!query || query.trim().length < 3) { Toast.warning('Enter at least 3 chars'); return; }
        Toast.info('Searching...');
        try {
            const resp = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}&limit=1&addressdetails=1`);
            const data = await resp.json();
            if (!data || data.length===0) { Toast.warning('Address not found'); return; }
            const result = data[0];
            const lat = parseFloat(result.lat), lon = parseFloat(result.lon);
            if (this.searchMarker) this.map.removeLayer(this.searchMarker);
            this.searchMarker = L.marker([lat, lon], {
                icon: L.divIcon({ html: '<div style="background:#3b82f6;width:16px;height:16px;border-radius:50%;border:3px solid white;box-shadow:0 2px 8px rgba(0,0,0,0.3);"></div>', iconSize:[16,16] })
            }).addTo(this.map);
            this.searchMarker.bindPopup(`<strong>${Utils.escapeHtml(result.display_name)}</strong>`).openPopup();
            this.map.flyTo([lat, lon], 15, { duration:1.5 });
            this.currentLat = lat; this.currentLng = lon;
            Toast.success(`Found: ${Utils.truncate(result.display_name, 50)}`);
        } catch { Toast.error('Search failed'); }
    }

    locateUser() {
        if (!navigator.geolocation) { Toast.warning('Geolocation not supported'); return; }
        Toast.info('Getting location...');
        navigator.geolocation.getCurrentPosition(
            pos => {
                const lat = pos.coords.latitude, lng = pos.coords.longitude;
                this.map.flyTo([lat, lng], 16, { duration:1 });
                this.currentLat = lat; this.currentLng = lng;
                if (this.searchMarker) this.map.removeLayer(this.searchMarker);
                this.searchMarker = L.marker([lat, lng], {
                    icon: L.divIcon({ html: '<div style="background:#dc2626;width:16px;height:16px;border-radius:50%;border:3px solid white;box-shadow:0 0 0 4px rgba(220,38,38,0.3);"></div>', iconSize:[16,16] })
                }).addTo(this.map);
                Toast.success('Location found');
            },
            () => Toast.warning('Location unavailable'),
            { enableHighAccuracy:true, timeout:10000 }
        );
    }

    initGPS() {
        if (!navigator.geolocation) { document.getElementById('gpsStatus').textContent = 'Unavailable'; return; }
        navigator.geolocation.watchPosition(
            pos => {
                this.currentLat = pos.coords.latitude;
                this.currentLng = pos.coords.longitude;
                document.getElementById('gpsStatus').textContent = `±${Math.round(pos.coords.accuracy)}m`;
                if (!this.gpsMarker) {
                    this.gpsMarker = L.marker([this.currentLat, this.currentLng], {
                        icon: L.divIcon({ html: '<div style="background:#dc2626;width:12px;height:12px;border-radius:50%;border:2px solid white;box-shadow:0 0 0 4px rgba(220,38,38,0.3);animation:pulse 2s infinite;"></div>', iconSize:[12,12] }),
                        zIndexOffset: 1000
                    }).addTo(this.map);
                    const style = document.createElement('style');
                    style.textContent = `@keyframes pulse { 0% { box-shadow:0 0 0 0 rgba(220,38,38,0.4); } 70% { box-shadow:0 0 0 10px rgba(220,38,38,0); } 100% { box-shadow:0 0 0 0 rgba(220,38,38,0); } }`;
                    document.head.appendChild(style);
                } else {
                    this.gpsMarker.setLatLng([this.currentLat, this.currentLng]);
                }
            },
            () => document.getElementById('gpsStatus').textContent = 'Error',
            { enableHighAccuracy:true }
        );
    }

    startMeasure() {
        if (this.measureMode) { this.stopMeasure(); return; }
        this.measureMode = true; this.measurePoints = [];
        Toast.info('Measure ON - Click two points');
        const handler = (e) => {
            if (!this.measureMode) return;
            const latlng = e.latlng;
            this.measurePoints.push(latlng);
            const marker = L.marker(latlng, {
                icon: L.divIcon({ html: `<div style="background:#f59e0b;color:white;border-radius:50%;width:20px;height:20px;display:flex;align-items:center;justify-content:center;font-weight:bold;border:2px solid white;font-size:9px;">${this.measurePoints.length}</div>`, iconSize:[20,20] })
            }).addTo(this.map);
            this.measureMarkers.push(marker);
            if (this.measurePoints.length === 2) {
                const p1 = this.measurePoints[0], p2 = this.measurePoints[1];
                const R = 6371;
                const dLat = (p2.lat - p1.lat) * Math.PI / 180;
                const dLon = (p2.lng - p1.lng) * Math.PI / 180;
                const a = Math.sin(dLat/2)**2 + Math.cos(p1.lat*Math.PI/180) * Math.cos(p2.lat*Math.PI/180) * Math.sin(dLon/2)**2;
                const dist = R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
                const distStr = dist >= 1 ? `${dist.toFixed(2)} km` : `${(dist * 1000).toFixed(0)} m`;
                if (this.measureLine) this.map.removeLayer(this.measureLine);
                this.measureLine = L.polyline(this.measurePoints, { color:'#f59e0b', weight:4, dashArray:'8,6', opacity:0.8 }).addTo(this.map);
                const mid = L.latLng((p1.lat+p2.lat)/2, (p1.lng+p2.lng)/2);
                const label = L.divIcon({ html: `<div style="background:#1a5f4a;color:white;padding:3px 10px;border-radius:20px;font-size:10px;font-weight:bold;box-shadow:0 2px 8px rgba(0,0,0,0.2);">📏 ${distStr}</div>`, iconSize:[null,null] });
                this.measureMarkers.push(L.marker(mid, { icon:label, interactive:false }).addTo(this.map));
                Toast.success(`Distance: ${distStr}`);
                setTimeout(() => this.stopMeasure(), 2000);
            }
        };
        this.map.on('click', handler);
        this._measureHandler = handler;
        document.getElementById('measureBtn').classList.add('active');
    }

    stopMeasure() {
        this.measureMode = false;
        if (this._measureHandler) { this.map.off('click', this._measureHandler); this._measureHandler = null; }
        if (this.measureLine) { this.map.removeLayer(this.measureLine); this.measureLine = null; }
        this.measureMarkers.forEach(m => this.map.removeLayer(m));
        this.measureMarkers = []; this.measurePoints = [];
        document.getElementById('measureBtn').classList.remove('active');
    }

    clearMap() {
        this.drawnItems.clearLayers();
        if (this.searchMarker) { this.map.removeLayer(this.searchMarker); this.searchMarker = null; }
        this.polygonCount = 0; this.waypointCount = 0;
        document.getElementById('polygonCount').textContent = '0';
        document.getElementById('waypointCount').textContent = '0';
        Toast.info('Map cleared');
    }
    resetView() { this.map.flyTo([-42.8806, 147.3250], 10, { duration:1 }); }
    toggleFullscreen() { const el = document.querySelector('.map-wrapper'); if (!document.fullscreenElement) el.requestFullscreen?.(); else document.exitFullscreen?.(); }

    getGeometry() { const features=[]; this.drawnItems.eachLayer(l => { try { const geo = l.toGeoJSON(); if (geo && geo.geometry) features.push(geo); } catch {} }); return features; }
    getWaypoints() { const wps=[]; this.drawnItems.eachLayer(l => { if (l instanceof L.Marker && l !== this.gpsMarker && l !== this.searchMarker) { const ll = l.getLatLng(); wps.push({ id:Utils.uuid(), lat:ll.lat, lng:ll.lng, label:`WP${wps.length+1}` }); } }); return wps; }

    openPanel() { document.getElementById('panel').classList.add('open'); }
    closePanel() { document.getElementById('panel').classList.remove('open'); }
    setPanel(html, title) { document.getElementById('panelBody').innerHTML = html; document.getElementById('panelTitle').innerHTML = title; this.openPanel(); }

    async updateStatus() {
        try {
            const insp = await this.db.count('inspections');
            const drafts = await this.db.count('drafts');
            document.getElementById('storageStatus').innerHTML = `<i class="fas fa-database"></i> ${insp} Reports | ${drafts} Drafts`;
            document.getElementById('inspCount').textContent = insp;
            document.getElementById('draftCount').textContent = drafts;
        } catch {}
    }

    // ============================================================
    // CHECKLIST HELPERS
    // ============================================================
    getChecklistData() {
        const getCheck = (id) => document.getElementById(id)?.checked || false;
        return {
            general: {
                siteLocation: getCheck('chk_siteLocation'),
                accessibility: getCheck('chk_accessibility'),
                siteConditions: getCheck('chk_siteConditions'),
                infrastructure: getCheck('chk_infrastructure')
            },
            environmental: {
                protectedSpecies: getCheck('chk_protectedSpecies'),
                environmentalImpacts: getCheck('chk_environmentalImpacts'),
                compliance: getCheck('chk_compliance'),
                conservation: getCheck('chk_conservation')
            },
            workPractices: {
                workPractices: getCheck('chk_workPractices'),
                healthSafety: getCheck('chk_healthSafety'),
                risksHazards: getCheck('chk_risksHazards'),
                controlMeasures: getCheck('chk_controlMeasures')
            },
            equipment: {
                equipmentInspected: getCheck('chk_equipmentInspected'),
                safeCondition: getCheck('chk_safeCondition'),
                maintenanceRecords: getCheck('chk_maintenanceRecords'),
                industryStandards: getCheck('chk_industryStandards')
            }
        };
    }

    getChecklistCount() {
        const data = this.getChecklistData();
        let total = 0, done = 0;
        Object.values(data).forEach(section => {
            Object.values(section).forEach(val => {
                total++;
                if (val) done++;
            });
        });
        return { total, done };
    }

    // ============================================================
    // FORM COLLECTION
    // ============================================================
    collectForm() {
        const get = (id) => document.getElementById(id)?.value || '';
        const getNum = (id) => parseFloat(document.getElementById(id)?.value) || 0;
        const checklist = this.getChecklistData();

        return {
            id: this.currentId || Utils.uuid(),
            status: this.isDraft ? 'draft' : 'finalised',
            // Site Info
            siteName: get('siteName'),
            inspector: get('inspector'),
            organization: get('organization'),
            dateTime: get('dateTime') || new Date().toISOString().slice(0,16),
            coords: `${this.currentLat.toFixed(6)}, ${this.currentLng.toFixed(6)}`,
            // General Site Conditions
            siteLocation: checklist.general.siteLocation,
            accessibility: checklist.general.accessibility,
            siteConditions: checklist.general.siteConditions,
            infrastructure: checklist.general.infrastructure,
            siteConditionsNotes: get('siteConditionsNotes'),
            // Environmental
            protectedSpecies: checklist.environmental.protectedSpecies,
            environmentalImpacts: checklist.environmental.environmentalImpacts,
            compliance: checklist.environmental.compliance,
            conservation: checklist.environmental.conservation,
            environmentalNotes: get('environmentalNotes'),
            // Work Practices
            workPractices: checklist.workPractices.workPractices,
            healthSafety: checklist.workPractices.healthSafety,
            risksHazards: checklist.workPractices.risksHazards,
            controlMeasures: checklist.workPractices.controlMeasures,
            workPracticesNotes: get('workPracticesNotes'),
            // Equipment
            equipmentInspected: checklist.equipment.equipmentInspected,
            safeCondition: checklist.equipment.safeCondition,
            maintenanceRecords: checklist.equipment.maintenanceRecords,
            industryStandards: checklist.equipment.industryStandards,
            equipmentNotes: get('equipmentNotes'),
            // Ecological Health
            vegetationType: get('vegetationType'),
            vegHealth: getNum('vegHealth'),
            speciesRichness: getNum('speciesRichness'),
            weedCover: getNum('weedCover'),
            habitatQuality: getNum('habitatQuality'),
            disturbance: getNum('disturbance'),
            regeneration: getNum('regeneration'),
            // Threats
            weedsList: get('weedsList'),
            feralAnimals: get('feralAnimals'),
            fireHistory: get('fireHistory'),
            threatLevel: get('threatLevel'),
            // Observations & Recommendations
            observations: get('observations'),
            recommendations: get('recommendations'),
            // Aboriginal Heritage
            aboriginalHeritage: get('aboriginalHeritage'),
            culturalSites: get('culturalSites'),
            heritageSignificance: get('heritageSignificance'),
            // Weather & Soil
            weather: get('weather'),
            soilCondition: get('soilCondition'),
            // Photos
            photos: this.currentPhotos,
            geometry: this.getGeometry(),
            waypoints: this.getWaypoints(),
            updatedAt: new Date().toISOString()
        };
    }

    // ============================================================
    // RENDER FORM WITH FULL CHECKLIST
    // ============================================================
    renderForm(data = null) {
        const d = data || {};
        const vegTypes = ['Dry Eucalypt Forest','Wet Eucalypt Forest','Rainforest','Moorland','Grassland','Coastal Heath','Saltmarsh','Alpine Vegetation','Riparian Forest','Plantation','Mixed Forest','Woodland'];
        const threats = ['Low','Medium','High','Critical'];
        const feral = ['Nil','Low','Medium','High'];
        const vegOpts = vegTypes.map(v => `<option ${d.vegetationType === v ? 'selected' : ''}>${v}</option>`).join('');
        const threatOpts = threats.map(t => `<option ${d.threatLevel === t ? 'selected' : ''}>${t}</option>`).join('');
        const feralOpts = feral.map(f => `<option ${d.feralAnimals === f ? 'selected' : ''}>${f}</option>`).join('');
        const photoCount = this.currentPhotos.length;
        const heritageOpts = ['High – known cultural site','Moderate – potential heritage','Low – minimal evidence','Not Assessed'];
        const heritageOptions = heritageOpts.map(h => `<option ${d.heritageSignificance === h ? 'selected' : ''}>${h}</option>`).join('');

        const chk = (id, val) => `<input type="checkbox" id="${id}" ${val ? 'checked' : ''}>`;
        const chkLabel = (id, label, val) => `<label>${chk(id, val)} ${label}</label>`;

        return `
            <form id="inspectionForm">
                <!-- Header -->
                <div class="form-section">
