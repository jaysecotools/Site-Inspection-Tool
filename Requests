                <span id="storageStatus" class="text-xs text-muted" style="padding:2px 8px;background:var(--gray-100);border-radius:20px;"><i class="fas fa-database"></i> Ready</span>
                <div class="toolbar-divider"></div>
                <button id="listInspectionsBtn" class="btn btn-secondary btn-sm"><i class="fas fa-folder-open"></i><span> Saved</span></button>
                <button id="newInspectionBtn" class="btn btn-primary btn-sm"><i class="fas fa-plus"></i><span> New</span></button>
