<script>
// ================================================================
// UTILITIES
// ================================================================
const Utils = {
    uuid() {
        return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => {
            const r = Math.random() * 16 | 0;
            return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);
        });
    },
    
    escapeHtml(str) {
        if (!str) return '';
        const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' };
        return str.replace(/[&<>"']/g, m => map[m]);
    },
    
    sanitizeText(str) {
        if (!str) return '';
        return str.replace(/[^\w\s.,!?()'"]/g, '').trim();
    },
    
    formatDate(isoStr) {
        if (!isoStr) return '—';
        try {
            const d = new Date(isoStr);
            return d.toLocaleDateString('en-AU', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
        } catch { return isoStr; }
    },
    
    truncate(str, len = 40) {
        if (!str) return '';
        return str.length > len ? str.slice(0, len) + '…' : str;
    },
    
    clamp(val, min, max) { return Math.max(min, Math.min(max, val)); },
    round(val, d = 1) { return Number(val.toFixed(d)); },
    
    haversineDist(lat1, lng1, lat2, lng2) {
        const R = 6371;
        const dLat = (lat2 - lat1) * Math.PI / 180;
        const dLon = (lng2 - lng1) * Math.PI / 180;
        const a = Math.sin(dLat/2)**2 + Math.cos(lat1 * Math.PI/180) * Math.cos(lat2 * Math.PI/180) * Math.sin(dLon/2)**2;
        return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
    },
    
    formatDistance(km) {
        if (km >= 1) return `${km.toFixed(2)} km`;
        return `${(km * 1000).toFixed(0)} m`;
    },
    
    compressImage(dataURL, maxWidth = 800, quality = 0.8) {
        return new Promise((resolve) => {
            const img = new Image();
            img.onload = () => {
                const canvas = document.createElement('canvas');
                let w = img.width, h = img.height;
                if (w > maxWidth) { h = (h * maxWidth) / w; w = maxWidth; }
                canvas.width = w; canvas.height = h;
                const ctx = canvas.getContext('2d');
                ctx.drawImage(img, 0, 0, w, h);
                resolve(canvas.toDataURL('image/jpeg', quality));
            };
            img.onerror = () => resolve(dataURL);
            img.src = dataURL;
        });
    },
    
    calculateScore(data) {
        const vh = parseFloat(data.vegHealth || 6);
        const sr = parseFloat(data.speciesRichness || 5);
        const wc = parseFloat(data.weedCover || 30);
        const hq = parseFloat(data.habitatQuality || 5);
        const dist = parseFloat(data.disturbance || 3);
        const regen = parseFloat(data.regeneration || 5);
        
        const score = Utils.clamp(
            (vh * 0.25) + (sr * 0.2) + ((100 - wc) / 10 * 0.2) + 
            (hq * 0.15) + ((10 - dist) * 0.1) + (regen * 0.1),
            0, 10
        );
        
        let riskRating, priority, colour;
        if (score < 3) { riskRating = 'Critical'; priority = 'Immediate Intervention'; colour = '#dc2626'; }
        else if (score < 5) { riskRating = 'High Risk'; priority = 'Urgent Management'; colour = '#f59e0b'; }
        else if (score < 7) { riskRating = 'Medium Risk'; priority = 'Short-term Plan'; colour = '#f59e0b'; }
        else if (score < 8.5) { riskRating = 'Low Risk'; priority = 'Regular Monitoring'; colour = '#3498db'; }
        else { riskRating = 'Excellent'; priority = 'Maintenance Only'; colour = '#10b981'; }
        
        return {
            conditionScore: Utils.round(score, 1),
            riskRating, priority, colour,
            significance: score > 7 ? 'High Conservation Value' : (score > 5 ? 'Moderate Conservation Value' : 'Low Conservation Value')
        };
    },
    
    getRatingClass(score) {
        if (score >= 8) return 'excellent';
        if (score >= 6.5) return 'good';
        if (score >= 4.5) return 'moderate';
        return 'poor';
    }
};

// ================================================================
// TOAST
// ================================================================
const Toast = {
    show(msg, type = 'info', duration = 3000) {
        const container = document.getElementById('toastContainer');
        const toast = document.createElement('div');
        const icons = { success: 'fa-check-circle', warning: 'fa-exclamation-triangle', error: 'fa-times-circle', info: 'fa-info-circle' };
        toast.className = `toast ${type}`;
        toast.innerHTML = `<i class="fas ${icons[type] || icons.info}"></i> ${Utils.escapeHtml(msg)}`;
        container.appendChild(toast);
        setTimeout(() => { if (toast.parentNode) toast.remove(); }, duration);
    },
    success(msg) { this.show(msg, 'success'); },
    warning(msg) { this.show(msg, 'warning'); },
    error(msg) { this.show(msg, 'error'); },
    info(msg) { this.show(msg, 'info'); }
};

// ================================================================
// DATABASE
// ================================================================
class Database {
    constructor() {
        this.db = null;
        this.ready = false;
        this.useLocalStorage = false;
    }
    
    async init() {
        return new Promise((resolve) => {
            try {
                const req = indexedDB.open('EcoMaintenance_v4', 5);
                req.onupgradeneeded = (e) => {
                    const db = e.target.result;
                    if (!db.objectStoreNames.contains('inspections')) {
                        const s = db.createObjectStore('inspections', { keyPath: 'id' });
                        s.createIndex('dateTime', 'dateTime');
                        s.createIndex('status', 'status');
                        s.createIndex('siteName', 'siteName');
                    }
                    if (!db.objectStoreNames.contains('drafts')) {
                        db.createObjectStore('drafts', { keyPath: 'id' });
                    }
                };
                req.onsuccess = (e) => { this.db = e.target.result; this.ready = true; resolve(); };
                req.onerror = () => { this.useLocalStorage = true; this.ready = true; resolve(); };
            } catch { this.useLocalStorage = true; this.ready = true; resolve(); }
        });
    }
    
    _store(store, mode = 'readonly') {
        if (this.useLocalStorage || !this.ready) return null;
        return this.db.transaction([store], mode).objectStore(store);
    }
    
    _key(id, draft = false) { return `${draft ? 'draft_' : 'insp_'}${id}`; }
    
    async save(data, draft = false) {
        const store = draft ? 'drafts' : 'inspections';
        if (this.useLocalStorage) {
            localStorage.setItem(this._key(data.id, draft), JSON.stringify(data));
            return;
        }
        return new Promise((resolve, reject) => {
            try {
                const s = this._store(store, 'readwrite');
                const req = s.put(data);
                req.onsuccess = () => resolve();
                req.onerror = () => reject(req.error);
            } catch (e) { reject(e); }
        });
    }
    
    async getAll(store = 'inspections') {
        if (this.useLocalStorage) {
            const prefix = store === 'inspections' ? 'insp_' : 'draft_';
            return Object.keys(localStorage).filter(k => k.startsWith(prefix)).map(k => JSON.parse(localStorage.getItem(k)));
        }
        return new Promise((resolve, reject) => {
            try {
                const s = this._store(store);
                const req = s.getAll();
                req.onsuccess = () => resolve(req.target.result || []);
                req.onerror = () => reject(req.error);
            } catch (e) { reject(e); }
        });
    }
    
    async get(id, draft = false) {
        const store = draft ? 'drafts' : 'inspections';
        if (this.useLocalStorage) {
            const data = localStorage.getItem(this._key(id, draft));
            return data ? JSON.parse(data) : null;
        }
        return new Promise((resolve, reject) => {
            try {
                const s = this._store(store);
                const req = s.get(id);
                req.onsuccess = () => resolve(req.target.result);
                req.onerror = () => reject(req.error);
            } catch (e) { reject(e); }
        });
    }
    
    async delete(id, draft = false) {
        const store = draft ? 'drafts' : 'inspections';
        if (this.useLocalStorage) {
            localStorage.removeItem(this._key(id, draft));
            return;
        }
        return new Promise((resolve, reject) => {
            try {
                const s = this._store(store, 'readwrite');
                const req = s.delete(id);
                req.onsuccess = () => resolve();
                req.onerror = () => reject(req.error);
            } catch (e) { reject(e); }
        });
    }
    
    async clear(store = 'inspections') {
        if (this.useLocalStorage) {
            const prefix = store === 'inspections' ? 'insp_' : 'draft_';
            Object.keys(localStorage).filter(k => k.startsWith(prefix)).forEach(k => localStorage.removeItem(k));
            return;
        }
        return new Promise((resolve, reject) => {
            try {
                const s = this._store(store, 'readwrite');
                const req = s.clear();
                req.onsuccess = () => resolve();
                req.onerror = () => reject(req.error);
            } catch (e) { reject(e); }
        });
    }
    
    async count(store = 'inspections') {
        const items = await this.getAll(store);
        return items.length;
    }
}

// ================================================================
// APPLICATION
// ================================================================
class App {
    constructor() {
        this.db = new Database();
        this.map = null;
        this.drawnItems = null;
        this.layers = { base: null, satellite: null, topo: null };
        this.activeLayer = 'streets';
        this.currentId = null;
        this.currentPhotos = [];
        this.isDraft = false;
        this.gpsMarker = null;
        this.gpsWatchId = null;
        this.currentLat = -42.8806;
        this.currentLng = 147.3250;
        this.measureMode = false;
        this.measurePoints = [];
        this.measureLine = null;
        this.measureMarkers = [];
        this.polygonCount = 0;
        this.waypointCount = 0;
        this.charts = {};
        this.panelOpen = false;
    }
    
    // ================================================================
    // INIT
    // ================================================================
    async init() {
        await this.db.init();
        this.initMap();
        this.initGPS();
        this.bindEvents();
        this.updateStatus();
        this.showDashboard();
        Toast.success('EcoMaintenance Professional Ready');
    }
    
    // ================================================================
    // MAP
    // ================================================================
    initMap() {
        this.map = L.map('map', { center: [-42.8806, 147.3250], zoom: 10, zoomControl: false });
        
        this.layers.base = L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
            attribution: '&copy; OpenStreetMap'
        }).addTo(this.map);
        
        this.layers.satellite = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
            attribution: '&copy; Esri'
        });
        
        this.layers.topo = L.tileLayer('https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenTopoMap'
        });
        
        this.drawnItems = L.featureGroup().addTo(this.map);
        
        const drawControl = new L.Control.Draw({
            position: 'topleft',
            draw: {
                polygon: { shapeOptions: { color: '#1a5f4a', weight: 3 }, showArea: true },
                rectangle: true,
                marker: true,
                circle: false,
                polyline: false
            },
            edit: { featureGroup: this.drawnItems, remove: true }
        });
        this.map.addControl(drawControl);
        
        L.control.zoom({ position: 'bottomright' }).addTo(this.map);
        
        this.map.on(L.Draw.Event.CREATED, (e) => {
            const layer = e.layer;
            if (e.layerType === 'polygon' || e.layerType === 'rectangle') {
                this.polygonCount++;
                document.getElementById('polygonCount').textContent = this.polygonCount;
                const area = turf.area(layer.toGeoJSON()) / 10000;
                Toast.success(`Polygon: ${area.toFixed(2)} ha`);
            } else if (e.layerType === 'marker') {
                this.waypointCount++;
                document.getElementById('waypointCount').textContent = this.waypointCount;
                Toast.success(`Waypoint ${this.waypointCount}`);
            }
            this.drawnItems.addLayer(layer);
        });
        
        this.map.on('click', (e) => {
            this.currentLat = e.latlng.lat;
            this.currentLng = e.latlng.lng;
        });
        
        document.getElementById('polygonCount').textContent = '0';
        document.getElementById('waypointCount').textContent = '0';
    }
    
    switchLayer(name) {
        Object.values(this.layers).forEach(l => { if (l && this.map.hasLayer(l)) this.map.removeLayer(l); });
        this.activeLayer = name;
        const layer = this.layers[name];
        if (layer) {
            layer.addTo(this.map);
            document.querySelectorAll('.layer-item').forEach(el => {
                el.classList.toggle('active', el.dataset.layer === name);
            });
        }
    }
    
    locateUser() {
        if (!navigator.geolocation) { Toast.warning('Geolocation not supported'); return; }
        navigator.geolocation.getCurrentPosition(
            pos => { this.map.setView([pos.coords.latitude, pos.coords.longitude], 16); Toast.success('Location found'); },
            () => Toast.warning('Location unavailable'),
            { enableHighAccuracy: true, timeout: 10000 }
        );
    }
    
    initGPS() {
        if (!navigator.geolocation) { document.getElementById('gpsStatus').textContent = 'Unavailable'; return; }
        this.gpsWatchId = navigator.geolocation.watchPosition(
            pos => {
                this.currentLat = pos.coords.latitude;
                this.currentLng = pos.coords.longitude;
                document.getElementById('gpsStatus').textContent = `±${Math.round(pos.coords.accuracy)}m`;
                if (!this.gpsMarker) {
                    this.gpsMarker = L.marker([this.currentLat, this.currentLng], {
                        icon: L.divIcon({
                            html: '<div style="background:#dc2626;width:12px;height:12px;border-radius:50%;border:2px solid white;box-shadow:0 0 0 4px rgba(220,38,38,0.3);"></div>',
                            iconSize: [12, 12],
                            className: 'gps-pulse'
                        }),
                        zIndexOffset: 1000
                    }).addTo(this.map);
                } else {
                    this.gpsMarker.setLatLng([this.currentLat, this.currentLng]);
                }
            },
            () => document.getElementById('gpsStatus').textContent = 'Error',
            { enableHighAccuracy: true }
        );
    }
    
    startMeasure() {
        if (this.measureMode) { this.stopMeasure(); return; }
        this.measureMode = true;
        this.measurePoints = [];
        Toast.info('Measure ON - Click two points');
        
        const handler = (e) => {
            if (!this.measureMode) return;
            const latlng = e.latlng;
            this.measurePoints.push(latlng);
            
            const marker = L.marker(latlng, {
                icon: L.divIcon({
                    html: `<div style="background:#f59e0b;color:white;border-radius:50%;width:22px;height:22px;display:flex;align-items:center;justify-content:center;font-weight:bold;border:2px solid white;font-size:10px;">${this.measurePoints.length}</div>`,
                    iconSize: [22, 22]
                })
            }).addTo(this.map);
            this.measureMarkers.push(marker);
            
            if (this.measurePoints.length === 2) {
                const p1 = this.measurePoints[0], p2 = this.measurePoints[1];
                const dist = Utils.haversineDist(p1.lat, p1.lng, p2.lat, p2.lng);
                if (this.measureLine) this.map.removeLayer(this.measureLine);
                this.measureLine = L.polyline(this.measurePoints, { color: '#f59e0b', weight: 4, dashArray: '8,6' }).addTo(this.map);
                const mid = L.latLng((p1.lat+p2.lat)/2, (p1.lng+p2.lng)/2);
                const label = L.divIcon({
                    html: `<div style="background:#1a5f4a;color:white;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:bold;">📏 ${Utils.formatDistance(dist)}</div>`,
                    iconSize: [null, null]
                });
                this.measureMarkers.push(L.marker(mid, { icon: label, interactive: false }).addTo(this.map));
                Toast.success(`Distance: ${Utils.formatDistance(dist)}`);
                setTimeout(() => this.stopMeasure(), 2000);
            }
        };
        this.map.on('click', handler);
        this._measureHandler = handler;
        document.getElementById('measureBtn').classList.add('active');
    }
    
    stopMeasure() {
        this.measureMode = false;
        if (this._measureHandler) { this.map.off('click', this._measureHandler); this._measureHandler = null; }
        if (this.measureLine) { this.map.removeLayer(this.measureLine); this.measureLine = null; }
        this.measureMarkers.forEach(m => this.map.removeLayer(m));
        this.measureMarkers = [];
        this.measurePoints = [];
        document.getElementById('measureBtn').classList.remove('active');
    }
    
    clearMap() {
        this.drawnItems.clearLayers();
        this.polygonCount = 0;
        this.waypointCount = 0;
        document.getElementById('polygonCount').textContent = '0';
        document.getElementById('waypointCount').textContent = '0';
        Toast.info('Map cleared');
    }
    
    resetView() { this.map.setView([-42.8806, 147.3250], 10); }
    
    toggleFullscreen() {
        const el = document.getElementById('mapWrapper');
        if (!document.fullscreenElement) { el.requestFullscreen?.(); } 
        else { document.exitFullscreen?.(); }
    }
    
    getGeometry() {
        const features = [];
        this.drawnItems.eachLayer(l => { try { features.push(l.toGeoJSON()); } catch(e) {} });
        return features;
    }
    
    getWaypoints() {
        const wps = [];
        this.drawnItems.eachLayer(l => {
            if (l instanceof L.Marker && !l.options.icon?.className?.includes('gps')) {
                const ll = l.getLatLng();
                wps.push({ id: Utils.uuid(), lat: ll.lat, lng: ll.lng, label: `WP${wps.length+1}` });
            }
        });
        return wps;
    }
    
    loadGeometry(geojson) {
        if (!geojson || !geojson.length) return;
        geojson.forEach(g => {
            try {
                const layer = L.geoJSON(g);
                this.drawnItems.addLayer(layer);
                if (g.geometry?.type === 'Polygon' || g.geometry?.type === 'MultiPolygon') this.polygonCount++;
                else if (g.geometry?.type === 'Point') this.waypointCount++;
            } catch(e) {}
        });
        document.getElementById('polygonCount').textContent = this.polygonCount;
        document.getElementById('waypointCount').textContent = this.waypointCount;
    }
    
