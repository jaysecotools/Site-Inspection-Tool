        const drafts = await this.db.getAll('drafts');
        if (drafts.length === 0) {
            this.setPanel(`
                <div class="text-center" style="padding:40px 20px;">
                    <i class="fas fa-save" style="font-size:40px;opacity:0.3;display:block;margin-bottom:12px;"></i>
                    <h3>No Drafts</h3>
                    <p class="text-muted">Start a new assessment to create a draft.</p>
                    <button class="btn btn-primary mt-3" onclick="app.newInspection()"><i class="fas fa-plus"></i> Start New</button>
                </div>
            `, 'Drafts');
            return;
        }
        
        drafts.sort((a, b) => new Date(b.updatedAt) - new Date(a.updatedAt));
        let html = `<div class="flex-between mb-2"><span><strong>${drafts.length}</strong> drafts</span>
            <div class="flex gap-2"><button class="btn btn-secondary btn-sm" onclick="app.showInspections()"><i class="fas fa-folder-open"></i> Reports</button>
            <button class="btn btn-primary btn-sm" onclick="app.newInspection()"><i class="fas fa-plus"></i> New</button></div></div>`;
        
        drafts.forEach(d => {
            html += `
                <div class="inspection-card" style="border-left-color:var(--warning);">
                    <div class="card-title">${Utils.escapeHtml(d.siteName || 'Unnamed Draft')}</div>
                    <div class="card-meta">Edited: ${Utils.formatDate(d.updatedAt)} · ${d.inspector || 'No inspector'}</div>
                    <div class="card-actions">
                        <button class="btn btn-secondary btn-sm resume-draft" data-id="${d.id}"><i class="fas fa-pen"></i> Resume</button>
                        <button class="btn btn-danger btn-sm del-draft" data-id="${d.id}"><i class="fas fa-trash"></i></button>
                    </div>
                    <div class="card-badge" style="background:rgba(212,168,67,0.15);color:var(--warning);">Draft</div>
                </div>
            `;
        });
        
        this.setPanel(html, 'Drafts');
        
        document.querySelectorAll('.resume-draft').forEach(el => {
            el.onclick = () => this.loadInspection(el.dataset.id, true);
        });
        document.querySelectorAll('.del-draft').forEach(el => {
            el.onclick = async () => {
                if (confirm('Delete this draft?')) {
                    await this.db.delete(el.dataset.id, true);
                    Toast.success('Deleted');
                    this.updateStatus();
                    this.showDrafts();
