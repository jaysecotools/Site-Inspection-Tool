    bindForm() {
        const input = document.getElementById('photoInput');
        const drop = document.getElementById('photoDropZone');
        if (input) {
            input.onchange = (e) => this.handlePhotos(e.target.files);
        }
        if (drop) {
            drop.onclick = () => input?.click();
            drop.ondragover = (e) => { e.preventDefault(); drop.style.borderColor = 'var(--brand-canopy)'; };
            drop.ondragleave = () => { drop.style.borderColor = ''; };
            drop.ondrop = (e) => {
                e.preventDefault();
                drop.style.borderColor = '';
                if (e.dataTransfer.files.length) this.handlePhotos(e.dataTransfer.files);
            };
        }
        
        this.renderGallery();
        
        document.getElementById('saveDraftBtn')?.addEventListener('click', () => this.saveDraft());
        document.getElementById('finaliseBtn')?.addEventListener('click', () => this.finalise());
        document.getElementById('cancelBtn')?.addEventListener('click', () => this.closePanel());
        
        document.querySelectorAll('.section-header').forEach(h => {
            h.onclick = () => {
                h.classList.toggle('collapsed');
                h.nextElementSibling?.classList.toggle('collapsed');
            };
        });
        
        ['vegHealth','speciesRichness','regeneration','weedCover','habitatQuality','disturbance'].forEach(id => {
            const el = document.getElementById(id);
            if (el) {
                el.oninput = () => {
                    const data = this.collectForm();
                    const eco = Utils.calculateScore(data);
                    const fill = document.querySelector('.health-fill');
                    const display = document.getElementById('scoreDisplay');
                    if (fill) { fill.style.width = `${eco.conditionScore*10}%`; fill.style.background = eco.colour; }
                    if (display) display.textContent = `${eco.conditionScore}/10`;
                };
            }
        });
    }
    
    // ================================================================
    // PHOTOS
    // ================================================================
    async handlePhotos(files) {
        const maxPhotos = 20;
        const remaining = maxPhotos - this.currentPhotos.length;
        const toProcess = Array.from(files).slice(0, remaining);
        
        if (Array.from(files).length > remaining) Toast.warning(`Only ${remaining} photos can be added`);
        
        for (const file of toProcess) {
            if (file.size > 2 * 1024 * 1024) { Toast.warning(`${file.name} is too large`); continue; }
            const reader = new FileReader();
            const data = await new Promise((resolve) => {
                reader.onload = async (e) => {
                    const compressed = await Utils.compressImage(e.target.result, 800);
                    resolve(compressed);
                };
                reader.readAsDataURL(file);
            });
            this.currentPhotos.push({
                id: Utils.uuid(),
                dataURL: data,
                timestamp: new Date().toISOString(),
                lat: this.currentLat,
                lng: this.currentLng,
                isHero: this.currentPhotos.length === 0
            });
        }
        this.renderGallery();
        Toast.success(`${toProcess.length} photo(s) added`);
    }
    
    renderGallery() {
        const g = document.getElementById('photoGallery');
        if (!g) return;
        if (this.currentPhotos.length === 0) {
            g.innerHTML = `<div style="padding:20px;text-align:center;color:var(--neutral-400);grid-column:1/-1;"><i class="fas fa-camera" style="font-size:20px;display:block;margin-bottom:4px;"></i>No photos</div>`;
            return;
        }
        g.innerHTML = this.currentPhotos.map((p, i) => `
            <div class="photo-item" data-idx="${i}">
                <img src="${p.dataURL}" alt="Photo ${i+1}" loading="lazy">
                <div class="photo-overlay"><span>${new Date(p.timestamp).toLocaleTimeString()}</span></div>
                <button class="remove-photo" data-idx="${i}">×</button>
                ${p.isHero ? '<div class="hero-badge">Cover</div>' : ''}
            </div>
        `).join('');
        
        document.querySelectorAll('.remove-photo').forEach(el => {
            el.onclick = (e) => {
                e.stopPropagation();
                const idx = parseInt(el.dataset.idx);
                this.currentPhotos.splice(idx, 1);
                if (this.currentPhotos.length > 0 && !this.currentPhotos.some(p => p.isHero)) {
                    this.currentPhotos[0].isHero = true;
                }
                this.renderGallery();
            };
        });
        
        document.querySelectorAll('.photo-item').forEach((el, idx) => {
            el.onclick = () => {
                this.currentPhotos.forEach((p, i) => p.isHero = (i === idx));
                this.renderGallery();
                Toast.success('Cover photo set');
            };
        });
    }
    
    // ================================================================
    // CRUD OPERATIONS
    // ================================================================
    async newInspection() {
        this.currentId = Utils.uuid();
        this.currentPhotos = [];
        this.isDraft = false;
        this.clearMap();
        this.setPanel(this.renderForm({ id: this.currentId }), 'New Ecological Assessment');
        this.bindForm();
    }
    
    async loadInspection(id, draft = false) {
        const data = await this.db.get(id, draft);
        if (!data) { Toast.error('Not found'); return; }
        this.currentId = data.id;
        this.currentPhotos = data.photos || [];
        this.isDraft = draft;
        this.clearMap();
        this.loadGeometry(data.geometry || []);
        (data.waypoints || []).forEach(w => {
            this.drawnItems.addLayer(L.marker([w.lat, w.lng]).bindPopup(`<strong>${Utils.escapeHtml(w.label)}</strong>`));
        });
        this.setPanel(this.renderForm(data), draft ? 'Edit Draft' : 'View Inspection');
        this.bindForm();
    }
    
    async saveDraft() {
        const data = this.collectForm();
        if (!data.siteName) { Toast.warning('Site name required'); return; }
        data.status = 'draft';
        await this.db.save(data, true);
        this.isDraft = true;
        Toast.success('Draft saved');
        this.updateStatus();
    }
    
    async finalise() {
        const data = this.collectForm();
        if (!data.siteName) { Toast.warning('Site name required'); return; }
        data.status = 'finalised';
        data.ecologicalScore = Utils.calculateScore(data);
        await this.db.save(data, false);
        await this.db.delete(data.id, true);
        await this.generateReport(data);
        this.closePanel();
        this.updateStatus();
        this.showInspections();
    }
    
    // ================================================================
    // REPORT GENERATION
    // ================================================================
    async generateReport(inspection) {
        const { jsPDF } = window.jspdf;
        const doc = new jsPDF('p', 'mm', 'a4');
        const pageWidth = 210, pageHeight = 297, margin = 18;
        let y = margin;
        const eco = inspection.ecologicalScore || Utils.calculateScore(inspection);
        const colour = '#1a5f4a';
        
        // Helper
        const addText = (text, size = 10, color = '#333', align = 'left') => {
            doc.setFontSize(size);
            doc.setTextColor(color);
            const lines = doc.splitTextToSize(text || '', pageWidth - 2*margin);
            doc.text(lines, margin, y, { align });
            y += lines.length * (size * 0.45) + 1.5;
        };
        
        const addTitle = (text, size = 18, color = colour) => {
            doc.setFontSize(size);
            doc.setTextColor(color);
            doc.text(text, margin, y);
            y += size * 0.4 + 2;
        };
        
        const line = () => { doc.setDrawColor(colour); doc.setLineWidth(0.5); doc.line(margin, y, pageWidth - margin, y); y += 6; };
        
        // Cover
        doc.setFillColor(colour);
        doc.rect(0, 0, pageWidth, 5, 'F');
        y = 30;
        doc.setFontSize(28);
        doc.setTextColor(colour);
        doc.text('ENVIRONMENTAL', margin, y);
        y += 14;
        doc.text('ASSESSMENT REPORT', margin, y);
        y += 12;
        line();
        y += 4;
        doc.setFontSize(18);
        doc.setTextColor('#222');
        doc.text(Utils.escapeHtml(inspection.siteName || 'Site Assessment'), margin, y);
        y += 10;
        doc.setFontSize(11);
        doc.setTextColor('#666');
        doc.text(`Prepared for: ${Utils.escapeHtml(inspection.organization || 'Environmental Client')}`, margin, y);
        y += 6;
        doc.text(`Date: ${Utils.formatDate(inspection.dateTime)}`, margin, y);
        y += 8;
        
        // Hero image
        if (inspection.photos && inspection.photos.length > 0) {
            const hero = inspection.photos.find(p => p.isHero) || inspection.photos[0];
            try {
                doc.addImage(hero.dataURL, 'JPEG', margin+5, y, pageWidth-2*margin-10, 60);
                y += 66;
            } catch(e) {
                doc.setFillColor('#f5f5f5');
                doc.roundedRect(margin+5, y, pageWidth-2*margin-10, 40, 3, 3, 'F');
                doc.setFontSize(10);
                doc.setTextColor('#999');
                doc.text('Cover Photo', pageWidth/2, y+22, { align: 'center' });
                y += 46;
            }
        }
        
        doc.setFontSize(8);
        doc.setTextColor('#888');
        doc.text(`Report ID: ${inspection.id}`, margin, y);
        doc.text(`v${'4.0'}`, pageWidth-margin, y, { align: 'right' });
        y += 6;
        doc.text(`Author: ${Utils.escapeHtml(inspection.inspector || 'Consultant')}`, margin, y);
        y += 8;
        
        // Footer
        doc.setFillColor(colour);
        doc.rect(0, pageHeight-6, pageWidth, 3, 'F');
        doc.setFontSize(7);
        doc.setTextColor('#999');
        doc.text('© EcoMaintenance Professional', margin, pageHeight-3);
        doc.text(new Date().toLocaleDateString(), pageWidth-margin, pageHeight-3, { align: 'right' });
        
        doc.addPage();
        
        // Summary
        y = margin + 8;
        addTitle('EXECUTIVE SUMMARY', 20);
        line();
        y += 4;
        addText(`This report presents findings of an ecological assessment at "${Utils.escapeHtml(inspection.siteName)}" conducted on ${Utils.formatDate(inspection.dateTime)}.`, 10);
        y += 4;
        addText(`Condition Score: ${eco.conditionScore}/10 (${eco.riskRating})`, 10);
        addText(`Significance: ${eco.significance}`, 10);
        addText(`Management Priority: ${eco.priority}`, 10);
        y += 4;
        
        // Assessment details
        addTitle('ASSESSMENT DETAILS', 16);
        line();
        y += 4;
        const details = [
            ['Vegetation Health', `${inspection.vegHealth || 6}/10`],
            ['Species Richness', `${inspection.speciesRichness || 5}/10`],
            ['Regeneration', `${inspection.regeneration || 5}/10`],
            ['Weed Cover', `${inspection.weedCover || 30}%`],
            ['Habitat Quality', `${inspection.habitatQuality || 5}/10`],
            ['Disturbance', `${inspection.disturbance || 3}/10`]
        ];
        doc.autoTable({
            startY: y,
            head: [['Parameter', 'Value']],
            body: details,
            theme: 'striped',
            headStyles: { fillColor: colour, textColor: '#fff', fontSize: 9 },
            bodyStyles: { fontSize: 8 },
            columnStyles: { 0: { cellWidth: 70 }, 1: { cellWidth: 100 } }
        });
        y = doc.lastAutoTable.finalY + 8;
        
        // Recommendations
        addTitle('RECOMMENDATIONS', 14);
        line();
        y += 4;
        const recs = inspection.recommendations || 'No recommendations recorded.';
        addText(recs, 9);
        y += 4;
        
        // Observations
        addTitle('OBSERVATIONS', 14);
        line();
        y += 4;
        const obs = inspection.observations || 'No observations recorded.';
        addText(obs, 9);
        
        // Photos appendix
        doc.addPage();
        y = margin + 8;
        addTitle('PHOTO DOCUMENTATION', 18);
        line();
        y += 4;
        if (inspection.photos && inspection.photos.length > 0) {
            const photos = inspection.photos.slice(0, 9);
            let px = margin, py = y;
            const size = 55;
            photos.forEach((p, i) => {
                if (i > 0 && i % 3 === 0) { px = margin; py += size + 6; }
                try {
                    doc.addImage(p.dataURL, 'JPEG', px, py, size, size * 0.75);
                    px += size + 4;
                } catch(e) {}
            });
            y = py + size + 10;
            doc.setFontSize(8);
            doc.setTextColor('#666');
            doc.text(`Total ${inspection.photos.length} images`, margin, y);
        } else {
            addText('No photos uploaded.', 10);
        }
        
        // Footer on all pages
        const total = doc.internal.getNumberOfPages();
        for (let i = 1; i <= total; i++) {
            doc.setPage(i);
            doc.setDrawColor(colour);
            doc.setLineWidth(0.3);
            doc.line(margin, pageHeight-10, pageWidth-margin, pageHeight-10);
            doc.setFontSize(7);
            doc.setTextColor('#aaa');
            doc.text(`Page ${i} of ${total}`, pageWidth/2, pageHeight-5, { align: 'center' });
            doc.text(inspection.id, margin, pageHeight-5);
        }
        
        doc.save(`EcoMaintenance_Report_${inspection.id}.pdf`);
        Toast.success('Report generated');
    }
    
    // ================================================================
    // VIEWS
    // ================================================================
    async showDashboard() {
        const insp = await this.db.getAll('inspections');
        const drafts = await this.db.getAll('drafts');
        const total = insp.length;
        const avg = total > 0 ? insp.reduce((s, i) => s + (i.ecologicalScore?.conditionScore || 0), 0) / total : 0;
        const high = insp.filter(i => (i.ecologicalScore?.conditionScore || 0) >= 7).length;
        const crit = insp.filter(i => (i.ecologicalScore?.conditionScore || 0) < 4).length;
        
        const recent = insp.slice(-8).reverse();
        const labels = recent.map(i => Utils.truncate(i.siteName || 'Site', 12));
        const scores = recent.map(i => i.ecologicalScore?.conditionScore || 0);
        
        const html = `
            <div class="dashboard-grid">
                <div class="stat-card"><div class="stat-icon"><i class="fas fa-clipboard-list"></i></div>
                    <div class="stat-value">${total}</div><div class="stat-label">Reports</div></div>
                <div class="stat-card"><div class="stat-icon"><i class="fas fa-chart-line"></i></div>
                    <div class="stat-value">${avg > 0 ? avg.toFixed(1) : '—'}</div><div class="stat-label">Avg Score</div>
                    <span class="stat-change ${avg >= 6 ? 'positive' : 'negative'}">${avg >= 6 ? 'Good' : 'Needs attention'}</span></div>
                <div class="stat-card"><div class="stat-icon"><i class="fas fa-star" style="color:var(--warning);"></i></div>
                    <div class="stat-value">${high}</div><div class="stat-label">High Value</div></div>
                <div class="stat-card"><div class="stat-icon"><i class="fas fa-exclamation-triangle" style="color:var(--danger);"></i></div>
                    <div class="stat-value">${crit}</div><div class="stat-label">Critical</div></div>
            </div>
            
            <div class="chart-container">
                <h4><i class="fas fa-chart-bar"></i> Recent Scores</h4>
                <canvas id="scoreChart" height="140"></canvas>
            </div>
            
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                <div class="stat-card" style="cursor:pointer;" onclick="app.showInspections()">
                    <div style="display:flex;justify-content:space-between;align-items:center;">
                        <span><i class="fas fa-folder-open" style="color:var(--brand-canopy);"></i> <strong>${total}</strong> Reports</span>
                        <span class="text-muted text-xs">View →</span>
                    </div>
                </div>
                <div class="stat-card" style="cursor:pointer;" onclick="app.showDrafts()">
                    <div style="display:flex;justify-content:space-between;align-items:center;">
                        <span><i class="fas fa-save" style="color:var(--warning);"></i> <strong>${drafts.length}</strong> Drafts</span>
                        <span class="text-muted text-xs">View →</span>
                    </div>
                </div>
            </div>
            
            <div style="margin-top:12px;display:flex;gap:6px;flex-wrap:wrap;">
                <button class="btn btn-primary" onclick="app.newInspection()"><i class="fas fa-plus"></i> New Assessment</button>
                <button class="btn btn-secondary" onclick="app.showDataManager()"><i class="fas fa-database"></i> Data Manager</button>
            </div>
            
            <div style="margin-top:12px;padding:10px 14px;background:var(--neutral-50);border-radius:var(--radius-md);border:1px solid var(--neutral-200);">
                <div class="flex-between text-xs text-muted">
                    <span>v${'4.0'}</span>
                    <span><i class="fas fa-database"></i> ${this.db.useLocalStorage ? 'LocalStorage' : 'IndexedDB'}</span>
                    <span><i class="fas fa-map-pin"></i> ${total} assessments</span>
                </div>
            </div>
        `;
        
        this.setPanel(html, 'Dashboard');
        
        setTimeout(() => {
            const canvas = document.getElementById('scoreChart');
            if (canvas && labels.length) {
                if (this.charts.score) this.charts.score.destroy();
                const ctx = canvas.getContext('2d');
                const grad = ctx.createLinearGradient(0, 0, 0, 140);
                grad.addColorStop(0, 'rgba(26,95,74,0.2)');
                grad.addColorStop(1, 'rgba(26,95,74,0)');
                this.charts.score = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: labels.length ? labels : ['No Data'],
                        datasets: [{
                            label: 'Score',
                            data: scores.length ? scores : [0],
                            borderColor: '#1a5f4a',
                            backgroundColor: grad,
                            fill: true,
                            tension: 0.3,
                            pointBackgroundColor: scores.map(v => v >= 7 ? '#10b981' : v >= 4 ? '#f59e0b' : '#dc2626'),
                            pointRadius: 4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            y: { min: 0, max: 10, grid: { color: 'rgba(0,0,0,0.05)' }, ticks: { stepSize: 2 } },
                            x: { grid: { display: false }, ticks: { font: { size: 9 } } }
                        }
                    }
                });
            }
        }, 150);
    }
    
    async showInspections() {
        const inspections = await this.db.getAll('inspections');
        if (inspections.length === 0) {
            this.setPanel(`
                <div class="text-center" style="padding:40px 20px;">
                    <i class="fas fa-folder-open" style="font-size:40px;opacity:0.3;display:block;margin-bottom:12px;"></i>
                    <h3>No Finalised Inspections</h3>
                    <p class="text-muted">Complete an assessment to generate a report.</p>
                    <button class="btn btn-primary mt-3" onclick="app.newInspection()"><i class="fas fa-plus"></i> Start New</button>
                </div>
            `, 'Inspections');
            return;
        }
        
        inspections.sort((a, b) => new Date(b.dateTime) - new Date(a.dateTime));
        let html = `<div class="flex-between mb-2"><span><strong>${inspections.length}</strong> reports</span>
            <div class="flex gap-2"><button class="btn btn-secondary btn-sm" onclick="app.showDrafts()"><i class="fas fa-save"></i> Drafts</button>
            <button class="btn btn-primary btn-sm" onclick="app.newInspection()"><i class="fas fa-plus"></i> New</button></div></div>`;
        
        inspections.forEach(ins => {
            const eco = ins.ecologicalScore || Utils.calculateScore(ins);
            const cls = Utils.getRatingClass(eco.conditionScore);
            html += `
                <div class="inspection-card" style="border-left-color:${eco.colour};">
                    <div class="card-title">${Utils.escapeHtml(ins.siteName || 'Unnamed')}</div>
                    <div class="card-meta">${Utils.formatDate(ins.dateTime)} · ${ins.inspector || 'Unknown'}</div>
                    <div class="flex gap-2" style="margin:4px 0;">
                        <span class="rating-badge ${cls}">${eco.conditionScore}/10</span>
                        <span class="text-muted text-sm">${eco.riskRating}</span>
                    </div>
                    <div class="health-meter"><div class="health-fill" style="width:${eco.conditionScore*10}%;background:${eco.colour};"></div></div>
                    <div class="card-actions">
                        <button class="btn btn-secondary btn-sm view-insp" data-id="${ins.id}"><i class="fas fa-eye"></i> View</button>
                        <button class="btn btn-primary btn-sm pdf-insp" data-id="${ins.id}"><i class="fas fa-file-pdf"></i> Report</button>
                        <button class="btn btn-danger btn-sm del-insp" data-id="${ins.id}"><i class="fas fa-trash"></i></button>
                    </div>
                    <div class="card-badge" style="background:${eco.colour}20;color:${eco.colour};">${eco.riskRating}</div>
                </div>
            `;
        });
        
        this.setPanel(html, 'Inspections');
        
        document.querySelectorAll('.view-insp').forEach(el => {
            el.onclick = () => this.loadInspection(el.dataset.id, false);
        });
        document.querySelectorAll('.pdf-insp').forEach(el => {
            el.onclick = async () => {
                const ins = await this.db.get(el.dataset.id, false);
                if (ins) this.generateReport(ins);
            };
        });
        document.querySelectorAll('.del-insp').forEach(el => {
            el.onclick = async () => {
                if (confirm('Delete this report?')) {
                    await this.db.delete(el.dataset.id, false);
                    Toast.success('Deleted');
                    this.updateStatus();
                    this.showInspections();
                }
            };
        });
    }
    
