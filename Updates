    bindForm() {
        const input = document.getElementById('photoInput');
        const drop = document.getElementById('photoDropZone');
        
        if (input) {
            input.onchange = (e) => this.handlePhotos(e.target.files);
        }
        if (drop) {
            drop.onclick = () => input?.click();
            drop.ondragover = (e) => { e.preventDefault(); drop.style.borderColor = 'var(--primary)'; };
            drop.ondragleave = () => { drop.style.borderColor = ''; };
            drop.ondrop = (e) => {
                e.preventDefault();
                drop.style.borderColor = '';
                if (e.dataTransfer.files.length) this.handlePhotos(e.dataTransfer.files);
            };
        }
        
        this.renderGallery();
        
        document.getElementById('saveDraftBtn')?.addEventListener('click', () => this.saveDraft());
        document.getElementById('finaliseBtn')?.addEventListener('click', () => this.finalise());
        document.getElementById('cancelBtn')?.addEventListener('click', () => this.closePanel());
        
        document.querySelectorAll('.section-header').forEach(h => {
            h.onclick = () => {
                h.classList.toggle('collapsed');
                h.nextElementSibling?.classList.toggle('collapsed');
            };
        });
        
        ['vegHealth','speciesRichness','regeneration','weedCover','habitatQuality','disturbance'].forEach(id => {
            const el = document.getElementById(id);
            if (el) {
                el.oninput = () => {
                    const data = this.collectForm();
                    const eco = Utils.calculateScore(data);
                    const fill = document.querySelector('.health-fill');
                    const display = document.getElementById('scoreDisplay');
                    if (fill) { fill.style.width = `${eco.conditionScore*10}%`; fill.style.background = eco.colour; }
                    if (display) display.textContent = `${eco.conditionScore}/10`;
                };
            }
        });
    }
    
    // ================================================================
    // PHOTOS
    // ================================================================
    async handlePhotos(files) {
        const maxPhotos = 20;
        const remaining = maxPhotos - this.currentPhotos.length;
        const toProcess = Array.from(files).slice(0, remaining);
        
        if (Array.from(files).length > remaining) {
            Toast.warning(`Only ${remaining} photos can be added`);
        }
        
        for (const file of toProcess) {
            if (file.size > 2 * 1024 * 1024) { Toast.warning(`${file.name} is too large`); continue; }
            const reader = new FileReader();
            const data = await new Promise((resolve) => {
                reader.onload = async (e) => {
                    const compressed = await Utils.compressImage(e.target.result, 800);
                    resolve(compressed);
                };
                reader.readAsDataURL(file);
            });
            this.currentPhotos.push({
                id: Utils.uuid(),
                dataURL: data,
                timestamp: new Date().toISOString(),
                lat: this.currentLat,
                lng: this.currentLng,
                isHero: this.currentPhotos.length === 0
            });
        }
        this.renderGallery();
        Toast.success(`${toProcess.length} photo(s) added`);
    }
    
    renderGallery() {
        const g = document.getElementById('photoGallery');
        if (!g) return;
        if (this.currentPhotos.length === 0) {
            g.innerHTML = `<div style="padding:20px;text-align:center;color:var(--gray-400);grid-column:1/-1;"><i class="fas fa-camera" style="font-size:20px;display:block;margin-bottom:4px;"></i>No photos</div>`;
            return;
        }
        g.innerHTML = this.currentPhotos.map((p, i) => `
            <div class="photo-item" data-idx="${i}">
                <img src="${p.dataURL}" alt="Photo ${i+1}" loading="lazy">
                <div class="photo-overlay"><span>${new Date(p.timestamp).toLocaleTimeString()}</span></div>
                <button class="remove-photo" data-idx="${i}">×</button>
                ${p.isHero ? '<div class="hero-badge">Cover</div>' : ''}
            </div>
        `).join('');
        
        document.querySelectorAll('.remove-photo').forEach(el => {
            el.onclick = (e) => {
                e.stopPropagation();
                const idx = parseInt(el.dataset.idx);
                this.currentPhotos.splice(idx, 1);
                if (this.currentPhotos.length > 0 && !this.currentPhotos.some(p => p.isHero)) {
                    this.currentPhotos[0].isHero = true;
                }
                this.renderGallery();
            };
        });
        
        document.querySelectorAll('.photo-item').forEach((el, idx) => {
            el.onclick = () => {
                this.currentPhotos.forEach((p, i) => p.isHero = (i === idx));
                this.renderGallery();
                Toast.success('Cover photo set');
            };
        });
    }
    
    // ================================================================
    // CRUD
    // ================================================================
    async newInspection() {
        this.currentId = Utils.uuid();
        this.currentPhotos = [];
        this.isDraft = false;
        this.clearMap();
        this.setPanel(this.renderForm({ id: this.currentId }), 'New Ecological Assessment');
        this.bindForm();
    }
    
    async loadInspection(id, draft = false) {
        try {
            const data = await this.db.get(id, draft);
            if (!data) { Toast.error('Not found'); return; }
            this.currentId = data.id;
            this.currentPhotos = data.photos || [];
            this.isDraft = draft;
            this.clearMap();
            this.loadGeometry(data.geometry || []);
            (data.waypoints || []).forEach(w => {
                this.drawnItems.addLayer(L.marker([w.lat, w.lng]).bindPopup(`<strong>${Utils.escapeHtml(w.label)}</strong>`));
            });
            this.setPanel(this.renderForm(data), draft ? 'Edit Draft' : 'View Inspection');
            this.bindForm();
        } catch (e) { console.error('Load error:', e); Toast.error('Failed to load'); }
    }
    
    async saveDraft() {
        try {
            const data = this.collectForm();
            if (!data.siteName) { Toast.warning('Site name required'); return; }
            data.status = 'draft';
            await this.db.save(data, true);
            this.isDraft = true;
            Toast.success('Draft saved');
            await this.updateStatus();
        } catch (e) { console.error('Save draft error:', e); Toast.error('Failed to save draft'); }
    }
    
    async finalise() {
        try {
            const data = this.collectForm();
            if (!data.siteName) { Toast.warning('Site name required'); return; }
            data.status = 'finalised';
            data.ecologicalScore = Utils.calculateScore(data);
            await this.db.save(data, false);
            await this.db.delete(data.id, true);
            await this.generateReport(data);
            this.closePanel();
            await this.updateStatus();
            this.showInspections();
        } catch (e) { console.error('Finalise error:', e); Toast.error('Failed to finalise'); }
    }
    
    // ================================================================
    // REPORT
    // ================================================================
    async generateReport(inspection) {
        try {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF('p', 'mm', 'a4');
            const pageWidth = 210, pageHeight = 297, margin = 18;
            let y = margin;
            const eco = inspection.ecologicalScore || Utils.calculateScore(inspection);
            const colour = '#1a5f4a';
            
            const addText = (text, size = 10, color = '#333') => {
                if (!text) return;
                doc.setFontSize(size);
                doc.setTextColor(color);
                const lines = doc.splitTextToSize(text || '', pageWidth - 2*margin);
                doc.text(lines, margin, y);
                y += lines.length * (size * 0.45) + 1.5;
            };
            
            const addTitle = (text, size = 18, color = colour) => {
                doc.setFontSize(size);
                doc.setTextColor(color);
                doc.text(text, margin, y);
                y += size * 0.4 + 2;
            };
            
            const drawLine = () => { doc.setDrawColor(colour); doc.setLineWidth(0.5); doc.line(margin, y, pageWidth - margin, y); y += 6; };
            
            // Cover
            doc.setFillColor(colour);
            doc.rect(0, 0, pageWidth, 5, 'F');
            y = 30;
            doc.setFontSize(28);
            doc.setTextColor(colour);
            doc.text('ENVIRONMENTAL', margin, y);
            y += 14;
            doc.text('ASSESSMENT REPORT', margin, y);
            y += 12;
            drawLine();
            y += 4;
            doc.setFontSize(18);
            doc.setTextColor('#222');
            doc.text(Utils.escapeHtml(inspection.siteName || 'Site Assessment'), margin, y);
            y += 10;
            doc.setFontSize(11);
            doc.setTextColor('#666');
            doc.text(`Prepared for: ${Utils.escapeHtml(inspection.organization || 'Environmental Client')}`, margin, y);
            y += 6;
            doc.text(`Date: ${Utils.formatDate(inspection.dateTime)}`, margin, y);
            y += 8;
            
            // Hero image
            if (inspection.photos && inspection.photos.length > 0) {
                const hero = inspection.photos.find(p => p.isHero) || inspection.photos[0];
                try {
                    doc.addImage(hero.dataURL, 'JPEG', margin+5, y, pageWidth-2*margin-10, 60);
                    y += 66;
                } catch(e) {
                    doc.setFillColor('#f5f5f5');
                    doc.roundedRect(margin+5, y, pageWidth-2*margin-10, 40, 3, 3, 'F');
                    doc.setFontSize(10);
                    doc.setTextColor('#999');
                    doc.text('Cover Photo', pageWidth/2, y+22, { align: 'center' });
                    y += 46;
                }
            }
            
            doc.setFontSize(8);
            doc.setTextColor('#888');
            doc.text(`Report ID: ${inspection.id}`, margin, y);
            doc.text('v4.0', pageWidth-margin, y, { align: 'right' });
            y += 6;
            doc.text(`Author: ${Utils.escapeHtml(inspection.inspector || 'Consultant')}`, margin, y);
            y += 8;
            
            doc.setFillColor(colour);
            doc.rect(0, pageHeight-6, pageWidth, 3, 'F');
            doc.setFontSize(7);
            doc.setTextColor('#999');
            doc.text('© EcoMaintenance Professional', margin, pageHeight-3);
            doc.text(new Date().toLocaleDateString(), pageWidth-margin, pageHeight-3, { align: 'right' });
            
            // Summary
            doc.addPage();
            y = margin + 8;
            addTitle('EXECUTIVE SUMMARY', 20);
            drawLine();
            y += 4;
            addText(`This report presents findings of an ecological assessment at "${Utils.escapeHtml(inspection.siteName)}" conducted on ${Utils.formatDate(inspection.dateTime)}.`, 10);
            y += 4;
            addText(`Condition Score: ${eco.conditionScore}/10 (${eco.riskRating})`, 10);
            addText(`Significance: ${eco.significance}`, 10);
            addText(`Management Priority: ${eco.priority}`, 10);
            y += 4;
            
            // Details
            addTitle('ASSESSMENT DETAILS', 16);
            drawLine();
            y += 4;
            const details = [
                ['Vegetation Health', `${inspection.vegHealth || 6}/10`],
                ['Species Richness', `${inspection.speciesRichness || 5}/10`],
                ['Regeneration', `${inspection.regeneration || 5}/10`],
                ['Weed Cover', `${inspection.weedCover || 30}%`],
                ['Habitat Quality', `${inspection.habitatQuality || 5}/10`],
                ['Disturbance', `${inspection.disturbance || 3}/10`]
            ];
            doc.autoTable({
                startY: y,
                head: [['Parameter', 'Value']],
                body: details,
                theme: 'striped',
                headStyles: { fillColor: colour, textColor: '#fff', fontSize: 9 },
                bodyStyles: { fontSize: 8 },
                columnStyles: { 0: { cellWidth: 70 }, 1: { cellWidth: 100 } }
            });
            y = doc.lastAutoTable.finalY + 8;
            
            // Recommendations
            addTitle('RECOMMENDATIONS', 14);
            drawLine();
            y += 4;
            addText(inspection.recommendations || 'No recommendations recorded.', 9);
            y += 4;
            
            // Observations
            addTitle('OBSERVATIONS', 14);
            drawLine();
            y += 4;
            addText(inspection.observations || 'No observations recorded.', 9);
            
            // Photos
            doc.addPage();
            y = margin + 8;
            addTitle('PHOTO DOCUMENTATION', 18);
            drawLine();
            y += 4;
            if (inspection.photos && inspection.photos.length > 0) {
                const photos = inspection.photos.slice(0, 9);
                let px = margin, py = y;
                const size = 55;
                photos.forEach((p, i) => {
                    if (i > 0 && i % 3 === 0) { px = margin; py += size + 6; }
                    try {
                        doc.addImage(p.dataURL, 'JPEG', px, py, size, size * 0.75);
                        px += size + 4;
                    } catch(e) {}
                });
                y = py + size + 10;
                doc.setFontSize(8);
                doc.setTextColor('#666');
                doc.text(`Total ${inspection.photos.length} images`, margin, y);
            } else {
                addText('No photos uploaded.', 10);
            }
            
            // Footer all pages
            const total = doc.internal.getNumberOfPages();
            for (let i = 1; i <= total; i++) {
                doc.setPage(i);
                doc.setDrawColor(colour);
                doc.setLineWidth(0.3);
                doc.line(margin, pageHeight-10, pageWidth-margin, pageHeight-10);
                doc.setFontSize(7);
                doc.setTextColor('#aaa');
                doc.text(`Page ${i} of ${total}`, pageWidth/2, pageHeight-5, { align: 'center' });
                doc.text(inspection.id, margin, pageHeight-5);
            }
            
            doc.save(`EcoMaintenance_Report_${inspection.id}.pdf`);
            Toast.success('Report generated');
        } catch (e) { console.error('Report error:', e); Toast.error('Failed to generate report'); }
    }
    
