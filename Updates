                        Toast.success('Deleted');
                        await this.updateStatus();
                        this.showInspections();
                    }
                };
            });
        } catch (e) { console.error('Inspections error:', e); Toast.error('Failed to load'); }
    }
    
    async showDrafts() {
        try {
            const drafts = await this.db.getAll('drafts');
            if (drafts.length === 0) {
                this.setPanel(`
                    <div class="text-center" style="padding:40px 20px;">
                        <i class="fas fa-save" style="font-size:40px;opacity:0.3;display:block;margin-bottom:12px;"></i>
                        <h3>No Drafts</h3>
                        <p class="text-muted">Start a new assessment to create a draft.</p>
                        <button class="btn btn-primary mt-3" onclick="app.newInspection()"><i class="fas fa-plus"></i> Start New</button>
                    </div>
                `, 'Drafts');
                return;
            }
            
            drafts.sort((a, b) => new Date(b.updatedAt) - new Date(a.updatedAt));
            let html = `
                <div class="flex-between mb-2">
                    <span><strong>${drafts.length}</strong> drafts</span>
                    <div class="flex gap-2">
                        <button class="btn btn-secondary btn-sm" onclick="app.showInspections()"><i class="fas fa-folder-open"></i> Reports</button>
                        <button class="btn btn-primary btn-sm" onclick="app.newInspection()"><i class="fas fa-plus"></i> New</button>
                    </div>
                </div>
            `;
            
            drafts.forEach(d => {
                html += `
                    <div class="inspection-card" style="border-left-color:var(--warning);">
                        <div class="card-title">${Utils.escapeHtml(d.siteName || 'Unnamed Draft')}</div>
                        <div class="card-meta">Edited: ${Utils.formatDate(d.updatedAt)} · ${d.inspector || 'No inspector'}</div>
                        <div class="card-actions">
                            <button class="btn btn-secondary btn-sm resume-draft" data-id="${d.id}"><i class="fas fa-pen"></i> Resume</button>
                            <button class="btn btn-danger btn-sm del-draft" data-id="${d.id}"><i class="fas fa-trash"></i></button>
                        </div>
                        <div class="card-badge" style="background:rgba(212,168,67,0.15);color:var(--warning);">Draft</div>
                    </div>
                `;
            });
            
            this.setPanel(html, 'Drafts');
            
            document.querySelectorAll('.resume-draft').forEach(el => {
                el.onclick = () => this.loadInspection(el.dataset.id, true);
            });
            document.querySelectorAll('.del-draft').forEach(el => {
                el.onclick = async () => {
                    if (confirm('Delete this draft?')) {
                        await this.db.delete(el.dataset.id, true);
                        Toast.success('Deleted');
                        await this.updateStatus();
                        this.showDrafts();
                    }
                };
            });
        } catch (e) { console.error('Drafts error:', e); Toast.error('Failed to load'); }
    }
    
    async showDataManager() {
        try {
            const insp = await this.db.count('inspections');
            const drafts = await this.db.count('drafts');
            const html = `
                <div style="max-width:440px;margin:0 auto;">
                    <div class="dashboard-grid" style="grid-template-columns:1fr 1fr;">
                        <div class="stat-card text-center"><div class="stat-value">${insp}</div><div class="stat-label">Reports</div></div>
                        <div class="stat-card text-center"><div class="stat-value">${drafts}</div><div class="stat-label">Drafts</div></div>
                    </div>
                    <h4 class="mb-2"><i class="fas fa-download"></i> Export</h4>
                    <button class="btn btn-primary w-full mb-2" onclick="app.exportCSV()"><i class="fas fa-file-excel"></i> Export Excel</button>
                    <button class="btn btn-secondary w-full mb-2" onclick="app.exportJSON()"><i class="fas fa-code"></i> Export JSON</button>
                    <button class="btn btn-secondary w-full mb-4" onclick="app.exportGeoJSON()"><i class="fas fa-map"></i> Export GeoJSON</button>
                    <h4 class="mb-2"><i class="fas fa-upload"></i> Import</h4>
                    <input type="file" id="importFile" accept=".json" style="margin-bottom:6px;">
                    <button class="btn btn-secondary w-full mb-4" onclick="app.importJSON()"><i class="fas fa-upload"></i> Import JSON</button>
                    <hr style="margin:12px 0;border-color:var(--gray-200);">
                    <button class="btn btn-danger w-full" onclick="app.clearAll()"><i class="fas fa-trash"></i> Clear All Data</button>
                    <div style="margin-top:12px;padding:10px;background:var(--gray-50);border-radius:var(--radius-sm);border:1px solid var(--gray-200);">
                        <div class="text-xs text-muted">
                            <strong>Storage:</strong> ${this.db.db ? 'IndexedDB' : 'Memory'}<br>
                            <strong>Reports:</strong> ${insp} | <strong>Drafts:</strong> ${drafts}
                        </div>
                    </div>
                </div>
            `;
            this.setPanel(html, 'Data Manager');
        } catch (e) { console.error('Data manager error:', e); Toast.error('Failed to load'); }
    }
    
    // ================================================================
    // EXPORT/IMPORT
    // ================================================================
    async exportCSV() {
        try {
            const insp = await this.db.getAll('inspections');
            if (!insp.length) { Toast.warning('No data'); return; }
            const data = insp.map(i => ({
                'ID': i.id, 'Site': i.siteName, 'Inspector': i.inspector,
                'Date': i.dateTime, 'Score': i.ecologicalScore?.conditionScore || '',
                'Risk': i.ecologicalScore?.riskRating || ''
            }));
            const ws = XLSX.utils.json_to_sheet(data);
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, 'Inspections');
            XLSX.writeFile(wb, `EcoMaintenance_${new Date().toISOString().slice(0,10)}.xlsx`);
            Toast.success('Excel export complete');
        } catch (e) { console.error('Export error:', e); Toast.error('Export failed'); }
    }
    
    async exportJSON() {
        try {
            const insp = await this.db.getAll('inspections');
            const drafts = await this.db.getAll('drafts');
            const data = { exportDate: new Date().toISOString(), version: '4.0', inspections: insp, drafts: drafts };
            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = `EcoMaintenance_Data_${new Date().toISOString().slice(0,10)}.json`;
            a.click();
            URL.revokeObjectURL(a.href);
            Toast.success('JSON export complete');
        } catch (e) { console.error('Export error:', e); Toast.error('Export failed'); }
    }
    
    exportGeoJSON() {
        try {
            const features = [
                ...this.getGeometry(),
                ...this.getWaypoints().map(w => ({
                    type: 'Feature',
                    geometry: { type: 'Point', coordinates: [w.lng, w.lat] },
                    properties: { label: w.label }
                }))
            ];
            const fc = { type: 'FeatureCollection', features };
            const blob = new Blob([JSON.stringify(fc, null, 2)], { type: 'application/json' });
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = `EcoMaintenance_Map_${Date.now()}.geojson`;
            a.click();
            URL.revokeObjectURL(a.href);
            Toast.success('GeoJSON exported');
        } catch (e) { console.error('Export error:', e); Toast.error('Export failed'); }
    }
    
    async importJSON() {
        const file = document.getElementById('importFile')?.files[0];
        if (!file) { Toast.warning('Select a JSON file'); return; }
        const reader = new FileReader();
        reader.onload = async (e) => {
            try {
                const data = JSON.parse(e.target.result);
                let count = 0;
                if (data.inspections) {
                    for (const insp of data.inspections) { await this.db.save(insp, false); count++; }
                }
                if (data.drafts) {
                    for (const draft of data.drafts) { await this.db.save(draft, true); count++; }
                }
                Toast.success(`Imported ${count} records`);
                await this.updateStatus();
                this.showDataManager();
            } catch (err) { Toast.error('Invalid JSON file'); }
        };
        reader.readAsText(file);
    }
    
    async clearAll() {
        if (!confirm('Delete ALL data? This cannot be undone.')) return;
        if (!confirm('Are you absolutely sure?')) return;
        try {
            await this.db.clear('inspections');
            await this.db.clear('drafts');
            Toast.success('All data cleared');
            await this.updateStatus();
            this.showDashboard();
        } catch (e) { Toast.error('Failed to clear data'); }
    }
    
    // ================================================================
    // EVENTS
    // ================================================================
    bindEvents() {
        // Navigation
        document.querySelector('.sidebar-nav').addEventListener('click', (e) => {
            const item = e.target.closest('.nav-item');
            if (!item) return;
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
            item.classList.add('active');
            const view = item.dataset.view;
            switch(view) {
                case 'dashboard': this.showDashboard(); break;
                case 'inspections': this.showInspections(); break;
                case 'new': this.newInspection(); break;
                case 'mapview': this.closePanel(); break;
                case 'drafts': this.showDrafts(); break;
                case 'data': this.showDataManager(); break;
            }
        });
        
        // Toolbar
        document.getElementById('newInspectionBtn').addEventListener('click', () => this.newInspection());
        document.getElementById('listInspectionsBtn').addEventListener('click', () => this.showInspections());
        document.getElementById('closePanelBtn').addEventListener('click', () => this.closePanel());
        document.getElementById('clearMapBtn').addEventListener('click', () => this.clearMap());
        document.getElementById('exportGeoJsonBtn').addEventListener('click', () => this.exportGeoJSON());
        document.getElementById('exportCSVBtn').addEventListener('click', () => this.exportCSV());
        document.getElementById('measureBtn').addEventListener('click', () => this.startMeasure());
        document.getElementById('locateBtn').addEventListener('click', () => this.locateUser());
        document.getElementById('resetMapBtn').addEventListener('click', () => this.resetView());
        document.getElementById('sidebarToggle').addEventListener('click', () => {
            document.getElementById('sidebar').classList.toggle('open');
        });
        
        document.querySelector('.main-content').addEventListener('click', () => {
            if (window.innerWidth <= 768) {
                document.getElementById('sidebar').classList.remove('open');
            }
        });
        
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') this.closePanel();
            if (e.ctrlKey && e.key === 'n') { e.preventDefault(); this.newInspection(); }
        });
    }
}

// ================================================================
// START
// ================================================================
const app = new App();
window.app = app;
document.addEventListener('DOMContentLoaded', () => app.init());
</script>
</body>
