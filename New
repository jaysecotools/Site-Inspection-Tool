    bindForm() {
        const input = document.getElementById('photoInput');
        const drop = document.getElementById('photoDropZone');
        
        if (input) {
            input.onchange = (e) => this.handlePhotos(e.target.files);
        }
        if (drop) {
            drop.onclick = () => input?.click();
            drop.ondragover = (e) => { 
                e.preventDefault(); 
                drop.classList.add('dragover');
            };
            drop.ondragleave = () => { 
                drop.classList.remove('dragover');
            };
            drop.ondrop = (e) => {
                e.preventDefault();
                drop.classList.remove('dragover');
                if (e.dataTransfer.files.length) this.handlePhotos(e.dataTransfer.files);
            };
        }
        
        this.renderGallery();
        
        // Direct event binding
        const saveBtn = document.getElementById('saveDraftBtn');
        const finalBtn = document.getElementById('finaliseBtn');
        const cancelBtn = document.getElementById('cancelBtn');
        
        if (saveBtn) saveBtn.onclick = () => this.saveDraft();
        if (finalBtn) finalBtn.onclick = () => this.finalise();
        if (cancelBtn) cancelBtn.onclick = () => this.closePanel();
        
        // Section toggles
        document.querySelectorAll('.section-header').forEach(h => {
            h.onclick = () => {
                h.classList.toggle('collapsed');
                if (h.nextElementSibling) h.nextElementSibling.classList.toggle('collapsed');
            };
        });
        
        // Live score update with icon
        ['vegHealth','speciesRichness','regeneration','weedCover','habitatQuality','disturbance'].forEach(id => {
            const el = document.getElementById(id);
            if (el) {
                el.oninput = () => {
                    const data = this.collectForm();
                    const eco = Utils.calculateScore(data);
                    const fill = document.querySelector('.health-fill');
                    const display = document.getElementById('scoreDisplay');
                    if (fill) { fill.style.width = `${eco.conditionScore*10}%`; fill.style.background = eco.colour; }
                    if (display) { 
                        display.innerHTML = `${eco.conditionScore}/10 <i class="fas ${eco.icon}" style="color:${eco.colour};font-size:0.9rem;"></i>`;
                    }
                    // Update value display
                    const valSpan = document.getElementById(id + 'Val');
                    if (valSpan) valSpan.textContent = el.value;
                };
            }
        });
    }
    
    // ================================================================
    // PHOTOS - IMPROVED WITH COMPRESSION
    // ================================================================
    async handlePhotos(files) {
        const maxPhotos = 20;
        const remaining = maxPhotos - this.currentPhotos.length;
        const toProcess = Array.from(files).slice(0, remaining);
        
        if (Array.from(files).length > remaining) {
            Toast.warning(`Only ${remaining} more photos can be added`);
        }
        
        let added = 0;
        let errors = 0;
        
        for (const file of toProcess) {
            // Check file size - warn but still try to process
            if (file.size > 5 * 1024 * 1024) {
                Toast.warning(`${file.name} is large (${Utils.formatFileSize(file.size)}), compressing...`);
            }
            
            try {
                const reader = new FileReader();
                const data = await new Promise((resolve) => {
                    reader.onload = async (e) => {
                        // Compress image - max 800x800, 85% quality
                        const compressed = await Utils.compressImage(e.target.result, 800, 800, 0.85);
                        resolve(compressed);
                    };
                    reader.onerror = () => resolve(null);
                    reader.readAsDataURL(file);
                });
                
                if (!data) { errors++; continue; }
                
                this.currentPhotos.push({
                    id: Utils.uuid(),
                    dataURL: data,
                    timestamp: new Date().toISOString(),
                    lat: this.currentLat,
                    lng: this.currentLng,
                    isHero: this.currentPhotos.length === 0,
                    filename: file.name,
                    size: file.size
                });
                added++;
            } catch (e) {
                console.error('Photo processing error:', e);
                errors++;
            }
        }
        
        this.renderGallery();
        
        // Update photo count in upload area
        const countEl = document.querySelector('.photo-count');
        if (countEl) {
            countEl.textContent = `${this.currentPhotos.length} photos added`;
        }
        
        if (added > 0) Toast.success(`${added} photo(s) added`);
        if (errors > 0) Toast.warning(`${errors} photo(s) failed to process`);
    }
    
    renderGallery() {
        const g = document.getElementById('photoGallery');
        if (!g) return;
        
        if (this.currentPhotos.length === 0) {
            g.innerHTML = `
                <div style="padding:16px;text-align:center;color:var(--gray-400);grid-column:1/-1;">
                    <i class="fas fa-camera" style="font-size:18px;display:block;margin-bottom:2px;"></i>
                    No photos
                </div>
            `;
            return;
        }
        
        g.innerHTML = this.currentPhotos.map((p, i) => `
            <div class="photo-item" data-idx="${i}">
                <img src="${p.dataURL}" alt="Photo ${i+1}" loading="lazy">
                <div class="photo-overlay">
                    <span>${new Date(p.timestamp).toLocaleTimeString()}</span>
                    ${p.filename ? `<span style="opacity:0.6;font-size:0.45rem;">${p.filename.split('.').pop()}</span>` : ''}
                </div>
                <button class="remove-photo" data-idx="${i}" title="Remove photo">×</button>
                ${p.isHero ? '<div class="hero-badge">Cover</div>' : ''}
            </div>
        `).join('');
        
        document.querySelectorAll('.remove-photo').forEach(el => {
            el.onclick = (e) => {
                e.stopPropagation();
                const idx = parseInt(el.dataset.idx);
                this.currentPhotos.splice(idx, 1);
                if (this.currentPhotos.length > 0 && !this.currentPhotos.some(p => p.isHero)) {
                    this.currentPhotos[0].isHero = true;
                }
                this.renderGallery();
                // Update count
                const countEl = document.querySelector('.photo-count');
                if (countEl) countEl.textContent = `${this.currentPhotos.length} photos added`;
            };
        });
        
        document.querySelectorAll('.photo-item').forEach((el, idx) => {
            el.onclick = () => {
                this.currentPhotos.forEach((p, i) => p.isHero = (i === idx));
                this.renderGallery();
                Toast.success('Cover photo set');
            };
        });
    }
    
    // ================================================================
    // CRUD
    // ================================================================
    async newInspection() {
        this.currentId = Utils.uuid();
        this.currentPhotos = [];
        this.isDraft = false;
        this.clearMap();
        this.setPanel(this.renderForm({ id: this.currentId }), 'New Ecological Assessment');
        this.bindForm();
    }
    
    async loadInspection(id, draft = false) {
        try {
            const data = await this.db.get(id, draft);
            if (!data) { Toast.error('Not found'); return; }
            this.currentId = data.id;
            this.currentPhotos = data.photos || [];
            this.isDraft = draft;
            this.clearMap();
            this.loadGeometry(data.geometry || []);
            (data.waypoints || []).forEach(w => {
                this.drawnItems.addLayer(
                    L.marker([w.lat, w.lng])
                        .bindPopup(`<strong>${Utils.escapeHtml(w.label)}</strong>`)
                );
            });
            this.setPanel(this.renderForm(data), draft ? 'Edit Draft' : 'View Inspection');
            this.bindForm();
            
            // Update photo count
            const countEl = document.querySelector('.photo-count');
            if (countEl) countEl.textContent = `${this.currentPhotos.length} photos added`;
        } catch (e) { console.error('Load error:', e); Toast.error('Failed to load'); }
    }
    
    async saveDraft() {
        try {
            const data = this.collectForm();
            if (!data.siteName) { Toast.warning('Site name required'); return; }
            data.status = 'draft';
            await this.db.save(data, true);
            this.isDraft = true;
            Toast.success('Draft saved');
            await this.updateStatus();
        } catch (e) { console.error('Save draft error:', e); Toast.error('Failed to save draft'); }
    }
    
    async finalise() {
        try {
            const data = this.collectForm();
            if (!data.siteName) { Toast.warning('Site name required'); return; }
            data.status = 'finalised';
            data.ecologicalScore = Utils.calculateScore(data);
            await this.db.save(data, false);
            await this.db.delete(data.id, true);
            await this.generateReport(data);
            this.closePanel();
            await this.updateStatus();
            this.showInspections();
        } catch (e) { console.error('Finalise error:', e); Toast.error('Failed to finalise'); }
    }
    
    // ================================================================
    // PROFESSIONAL REPORT
    // ================================================================
    async generateReport(inspection) {
        try {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF('p', 'mm', 'a4');
            const pageWidth = 210, pageHeight = 297, margin = 18;
            let y = margin;
            const eco = inspection.ecologicalScore || Utils.calculateScore(inspection);
            const colour = '#1a5f4a';
            
            // Helper functions
            const addText = (text, size = 10, color = '#333') => {
                if (!text) return;
                doc.setFontSize(size);
                doc.setTextColor(color);
                const lines = doc.splitTextToSize(text || '', pageWidth - 2*margin);
                doc.text(lines, margin, y);
                y += lines.length * (size * 0.45) + 1.5;
            };
            
            const addTitle = (text, size = 18, color = colour) => {
                doc.setFontSize(size);
                doc.setTextColor(color);
                doc.text(text, margin, y);
                y += size * 0.4 + 2;
            };
            
            const drawLine = () => { 
                doc.setDrawColor(colour); 
                doc.setLineWidth(0.5); 
                doc.line(margin, y, pageWidth - margin, y); 
                y += 6; 
            };
            
            // --- COVER PAGE ---
            doc.setFillColor(colour);
            doc.rect(0, 0, pageWidth, 6, 'F');
            y = 30;
            
            // Title
            doc.setFontSize(32);
            doc.setTextColor(colour);
            doc.text('ENVIRONMENTAL', margin, y);
            y += 14;
            doc.text('ASSESSMENT REPORT', margin, y);
            y += 12;
            drawLine();
            y += 6;
            
            // Site name
            doc.setFontSize(20);
            doc.setTextColor('#222');
            doc.text(Utils.escapeHtml(inspection.siteName || 'Site Assessment'), margin, y);
            y += 12;
            
            // Metadata
            doc.setFontSize(11);
            doc.setTextColor('#666');
            doc.text(`Prepared for: ${Utils.escapeHtml(inspection.organization || 'Environmental Client')}`, margin, y);
            y += 6;
            doc.text(`Date: ${Utils.formatDate(inspection.dateTime)}`, margin, y);
            y += 6;
            doc.text(`Report ID: ${inspection.id}`, margin, y);
            y += 6;
            doc.text(`Author: ${Utils.escapeHtml(inspection.inspector || 'Environmental Consultant')}`, margin, y);
            y += 10;
            
            // Hero image with aspect ratio preservation
            if (inspection.photos && inspection.photos.length > 0) {
                const hero = inspection.photos.find(p => p.isHero) || inspection.photos[0];
                try {
                    // Get image dimensions for proper aspect ratio
                    const img = new Image();
                    const imgData = await new Promise((resolve) => {
                        img.onload = () => resolve({ width: img.width, height: img.height });
                        img.onerror = () => resolve(null);
                        img.src = hero.dataURL;
                    });
                    
                    if (imgData) {
                        const maxImgWidth = pageWidth - 2*margin - 20;
                        const maxImgHeight = 80;
                        let imgWidth = maxImgWidth;
                        let imgHeight = (imgData.height / imgData.width) * maxImgWidth;
                        
                        if (imgHeight > maxImgHeight) {
                            imgHeight = maxImgHeight;
                            imgWidth = (imgData.width / imgData.height) * maxImgHeight;
                        }
                        
                        const xOffset = margin + 10 + (maxImgWidth - imgWidth) / 2;
                        doc.addImage(hero.dataURL, 'JPEG', xOffset, y, imgWidth, imgHeight);
                        y += imgHeight + 8;
                        
                        doc.setFontSize(7);
                        doc.setTextColor('#999');
                        doc.text(`Cover Photo: ${inspection.siteName}`, margin + 10, y);
                        y += 6;
                    } else {
                        // Fallback if image loading fails
                        doc.setFillColor('#f5f5f5');
                        doc.roundedRect(margin+10, y, pageWidth-2*margin-20, 50, 4, 4, 'F');
                        doc.setFontSize(10);
                        doc.setTextColor('#999');
                        doc.text('Project Photograph', pageWidth/2, y+25, { align: 'center' });
                        y += 56;
                    }
                } catch(e) {
                    // Fallback
                    doc.setFillColor('#f5f5f5');
                    doc.roundedRect(margin+10, y, pageWidth-2*margin-20, 50, 4, 4, 'F');
                    doc.setFontSize(10);
                    doc.setTextColor('#999');
                    doc.text('Project Photograph', pageWidth/2, y+25, { align: 'center' });
                    y += 56;
                }
            }
            
            // Footer on cover
            doc.setFillColor(colour);
            doc.rect(0, pageHeight-6, pageWidth, 3, 'F');
            doc.setFontSize(7);
            doc.setTextColor('#999');
            doc.text('© EcoMaintenance Professional v4.0', margin, pageHeight-3);
            doc.text('Environmental Assessment Report', pageWidth/2, pageHeight-3, { align: 'center' });
            
            // --- SUMMARY PAGE ---
            doc.addPage();
            y = margin + 10;
            addTitle('EXECUTIVE SUMMARY', 22);
            drawLine();
            y += 6;
            
            // Score highlight
            doc.setFontSize(14);
            doc.setTextColor(colour);
            doc.text(`Overall Condition Score: ${eco.conditionScore}/10`, margin, y);
            y += 8;
            
            // Risk rating with color
            doc.setFontSize(11);
            doc.setTextColor(eco.colour);
            doc.text(`Risk Rating: ${eco.riskRating}`, margin, y);
            y += 6;
            doc.setTextColor('#333');
            doc.text(`Management Priority: ${eco.priority}`, margin, y);
            y += 6;
            doc.text(`Conservation Significance: ${eco.significance}`, margin, y);
            y += 10;
            
            // Summary text
            addText(`This report presents findings of an ecological assessment at "${Utils.escapeHtml(inspection.siteName)}" conducted on ${Utils.formatDate(inspection.dateTime)}.`, 10);
            y += 6;
            
            // Key findings
            doc.setFontSize(11);
            doc.setTextColor(colour);
            doc.text('Key Findings:', margin, y);
            y += 5;
            doc.setFontSize(9);
            doc.setTextColor('#444');
            const findings = [
                `• Vegetation Health: ${inspection.vegHealth || 6}/10`,
                `• Species Richness: ${inspection.speciesRichness || 5} species recorded`,
                `• Weed Cover: ${inspection.weedCover || 30}%`,
                `• Habitat Quality: ${inspection.habitatQuality || 5}/10`,
                `• Disturbance Level: ${inspection.disturbance || 3}/10`
            ];
            findings.forEach(f => { doc.text(f, margin + 4, y); y += 5; });
            y += 6;
            
            // --- ASSESSMENT DETAILS ---
            addTitle('ASSESSMENT DETAILS', 16);
            drawLine();
            y += 4;
            
            const details = [
                ['Parameter', 'Value', 'Status'],
                ['Vegetation Health', `${inspection.vegHealth || 6}/10`, getStatusBadge(inspection.vegHealth || 6, 10)],
                ['Species Richness', `${inspection.speciesRichness || 5}/10`, getStatusBadge(inspection.speciesRichness || 5, 10)],
                ['Regeneration', `${inspection.regeneration || 5}/10`, getStatusBadge(inspection.regeneration || 5, 10)],
                ['Weed Cover', `${inspection.weedCover || 30}%`, getStatusBadge(100 - (inspection.weedCover || 30), 100)],
                ['Habitat Quality', `${inspection.habitatQuality || 5}/10`, getStatusBadge(inspection.habitatQuality || 5, 10)],
                ['Disturbance', `${inspection.disturbance || 3}/10`, getStatusBadge(10 - (inspection.disturbance || 3), 10)]
            ];
            
            function getStatusBadge(value, max) {
                const ratio = value / max;
                if (ratio >= 0.8) return '✅ Good';
                if (ratio >= 0.5) return '⚠️ Moderate';
                return '❌ Poor';
            }
            
            doc.autoTable({
                startY: y,
                head: [['Parameter', 'Value', 'Status']],
                body: details.slice(1),
                theme: 'striped',
                headStyles: { fillColor: colour, textColor: '#fff', fontSize: 9 },
                bodyStyles: { fontSize: 8 },
                columnStyles: { 0: { cellWidth: 60 }, 1: { cellWidth: 40 }, 2: { cellWidth: 70 } },
                didDrawCell: function(data) {
                    if (data.section === 'body' && data.column.index === 2) {
                        const text = data.cell.raw;
                        let color = '#10b981';
                        if (text.includes('⚠️')) color = '#f59e0b';
                        if (text.includes('❌')) color = '#dc2626';
                        data.cell.styles.textColor = color;
                    }
                }
            });
            y = doc.lastAutoTable.finalY + 10;
            
            // --- RECOMMENDATIONS ---
            addTitle('RECOMMENDATIONS', 14);
            drawLine();
            y += 4;
            const recs = inspection.recommendations || 'No specific recommendations recorded.';
            addText(recs, 9);
            y += 8;
            
            // --- OBSERVATIONS ---
            addTitle('OBSERVATIONS', 14);
            drawLine();
            y += 4;
            const obs = inspection.observations || 'No observations recorded.';
            addText(obs, 9);
            
            // --- PHOTOS ---
            doc.addPage();
            y = margin + 10;
            addTitle('PHOTO DOCUMENTATION', 18);
            drawLine();
            y += 6;
            
            if (inspection.photos && inspection.photos.length > 0) {
                const photos = inspection.photos.slice(0, 12);
                let px = margin, py = y;
                const size = 50;
                const gap = 4;
                const cols = Math.floor((pageWidth - 2*margin) / (size + gap));
                
                photos.forEach((p, i) => {
                    if (i > 0 && i % cols === 0) { 
                        px = margin; 
                        py += size + gap; 
                    }
                    if (py > pageHeight - margin - 20) {
                        doc.addPage();
                        py = margin + 10;
                        px = margin;
                    }
                    try {
                        doc.addImage(p.dataURL, 'JPEG', px, py, size, size * 0.75);
                        px += size + gap;
                    } catch(e) {}
                });
                
                y = py + size + 12;
                doc.setFontSize(8);
                doc.setTextColor('#666');
                doc.text(`Total ${inspection.photos.length} images captured during assessment.`, margin, y);
            } else {
                addText('No photos were captured during this assessment.', 10);
            }
            
            // Footer all pages
            const total = doc.internal.getNumberOfPages();
            for (let i = 1; i <= total; i++) {
                doc.setPage(i);
                doc.setDrawColor(colour);
                doc.setLineWidth(0.3);
                doc.line(margin, pageHeight-10, pageWidth-margin, pageHeight-10);
                doc.setFontSize(7);
                doc.setTextColor('#aaa');
                doc.text(`Page ${i} of ${total}`, pageWidth/2, pageHeight-5, { align: 'center' });
                doc.text(inspection.id, margin, pageHeight-5);
                doc.text(Utils.formatDate(inspection.dateTime), pageWidth-margin, pageHeight-5, { align: 'right' });
            }
            
            doc.save(`EcoMaintenance_Report_${inspection.id}.pdf`);
            Toast.success('Professional report generated');
        } catch (e) { 
            console.error('Report error:', e); 
            Toast.error('Failed to generate report'); 
        }
    }
    
