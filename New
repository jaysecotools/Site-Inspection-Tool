<script>
// ================================================================
// UTILITY
// ================================================================
const Utils = {
    uuid() {
        return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => {
            const r = Math.random() * 16 | 0;
            return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);
        });
    },
    
    escapeHtml(str) {
        if (!str) return '';
        const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' };
        return str.replace(/[&<>"']/g, m => map[m]);
    },
    
    sanitizeText(str) {
        if (!str) return '';
        return str.replace(/[^\w\s.,!?()'"]/g, '').trim();
    },
    
    formatDate(isoStr) {
        if (!isoStr) return '—';
        try {
            const d = new Date(isoStr);
            return d.toLocaleDateString('en-AU', { 
                year: 'numeric', month: 'short', day: 'numeric',
                hour: '2-digit', minute: '2-digit'
            });
        } catch { return isoStr; }
    },
    
    truncate(str, len = 40) {
        if (!str) return '';
        return str.length > len ? str.slice(0, len) + '…' : str;
    },
    
    clamp(val, min, max) { return Math.max(min, Math.min(max, val)); },
    round(val, d = 1) { return Number(val.toFixed(d)); },
    
    // Improved image compression with EXIF orientation handling
    compressImage(dataURL, maxWidth = 800, maxHeight = 800, quality = 0.85) {
        return new Promise((resolve) => {
            const img = new Image();
            img.onload = () => {
                const canvas = document.createElement('canvas');
                let w = img.width, h = img.height;
                
                // Maintain aspect ratio while fitting within max dimensions
                if (w > maxWidth) { h = (h * maxWidth) / w; w = maxWidth; }
                if (h > maxHeight) { w = (w * maxHeight) / h; h = maxHeight; }
                
                canvas.width = Math.round(w);
                canvas.height = Math.round(h);
                const ctx = canvas.getContext('2d');
                ctx.imageSmoothingEnabled = true;
                ctx.imageSmoothingQuality = 'high';
                ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
                resolve(canvas.toDataURL('image/jpeg', quality));
            };
            img.onerror = () => resolve(dataURL);
            img.src = dataURL;
        });
    },
    
    // Get file size in human-readable format
    formatFileSize(bytes) {
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
        return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
    },
    
    calculateScore(data) {
        const vh = parseFloat(data.vegHealth || 6);
        const sr = parseFloat(data.speciesRichness || 5);
        const wc = parseFloat(data.weedCover || 30);
        const hq = parseFloat(data.habitatQuality || 5);
        const dist = parseFloat(data.disturbance || 3);
        const regen = parseFloat(data.regeneration || 5);
        
        const score = Utils.clamp(
            (vh * 0.25) + (sr * 0.2) + ((100 - wc) / 10 * 0.2) + 
            (hq * 0.15) + ((10 - dist) * 0.1) + (regen * 0.1),
            0, 10
        );
        
        let riskRating, priority, colour, icon;
        if (score < 3) { riskRating = 'Critical'; priority = 'Immediate Intervention'; colour = '#dc2626'; icon = 'fa-exclamation-triangle'; }
        else if (score < 5) { riskRating = 'High Risk'; priority = 'Urgent Management'; colour = '#f59e0b'; icon = 'fa-exclamation-circle'; }
        else if (score < 7) { riskRating = 'Medium Risk'; priority = 'Short-term Plan'; colour = '#f59e0b'; icon = 'fa-minus-circle'; }
        else if (score < 8.5) { riskRating = 'Low Risk'; priority = 'Regular Monitoring'; colour = '#3b82f6'; icon = 'fa-check-circle'; }
        else { riskRating = 'Excellent'; priority = 'Maintenance Only'; colour = '#10b981'; icon = 'fa-star'; }
        
        return {
            conditionScore: Utils.round(score, 1),
            riskRating, priority, colour, icon,
            significance: score > 7 ? 'High Conservation Value' : (score > 5 ? 'Moderate Conservation Value' : 'Low Conservation Value')
        };
    },
    
    getRatingClass(score) {
        if (score >= 8) return 'excellent';
        if (score >= 6.5) return 'good';
        if (score >= 4.5) return 'moderate';
        return 'poor';
    },
    
    getVegetationTypes() {
        return ['Dry Eucalypt Forest', 'Wet Eucalypt Forest', 'Rainforest', 'Moorland', 
                'Grassland', 'Coastal Heath', 'Saltmarsh', 'Alpine Vegetation', 
                'Riparian Forest', 'Plantation', 'Mixed Forest', 'Woodland'];
    },
    
    getThreatLevels() { return ['Low', 'Medium', 'High', 'Critical']; },
    getFeralOptions() { return ['Nil', 'Low', 'Medium', 'High']; }
};

// ================================================================
// TOAST
// ================================================================
const Toast = {
    show(msg, type = 'info', duration = 3000) {
        const container = document.getElementById('toastContainer');
        const toast = document.createElement('div');
        const icons = { 
            success: 'fa-check-circle', 
            warning: 'fa-exclamation-triangle', 
            error: 'fa-times-circle', 
            info: 'fa-info-circle' 
        };
        toast.className = `toast ${type}`;
        toast.innerHTML = `<i class="fas ${icons[type] || icons.info}"></i> ${Utils.escapeHtml(msg)}`;
        container.appendChild(toast);
        setTimeout(() => { if (toast.parentNode) toast.remove(); }, duration);
    },
    success(msg) { this.show(msg, 'success'); },
    warning(msg) { this.show(msg, 'warning'); },
    error(msg) { this.show(msg, 'error'); },
    info(msg) { this.show(msg, 'info'); }
};

// ================================================================
// DATABASE
// ================================================================
class Database {
    constructor() {
        this.data = { inspections: [], drafts: [] };
        this.ready = true;
        this._loadFromStorage();
    }
    
    _loadFromStorage() {
        try {
            const saved = localStorage.getItem('EcoMaintenanceData');
            if (saved) {
                const parsed = JSON.parse(saved);
                this.data = parsed;
            }
        } catch (e) {}
    }
    
    _saveToStorage() {
        try {
            localStorage.setItem('EcoMaintenanceData', JSON.stringify(this.data));
        } catch (e) {}
    }
    
    async save(item, isDraft = false) {
        const store = isDraft ? 'drafts' : 'inspections';
        const existing = this.data[store].findIndex(i => i.id === item.id);
        if (existing >= 0) {
            this.data[store][existing] = item;
        } else {
            this.data[store].push(item);
        }
        this._saveToStorage();
        return item;
    }
    
    async getAll(store = 'inspections') {
        return this.data[store] || [];
    }
    
    async get(id, isDraft = false) {
        const store = isDraft ? 'drafts' : 'inspections';
        return this.data[store].find(i => i.id === id) || null;
    }
    
    async delete(id, isDraft = false) {
        const store = isDraft ? 'drafts' : 'inspections';
        this.data[store] = this.data[store].filter(i => i.id !== id);
        this._saveToStorage();
    }
    
    async count(store = 'inspections') {
        return (this.data[store] || []).length;
    }
    
    async clear(store = 'inspections') {
        this.data[store] = [];
        this._saveToStorage();
    }
    
    async search(query, store = 'inspections') {
        const items = await this.getAll(store);
        if (!query) return items;
        const q = query.toLowerCase();
        return items.filter(i => 
            (i.siteName && i.siteName.toLowerCase().includes(q)) ||
            (i.inspector && i.inspector.toLowerCase().includes(q)) ||
            (i.vegetationType && i.vegetationType.toLowerCase().includes(q))
        );
    }
}

// ================================================================
// MAIN APP
// ================================================================
class App {
    constructor() {
        this.db = new Database();
        this.map = null;
        this.drawnItems = null;
        this.currentId = null;
        this.currentPhotos = [];
        this.isDraft = false;
        this.currentLat = -42.8806;
        this.currentLng = 147.3250;
        this.polygonCount = 0;
        this.waypointCount = 0;
        this.measureMode = false;
        this.measurePoints = [];
        this.measureLine = null;
        this.measureMarkers = [];
        this.gpsMarker = null;
        this.initialized = false;
        this.layers = { base: null, satellite: null, topo: null };
        this.activeLayer = 'streets';
        this.charts = {};
        this.reportTemplates = ['Standard', 'Executive', 'Technical'];
    }
    
    // ================================================================
    // INIT
    // ================================================================
    init() {
        if (this.initialized) return;
        this.initMap();
        this.initGPS();
        this.updateStatus();
        this.bindEvents();
        this.showDashboard();
        this.initialized = true;
        Toast.success('EcoMaintenance Professional Ready');
    }
    
    // ================================================================
    // MAP
    // ================================================================
    initMap() {
        this.map = L.map('map', { center: [-42.8806, 147.3250], zoom: 10, zoomControl: false });
        
        this.layers.base = L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
        }).addTo(this.map);
        
        this.layers.satellite = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
            attribution: '&copy; <a href="https://www.esri.com">Esri</a>'
        });
        
        this.layers.topo = L.tileLayer('https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; <a href="https://opentopomap.org">OpenTopoMap</a>'
        });
        
        L.control.zoom({ position: 'bottomright' }).addTo(this.map);
        
        this.drawnItems = L.featureGroup().addTo(this.map);
        
        const drawControl = new L.Control.Draw({
            position: 'topleft',
            draw: {
                polygon: { shapeOptions: { color: '#1a5f4a', weight: 3, opacity: 0.7 }, showArea: true },
                rectangle: { shapeOptions: { color: '#1a5f4a', weight: 3 } },
                marker: true,
                circle: false,
                polyline: false
            },
            edit: { featureGroup: this.drawnItems, remove: true }
        });
        this.map.addControl(drawControl);
        
        this.map.on(L.Draw.Event.CREATED, (e) => {
            const layer = e.layer;
            if (e.layerType === 'polygon' || e.layerType === 'rectangle') {
                this.polygonCount++;
                document.getElementById('polygonCount').textContent = this.polygonCount;
                try {
                    const area = turf.area(layer.toGeoJSON()) / 10000;
                    Toast.success(`Polygon: ${area.toFixed(2)} ha`);
                } catch {}
            } else if (e.layerType === 'marker') {
                this.waypointCount++;
                document.getElementById('waypointCount').textContent = this.waypointCount;
                Toast.success(`Waypoint ${this.waypointCount}`);
            }
            this.drawnItems.addLayer(layer);
        });
        
        this.map.on('click', (e) => {
            this.currentLat = e.latlng.lat;
            this.currentLng = e.latlng.lng;
        });
        
        document.getElementById('polygonCount').textContent = '0';
        document.getElementById('waypointCount').textContent = '0';
    }
    
    switchLayer(name) {
        Object.values(this.layers).forEach(l => { 
            if (l && this.map.hasLayer(l)) this.map.removeLayer(l); 
        });
        this.activeLayer = name;
        const layer = this.layers[name];
        if (layer) {
            layer.addTo(this.map);
            document.querySelectorAll('.layer-item').forEach(el => {
                el.classList.toggle('active', el.dataset.layer === name);
            });
        }
    }
    
    locateUser() {
        if (!navigator.geolocation) { Toast.warning('Geolocation not supported'); return; }
        navigator.geolocation.getCurrentPosition(
            pos => { 
                this.map.setView([pos.coords.latitude, pos.coords.longitude], 16); 
                Toast.success('Location found');
                this.currentLat = pos.coords.latitude;
                this.currentLng = pos.coords.longitude;
            },
            () => Toast.warning('Location unavailable'),
            { enableHighAccuracy: true, timeout: 10000 }
        );
    }
    
    initGPS() {
        if (!navigator.geolocation) { 
            document.getElementById('gpsStatus').textContent = 'Unavailable'; 
            return; 
        }
        navigator.geolocation.watchPosition(
            pos => {
                this.currentLat = pos.coords.latitude;
                this.currentLng = pos.coords.longitude;
                document.getElementById('gpsStatus').textContent = `±${Math.round(pos.coords.accuracy)}m`;
                if (!this.gpsMarker) {
                    this.gpsMarker = L.marker([this.currentLat, this.currentLng], {
                        icon: L.divIcon({
                            html: '<div style="background:#dc2626;width:12px;height:12px;border-radius:50%;border:2px solid white;box-shadow:0 0 0 4px rgba(220,38,38,0.3);animation:pulse 2s infinite;"></div>',
                            iconSize: [12, 12],
                            className: 'gps-marker'
                        }),
                        zIndexOffset: 1000
                    }).addTo(this.map);
                    // Add pulse animation
                    const style = document.createElement('style');
                    style.textContent = `
                        @keyframes pulse {
                            0% { box-shadow: 0 0 0 0 rgba(220,38,38,0.4); }
                            70% { box-shadow: 0 0 0 10px rgba(220,38,38,0); }
                            100% { box-shadow: 0 0 0 0 rgba(220,38,38,0); }
                        }
                    `;
                    document.head.appendChild(style);
                } else {
                    this.gpsMarker.setLatLng([this.currentLat, this.currentLng]);
                }
            },
            () => document.getElementById('gpsStatus').textContent = 'Error',
            { enableHighAccuracy: true }
        );
    }
    
    startMeasure() {
        if (this.measureMode) { this.stopMeasure(); return; }
        this.measureMode = true;
        this.measurePoints = [];
        Toast.info('Measure ON - Click two points on map');
        
        const handler = (e) => {
            if (!this.measureMode) return;
            const latlng = e.latlng;
            this.measurePoints.push(latlng);
            
            const marker = L.marker(latlng, {
                icon: L.divIcon({
                    html: `<div style="background:#f59e0b;color:white;border-radius:50%;width:20px;height:20px;display:flex;align-items:center;justify-content:center;font-weight:bold;border:2px solid white;font-size:9px;box-shadow:0 2px 8px rgba(0,0,0,0.2);">${this.measurePoints.length}</div>`,
                    iconSize: [20, 20]
                })
            }).addTo(this.map);
            this.measureMarkers.push(marker);
            
            if (this.measurePoints.length === 2) {
                const p1 = this.measurePoints[0], p2 = this.measurePoints[1];
                const R = 6371;
                const dLat = (p2.lat - p1.lat) * Math.PI / 180;
                const dLon = (p2.lng - p1.lng) * Math.PI / 180;
                const a = Math.sin(dLat/2)**2 + Math.cos(p1.lat * Math.PI/180) * Math.cos(p2.lat * Math.PI/180) * Math.sin(dLon/2)**2;
                const dist = R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
                const distStr = dist >= 1 ? `${dist.toFixed(2)} km` : `${(dist * 1000).toFixed(0)} m`;
                
                if (this.measureLine) this.map.removeLayer(this.measureLine);
                this.measureLine = L.polyline(this.measurePoints, { 
                    color: '#f59e0b', 
                    weight: 4, 
                    dashArray: '8,6',
                    opacity: 0.8
                }).addTo(this.map);
                
                const mid = L.latLng((p1.lat+p2.lat)/2, (p1.lng+p2.lng)/2);
                const label = L.divIcon({
                    html: `<div style="background:#1a5f4a;color:white;padding:3px 10px;border-radius:20px;font-size:10px;font-weight:bold;box-shadow:0 2px 8px rgba(0,0,0,0.2);">📏 ${distStr}</div>`,
                    iconSize: [null, null],
                    className: 'measure-label'
                });
                this.measureMarkers.push(L.marker(mid, { icon: label, interactive: false }).addTo(this.map));
                Toast.success(`Distance: ${distStr}`);
                setTimeout(() => this.stopMeasure(), 2000);
            }
        };
        this.map.on('click', handler);
        this._measureHandler = handler;
        document.getElementById('measureBtn').classList.add('active');
    }
    
    stopMeasure() {
        this.measureMode = false;
        if (this._measureHandler) { this.map.off('click', this._measureHandler); this._measureHandler = null; }
        if (this.measureLine) { this.map.removeLayer(this.measureLine); this.measureLine = null; }
        this.measureMarkers.forEach(m => this.map.removeLayer(m));
        this.measureMarkers = [];
        this.measurePoints = [];
        document.getElementById('measureBtn').classList.remove('active');
    }
    
    clearMap() {
        this.drawnItems.clearLayers();
        this.polygonCount = 0;
        this.waypointCount = 0;
        document.getElementById('polygonCount').textContent = '0';
        document.getElementById('waypointCount').textContent = '0';
        Toast.info('Map cleared');
    }
    
    resetView() { this.map.setView([-42.8806, 147.3250], 10); }
    toggleFullscreen() {
        const el = document.getElementById('mapWrapper');
        if (!document.fullscreenElement) { 
            el.requestFullscreen?.(); 
        } else { 
            document.exitFullscreen?.(); 
        }
    }
    
    getGeometry() {
        const features = [];
        this.drawnItems.eachLayer(l => { 
            try { features.push(l.toGeoJSON()); } catch(e) {} 
        });
        return features;
    }
    
    getWaypoints() {
        const wps = [];
        this.drawnItems.eachLayer(l => {
            if (l instanceof L.Marker && l !== this.gpsMarker) {
                const ll = l.getLatLng();
                wps.push({ id: Utils.uuid(), lat: ll.lat, lng: ll.lng, label: `WP${wps.length+1}` });
            }
        });
        return wps;
    }
    
    loadGeometry(geojson) {
        if (!geojson || !geojson.length) return;
        geojson.forEach(g => {
            try {
                const layer = L.geoJSON(g, {
                    style: { color: '#1a5f4a', weight: 3, opacity: 0.7 }
                });
                this.drawnItems.addLayer(layer);
                if (g.geometry?.type === 'Polygon' || g.geometry?.type === 'MultiPolygon') this.polygonCount++;
                else if (g.geometry?.type === 'Point') this.waypointCount++;
            } catch(e) {}
        });
        document.getElementById('polygonCount').textContent = this.polygonCount;
        document.getElementById('waypointCount').textContent = this.waypointCount;
    }
    
