// ================================================================
// REPORT GENERATION - THE REAL FIX
// ================================================================
async generateReport(inspection) {
    if (this.isGenerating) {
        Toast.warning('Report generation already in progress');
        return;
    }
    
    this.isGenerating = true;
    const finalBtn = document.getElementById('finaliseBtn');
    if (finalBtn) {
        finalBtn.disabled = true;
        finalBtn.innerHTML = '<span class="spinner"></span> Generating...';
    }
    
    try {
        const { jsPDF } = window.jspdf;
        const doc = new jsPDF('p', 'mm', 'a4');
        const pageWidth = 210;
        const pageHeight = 297;
        const margin = 18;
        const contentWidth = pageWidth - 2 * margin;
        let y = margin;
        
        const eco = inspection.ecologicalScore || Utils.calculateScore(inspection);
        const colour = '#1a5f4a';
        
        // ULTRA SIMPLE CLEAN - just remove non-printable and normalize spaces
        const simpleClean = (text) => {
            if (!text) return '';
            let s = String(text);
            // Remove ALL non-printable characters EXCEPT space (32)
            s = s.replace(/[\x00-\x1F\x7F-\x9F]/g, '');
            // Remove zero-width spaces and other invisible Unicode
            s = s.replace(/[\u200B-\u200D\uFEFF]/g, '');
            // Decode common HTML entities
            s = s.replace(/&amp;/g, '&')
                 .replace(/&lt;/g, '<')
                 .replace(/&gt;/g, '>')
                 .replace(/&quot;/g, '"')
                 .replace(/&#039;/g, "'")
                 .replace(/&nbsp;/g, ' ');
            // Remove any remaining HTML tags
            s = s.replace(/<[^>]*>/g, '');
            // Normalize spaces (but keep single spaces between words)
            s = s.replace(/\s{2,}/g, ' ');
            return s.trim();
        };
        
        // CRITICAL FIX: This function completely rebuilds the string to remove hidden characters
        const rebuildString = (text) => {
            if (!text) return '';
            let s = String(text);
            // First, decode HTML entities
            s = s.replace(/&amp;/g, '&')
                 .replace(/&lt;/g, '<')
                 .replace(/&gt;/g, '>')
                 .replace(/&quot;/g, '"')
                 .replace(/&#039;/g, "'")
                 .replace(/&nbsp;/g, ' ')
                 .replace(/&#x2F;/g, '/')
                 .replace(/&#x27;/g, "'")
                 .replace(/&#x60;/g, '`')
                 .replace(/&#x3D;/g, '=')
                 .replace(/&#x2D;/g, '-');
            
            // Remove HTML tags
            s = s.replace(/<[^>]*>/g, '');
            
            // CRITICAL: Remove ALL non-ASCII characters and rebuild
            // This strips out zero-width spaces, smart quotes, etc.
            let result = '';
            for (let i = 0; i < s.length; i++) {
                const char = s[i];
                const code = char.charCodeAt(0);
                // Keep only printable ASCII characters (space through ~)
                if (code === 32 || (code >= 33 && code <= 126)) {
                    result += char;
                } else {
                    // Replace with space
                    result += ' ';
                }
            }
            
            // Normalize spaces
            result = result.replace(/\s{2,}/g, ' ');
            return result.trim();
        };
        
        // The label we know should work - direct string with no processing
        const getChecklistLabel = (index) => {
            const labels = [
                'Verified site location and boundaries',
                'Assessed accessibility and entry points',
                'Evaluated site conditions',
                'Identified existing infrastructure or features',
                'Assessed presence of protected flora or fauna',
                'Evaluated potential environmental impacts',
                'Verified compliance with environmental regulations',
                'Noted areas of conservation significance',
                'Observed and evaluated work practices',
                'Assessed compliance with health and safety regulations',
                'Identified potential risks and hazards',
                'Reviewed implementation of control measures',
                'Inspected equipment and machinery',
                'Ensured equipment in safe working condition',
                'Checked maintenance and service records',
                'Verified compliance with industry standards'
            ];
            return labels[index] || '';
        };
        
        const getChecklistValue = (index) => {
            const values = [
                inspection.siteLocation,
                inspection.accessibility,
                inspection.siteConditions,
                inspection.infrastructure,
                inspection.protectedSpecies,
                inspection.environmentalImpacts,
                inspection.compliance,
                inspection.conservation,
                inspection.workPractices,
                inspection.healthSafety,
                inspection.risksHazards,
                inspection.controlMeasures,
                inspection.equipmentInspected,
                inspection.safeCondition,
                inspection.maintenanceRecords,
                inspection.industryStandards
            ];
            return values[index] || false;
        };
        
        // Add text with wrapping
        const addText = (text, fontSize = 10, color = '#000000') => {
            if (!text) return;
            const cleaned = simpleClean(text);
            if (!cleaned) return;
            
            doc.setFontSize(fontSize);
            doc.setTextColor(color);
            
            const lines = doc.splitTextToSize(cleaned, contentWidth);
            const lineHeight = fontSize * 0.45;
            
            const neededHeight = lines.length * lineHeight;
            if (y + neededHeight > pageHeight - margin - 10) {
                doc.addPage();
                y = margin + 5;
                addFooter();
            }
            
            doc.text(lines, margin, y);
            y += neededHeight + 2;
        };
        
        // Add title
        const addTitle = (text, fontSize = 18, color = colour) => {
            const cleaned = simpleClean(text);
            if (!cleaned) return;
            
            if (y > pageHeight - 30) {
                doc.addPage();
                y = margin + 5;
                addFooter();
            }
            
            doc.setFontSize(fontSize);
            doc.setTextColor(color);
            doc.text(cleaned, margin, y);
            y += fontSize * 0.4 + 2;
        };
        
        // Draw line
        const drawLine = () => {
            if (y > pageHeight - 15) {
                doc.addPage();
                y = margin + 5;
                addFooter();
            }
            doc.setDrawColor(colour);
            doc.setLineWidth(0.5);
            doc.line(margin, y, pageWidth - margin, y);
            y += 5;
        };
        
        // Add footer
        const addFooter = () => {
            doc.setDrawColor(colour);
            doc.setLineWidth(0.3);
            doc.line(margin, pageHeight - 12, pageWidth - margin, pageHeight - 12);
            doc.setFontSize(7);
            doc.setTextColor('#aaa');
            const id = simpleClean(inspection.id || 'N/A');
            doc.text(id, margin, pageHeight - 5);
            const date = Utils.formatDate(inspection.dateTime);
            doc.text(date, pageWidth - margin, pageHeight - 5, { align: 'right' });
            const pageNum = doc.internal.getCurrentPageInfo().pageNumber;
            doc.text(`Page ${pageNum}`, pageWidth/2, pageHeight - 5, { align: 'center' });
        };
        
        // ============================================================
        // COVER PAGE
        // ============================================================
        doc.setFillColor(colour);
        doc.rect(0, 0, pageWidth, 6, 'F');
        y = 30;
        
        doc.setFontSize(32);
        doc.setTextColor(colour);
        doc.text('ENVIRONMENTAL', margin, y);
        y += 14;
        doc.text('ASSESSMENT REPORT', margin, y);
        y += 12;
        drawLine();
        y += 6;
        
        doc.setFontSize(20);
        doc.setTextColor('#000000');
        const siteName = simpleClean(inspection.siteName || 'Site Assessment');
        doc.text(siteName, margin, y);
        y += 12;
        
        doc.setFontSize(11);
        doc.setTextColor('#000000');
        const org = simpleClean(inspection.organization || 'Environmental Client');
        doc.text(`Prepared for: ${org}`, margin, y);
        y += 6;
        const date = Utils.formatDate(inspection.dateTime);
        doc.text(`Date: ${date}`, margin, y);
        y += 6;
        const id = simpleClean(inspection.id || 'N/A');
        doc.text(`Report ID: ${id}`, margin, y);
        y += 6;
        const author = simpleClean(inspection.inspector || 'Environmental Consultant');
        doc.text(`Author: ${author}`, margin, y);
        y += 10;
        
        // Cover photo
        if (inspection.photos && inspection.photos.length > 0) {
            const hero = inspection.photos.find(p => p.isHero) || inspection.photos[0];
            try {
                const img = new Image();
                const imgData = await new Promise((resolve) => {
                    img.onload = () => resolve({ width: img.width, height: img.height });
                    img.onerror = () => resolve(null);
                    img.src = hero.dataURL;
                });
                
                if (imgData) {
                    const maxImgWidth = contentWidth - 20;
                    const maxImgHeight = 70;
                    let imgWidth = maxImgWidth;
                    let imgHeight = (imgData.height / imgData.width) * maxImgWidth;
                    if (imgHeight > maxImgHeight) {
                        imgHeight = maxImgHeight;
                        imgWidth = (imgData.width / imgData.height) * maxImgHeight;
                    }
                    const xOffset = margin + 10 + (maxImgWidth - imgWidth) / 2;
                    doc.addImage(hero.dataURL, 'JPEG', xOffset, y, imgWidth, imgHeight);
                    y += imgHeight + 8;
                    doc.setFontSize(7);
                    doc.setTextColor('#999');
                    const caption = simpleClean(inspection.siteName || 'Site Photo');
                    doc.text(`Cover Photo: ${caption}`, margin + 10, y);
                    y += 6;
                }
            } catch (e) {}
        }
        
        doc.setFillColor(colour);
        doc.rect(0, pageHeight - 6, pageWidth, 3, 'F');
        doc.setFontSize(7);
        doc.setTextColor('#999');
        doc.text('© EcoMaintenance Professional v4.0', margin, pageHeight - 3);
        doc.text('Environmental Assessment Report', pageWidth / 2, pageHeight - 3, { align: 'center' });
        doc.text('Page 1', pageWidth - margin, pageHeight - 3, { align: 'right' });
        
        // ============================================================
        // EXECUTIVE SUMMARY
        // ============================================================
        doc.addPage();
        y = margin + 5;
        addFooter();
        addTitle('EXECUTIVE SUMMARY', 22);
        drawLine();
        y += 4;
        
        doc.setFontSize(14);
        doc.setTextColor(colour);
        doc.text(`Overall Condition Score: ${eco.conditionScore}/10`, margin, y);
        y += 8;
        
        doc.setFontSize(11);
        doc.setTextColor(eco.colour);
        doc.text(`Risk Rating: ${eco.riskRating}`, margin, y);
        y += 6;
        doc.setTextColor('#000000');
        doc.text(`Management Priority: ${eco.priority}`, margin, y);
        y += 6;
        doc.text(`Conservation Significance: ${eco.significance}`, margin, y);
        y += 10;
        
        addText(`This report presents findings of an ecological assessment at "${simpleClean(inspection.siteName)}" conducted on ${Utils.formatDate(inspection.dateTime)}.`, 10);
        y += 4;
        
        doc.setFontSize(11);
        doc.setTextColor(colour);
        doc.text('Key Findings:', margin, y);
        y += 5;
        doc.setFontSize(9);
        doc.setTextColor('#000000');
        const findings = [
            `Vegetation Health: ${inspection.vegHealth || 6}/10`,
            `Species Richness: ${inspection.speciesRichness || 5} species recorded`,
            `Weed Cover: ${inspection.weedCover || 30}%`,
            `Habitat Quality: ${inspection.habitatQuality || 5}/10`,
            `Disturbance Level: ${inspection.disturbance || 3}/10`
        ];
        findings.forEach(f => {
            doc.text(`• ${f}`, margin + 4, y);
            y += 5;
        });
        y += 6;
        
        // ============================================================
        // CHECKLIST SUMMARY - COMPLETELY REBUILT WITH CLEAN STRINGS
        // ============================================================
        if (y > pageHeight - 60) {
            doc.addPage();
            y = margin + 5;
            addFooter();
        }
        addTitle('CHECKLIST SUMMARY', 16);
        drawLine();
        y += 4;
        
        // Define checklist sections and items
        const sections = [
            'General Site Conditions',
            'Environmental Considerations',
            'Work Practices and Procedures',
            'Equipment and Machinery'
        ];
        
        // Items per section (4 items each)
        const itemsPerSection = 4;
        let totalItems = 16;
        let completedItems = 0;
        
        // First pass: count completed items
        for (let i = 0; i < totalItems; i++) {
            if (getChecklistValue(i) === true || getChecklistValue(i) === 'true' || getChecklistValue(i) === 1) {
                completedItems++;
            }
        }
        
        doc.setFontSize(9);
        doc.setTextColor('#000000');
        doc.text(`Completion: ${completedItems}/${totalItems} items (${Math.round((completedItems/totalItems)*100)}%)`, margin, y);
        y += 6;
        
        // Render checklist with clean labels
        let currentSection = '';
        for (let i = 0; i < totalItems; i++) {
            if (y > pageHeight - 25) {
                doc.addPage();
                y = margin + 5;
                addFooter();
                doc.setFontSize(9);
                doc.setTextColor('#000000');
                doc.text(`Completion: ${completedItems}/${totalItems} items (${Math.round((completedItems/totalItems)*100)}%)`, margin, y);
                y += 6;
            }
            
            const sectionIndex = Math.floor(i / itemsPerSection);
            const sectionName = sections[sectionIndex] || '';
            
            if (sectionName !== currentSection) {
                currentSection = sectionName;
                doc.setFontSize(11);
                doc.setTextColor(colour);
                doc.text(currentSection, margin, y);
                y += 5;
            }
            
            const isChecked = (getChecklistValue(i) === true || getChecklistValue(i) === 'true' || getChecklistValue(i) === 1);
            const symbol = isChecked ? '✓' : '✗';
            const color = isChecked ? '#10b981' : '#dc2626';
            
            // CRITICAL FIX: Use getChecklistLabel which returns a clean string
            const label = getChecklistLabel(i);
            
            doc.setFontSize(8);
            doc.setTextColor(color);
            // Use a simple string that we know is clean
            doc.text(`${symbol}  ${label}`, margin + 4, y);
            y += 5;
        }
        y += 3;
        
        // ============================================================
        // SITE INFORMATION DETAILS
        // ============================================================
        if (y > pageHeight - 50) {
            doc.addPage();
            y = margin + 5;
            addFooter();
        }
        addTitle('SITE INFORMATION', 16);
        drawLine();
        y += 4;
        
        const siteInfo = [
            ['Site Name:', simpleClean(inspection.siteName || 'Not specified')],
            ['Inspector:', simpleClean(inspection.inspector || 'Not specified')],
            ['Organization:', simpleClean(inspection.organization || 'Not specified')],
            ['Date/Time:', Utils.formatDate(inspection.dateTime)],
            ['Coordinates:', simpleClean(inspection.coords || 'Not recorded')],
            ['Vegetation Type:', simpleClean(inspection.vegetationType || 'Not specified')],
            ['Tenure:', simpleClean(inspection.tenure || 'Not specified')],
            ['Weather:', simpleClean(inspection.weather || 'Not recorded')],
            ['Soil Condition:', simpleClean(inspection.soilCondition || 'Not recorded')]
        ];
        
        siteInfo.forEach(([label, value]) => {
            if (y > pageHeight - 20) {
                doc.addPage();
                y = margin + 5;
                addFooter();
                doc.setFontSize(9);
                doc.setTextColor('#000000');
            }
            
            const fullText = `${label} ${value}`;
            const lines = doc.splitTextToSize(fullText, contentWidth);
            doc.setFontSize(9);
            doc.setTextColor('#000000');
            doc.text(lines, margin, y);
            y += (lines.length * 4.5) + 2;
        });
        y += 3;
        
        // ============================================================
        // SPECIES AND THREATS
        // ============================================================
        if (y > pageHeight - 50) {
            doc.addPage();
            y = margin + 5;
            addFooter();
        }
        addTitle('SPECIES AND THREATS', 16);
        drawLine();
        y += 4;
        
        const threats = [
            ['Declared Weeds Present:', simpleClean(inspection.weedsList || 'None recorded')],
            ['Feral Animals:', simpleClean(inspection.feralAnimals || 'Not assessed')],
            ['Fire History:', simpleClean(inspection.fireHistory || 'Not recorded')],
            ['Overall Threat Level:', simpleClean(inspection.threatLevel || 'Not assessed')]
        ];
        
        threats.forEach(([label, value]) => {
            if (y > pageHeight - 20) {
                doc.addPage();
                y = margin + 5;
                addFooter();
                doc.setFontSize(9);
                doc.setTextColor('#000000');
            }
            const fullText = `${label} ${value}`;
            const lines = doc.splitTextToSize(fullText, contentWidth);
            doc.setFontSize(9);
            doc.setTextColor('#000000');
            doc.text(lines, margin, y);
            y += (lines.length * 4.5) + 2;
        });
        y += 3;
        
        // ============================================================
        // ABORIGINAL HERITAGE
        // ============================================================
        if (y > pageHeight - 50) {
            doc.addPage();
            y = margin + 5;
            addFooter();
        }
        addTitle('ABORIGINAL HERITAGE', 16);
        drawLine();
        y += 4;
        
        doc.setFontSize(10);
        doc.setTextColor('#000000');
        const heritageSig = simpleClean(inspection.heritageSignificance || 'Not Assessed');
        doc.text(`Heritage Significance: ${heritageSig}`, margin, y);
        y += 6;
        
        doc.text('Cultural Sites / Artefacts:', margin, y);
        y += 4;
        const culturalSites = simpleClean(inspection.culturalSites || 'No cultural sites recorded.');
        addText(culturalSites, 9);
        y += 4;
        
        doc.text('Heritage Management Notes:', margin, y);
        y += 4;
        const heritageNotes = simpleClean(inspection.aboriginalHeritage || 'No heritage management notes.');
        addText(heritageNotes, 9);
        y += 6;
        
        // ============================================================
        // OBSERVATIONS
        // ============================================================
        if (y > pageHeight - 40) {
            doc.addPage();
            y = margin + 5;
            addFooter();
        }
        addTitle('OBSERVATIONS', 14);
        drawLine();
        y += 4;
        const observations = simpleClean(inspection.observations || 'No observations recorded.');
        addText(observations, 10);
        y += 4;
        
        // ============================================================
        // RECOMMENDATIONS
        // ============================================================
        if (y > pageHeight - 40) {
            doc.addPage();
            y = margin + 5;
            addFooter();
        }
        addTitle('RECOMMENDATIONS', 14);
        drawLine();
        y += 4;
        const recommendations = simpleClean(inspection.recommendations || 'No specific recommendations recorded.');
        addText(recommendations, 10);
        y += 4;
        
        // ============================================================
        // ECOLOGICAL HEALTH DETAILS
        // ============================================================
        if (y > pageHeight - 50) {
            doc.addPage();
            y = margin + 5;
            addFooter();
        }
        addTitle('ECOLOGICAL HEALTH METRICS', 14);
        drawLine();
        y += 4;
        
        doc.setFontSize(9);
        doc.setTextColor('#000000');
        const metrics = [
            ['Vegetation Health:', `${inspection.vegHealth || 6}/10`],
            ['Species Richness:', `${inspection.speciesRichness || 5}/10`],
            ['Weed Cover:', `${inspection.weedCover || 30}%`],
            ['Habitat Quality:', `${inspection.habitatQuality || 5}/10`],
            ['Disturbance Level:', `${inspection.disturbance || 3}/10`],
            ['Regeneration:', `${inspection.regeneration || 5}/10`],
            ['Overall Score:', `${eco.conditionScore}/10`]
        ];
        
        metrics.forEach(([label, value]) => {
            if (y > pageHeight - 20) {
                doc.addPage();
                y = margin + 5;
                addFooter();
                doc.setFontSize(9);
                doc.setTextColor('#000000');
            }
            const fullText = `${label} ${value}`;
            const lines = doc.splitTextToSize(fullText, contentWidth);
            doc.text(lines, margin, y);
            y += (lines.length * 4.5) + 2;
        });
        y += 3;
        
        // ============================================================
        // CHECKLIST NOTES
        // ============================================================
        const notes = [
            { title: 'Site Conditions Notes:', text: inspection.siteConditionsNotes },
            { title: 'Environmental Notes:', text: inspection.environmentalNotes },
            { title: 'Work Practice Notes:', text: inspection.workPracticesNotes },
            { title: 'Equipment Notes:', text: inspection.equipmentNotes }
        ];
        
        let hasNotes = notes.some(n => n.text);
        if (hasNotes) {
            if (y > pageHeight - 50) {
                doc.addPage();
                y = margin + 5;
                addFooter();
            }
            addTitle('ADDITIONAL NOTES', 14);
            drawLine();
            y += 4;
            
            notes.forEach(note => {
                if (note.text) {
                    doc.setFontSize(10);
                    doc.setTextColor(colour);
                    doc.text(note.title, margin, y);
                    y += 4;
                    doc.setFontSize(9);
                    doc.setTextColor('#000000');
                    addText(note.text, 9);
                    y += 2;
                }
            });
        }
        
        // ============================================================
        // PHOTOS
        // ============================================================
        if (inspection.photos && inspection.photos.length > 0) {
            doc.addPage();
            y = margin + 5;
            addFooter();
            addTitle('PHOTO DOCUMENTATION', 18);
            drawLine();
            y += 6;
            
            const photos = inspection.photos.slice(0, 15);
            const photoSize = 50;
            const gap = 5;
            const maxCols = Math.floor((contentWidth + gap) / (photoSize + gap));
            let row = 0, col = 0;
            
            for (let i = 0; i < photos.length; i++) {
                const p = photos[i];
                const px = margin + col * (photoSize + gap);
                const py = y + row * (photoSize + gap + 8);
                
                if (py + photoSize + 10 > pageHeight - margin - 15) {
                    doc.addPage();
                    y = margin + 5;
                    addFooter();
                    addTitle('PHOTO DOCUMENTATION (continued)', 14);
                    drawLine();
                    y += 6;
                    row = 0;
                    col = 0;
                }
                
                try {
                    const img = new Image();
                    const imgData = await new Promise((resolve) => {
                        img.onload = () => resolve({ width: img.width, height: img.height });
                        img.onerror = () => resolve(null);
                        img.src = p.dataURL;
                    });
                    
                    let imgWidth = photoSize;
                    let imgHeight = photoSize * 0.75;
                    if (imgData) {
                        const aspectRatio = imgData.width / imgData.height;
                        if (aspectRatio > 1) {
                            imgWidth = photoSize;
                            imgHeight = photoSize / aspectRatio;
                        } else {
                            imgHeight = photoSize;
                            imgWidth = photoSize * aspectRatio;
                        }
                    }
                    
                    const xOffset = px + (photoSize - imgWidth) / 2;
                    const yOffset = py + (photoSize * 0.75 - imgHeight) / 2;
                    doc.addImage(p.dataURL, 'JPEG', xOffset, yOffset, imgWidth, imgHeight);
                    doc.setFontSize(6);
                    doc.setTextColor('#666');
                    doc.text(`Photo ${i+1}`, px + 2, py + photoSize * 0.75 + 4);
                } catch (e) {
                    doc.setFillColor('#f0f0f0');
                    doc.roundedRect(px, py, photoSize, photoSize * 0.75, 2, 2, 'F');
                    doc.setFontSize(8);
                    doc.setTextColor('#999');
                    doc.text(`Photo ${i+1}`, px + photoSize/2 - 10, py + photoSize * 0.375);
                }
                
                col++;
                if (col >= maxCols) {
                    col = 0;
                    row++;
                }
            }
        }
        
        // Save the PDF
        const fileName = `EcoMaintenance_Report_${inspection.id || Date.now()}.pdf`;
        doc.save(fileName);
        Toast.success('Professional report generated successfully');
        
    } catch (e) {
        console.error('Report generation error:', e);
        Toast.error('Failed to generate report: ' + e.message);
    } finally {
        this.isGenerating = false;
        if (finalBtn) {
            finalBtn.disabled = false;
            finalBtn.innerHTML = '<i class="fas fa-file-pdf"></i> Generate Report';
        }
    }
}
