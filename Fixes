    async newInspection() {
        this.currentId = Utils.uuid();
        this.currentPhotos = [];
        this.isDraft = false;
        this.clearMap();
        this.setPanel(this.renderForm({ id: this.currentId }), 'New Ecological Assessment');
        this.bindForm();
    }
    
    async loadInspection(id, draft = false) {
        try {
            const data = await this.db.get(id, draft);
            if (!data) { Toast.error('Not found'); return; }
            this.currentId = data.id;
            this.currentPhotos = data.photos || [];
            this.isDraft = draft;
            this.clearMap();
            this.loadGeometry(data.geometry || []);
            (data.waypoints || []).forEach(w => {
                this.drawnItems.addLayer(
                    L.marker([w.lat, w.lng])
                        .bindPopup(`<strong>${Utils.escapeHtml(w.label)}</strong>`)
                );
            });
            this.setPanel(this.renderForm(data), draft ? 'Edit Draft' : 'View Inspection');
            this.bindForm();
            
            const countEl = document.querySelector('.photo-count');
            if (countEl) countEl.textContent = `${this.currentPhotos.length} photos added`;
            
            // Update checklist state from saved data
            this.updateChecklistDisplay();
        } catch (e) { console.error('Load error:', e); Toast.error('Failed to load'); }
    }
    
    async saveDraft() {
        try {
            const data = this.collectForm();
            if (!data.siteName) { Toast.warning('Site name required'); return; }
            data.status = 'draft';
            await this.db.save(data, true);
            this.isDraft = true;
            Toast.success('Draft saved');
            await this.updateStatus();
        } catch (e) { console.error('Save draft error:', e); Toast.error('Failed to save draft'); }
    }
    
    async finalise() {
        if (this.isGenerating) return;
        
        try {
            const data = this.collectForm();
            if (!data.siteName) { Toast.warning('Site name required'); return; }
            data.status = 'finalised';
            data.ecologicalScore = Utils.calculateScore(data);
            await this.db.save(data, false);
            await this.db.delete(data.id, true);
            await this.generateReport(data);
            this.closePanel();
            await this.updateStatus();
            this.showInspections();
        } catch (e) { console.error('Finalise error:', e); Toast.error('Failed to finalise'); }
    }
    
// ================================================================
// REPORT GENERATION - THE REAL FIX FOR & CHARACTERS
// ================================================================
async generateReport(inspection) {
    if (this.isGenerating) {
        Toast.warning('Report generation already in progress');
        return;
    }
    
    this.isGenerating = true;
    const finalBtn = document.getElementById('finaliseBtn');
    if (finalBtn) {
        finalBtn.disabled = true;
        finalBtn.innerHTML = '<span class="spinner"></span> Generating...';
    }
    
    try {
        const { jsPDF } = window.jspdf;
        const doc = new jsPDF('p', 'mm', 'a4');
        const pageWidth = 210;
        const pageHeight = 297;
        const margin = 18;
        const contentWidth = pageWidth - 2 * margin;
        let y = margin;
        
        const eco = inspection.ecologicalScore || Utils.calculateScore(inspection);
        const colour = '#1a5f4a';
        
        // CRITICAL FIX: Remove ALL & characters and HTML entities
        const cleanForPDF = (text) => {
            if (!text) return '';
            let s = String(text);
            
            // First, decode any existing HTML entities to their character equivalents
            s = s.replace(/&amp;/g, '&')
                 .replace(/&lt;/g, '<')
                 .replace(/&gt;/g, '>')
                 .replace(/&quot;/g, '"')
                 .replace(/&#039;/g, "'")
                 .replace(/&nbsp;/g, ' ')
                 .replace(/&#x2F;/g, '/')
                 .replace(/&#x27;/g, "'")
                 .replace(/&#x60;/g, '`')
                 .replace(/&#x3D;/g, '=')
                 .replace(/&#x2D;/g, '-');
            
            // Remove HTML tags
            s = s.replace(/<[^>]*>/g, '');
            
            // CRITICAL: Remove ALL remaining & characters (they cause issues in jsPDF)
            // Replace & with space to prevent HTML entity interpretation
            s = s.replace(/&/g, ' ');
            
            // Remove non-printable characters but KEEP normal spaces
            s = s.replace(/[^\x20-\x7E]/g, '');
            
            // Normalize multiple spaces
            s = s.replace(/\s{2,}/g, ' ').trim();
            
            return s;
        };
        
        // For checklist labels - ensure they're clean
        const cleanLabel = (text) => {
            if (!text) return '';
            let s = String(text);
            
            // Remove ALL & characters (the root cause of the issue)
            s = s.replace(/&/g, ' ');
            
            // Remove any HTML entities that might remain
            s = s.replace(/&[a-zA-Z]+;/g, ' ')
                 .replace(/&#[0-9]+;/g, ' ');
            
            // Remove HTML tags
            s = s.replace(/<[^>]*>/g, '');
            
            // Remove non-printable characters
            s = s.replace(/[^\x20-\x7E]/g, ' ');
            
            // Normalize spaces
            s = s.replace(/\s{2,}/g, ' ').trim();
            
            return s;
        };
        
        // Add text with wrapping
        const addText = (text, fontSize = 10, color = '#000000') => {
            if (!text) return;
            const cleaned = cleanForPDF(text);
            if (!cleaned) return;
            
            doc.setFontSize(fontSize);
            doc.setTextColor(color);
            
            const lines = doc.splitTextToSize(cleaned, contentWidth);
            const lineHeight = fontSize * 0.45;
            
            const neededHeight = lines.length * lineHeight;
            if (y + neededHeight > pageHeight - margin - 10) {
                doc.addPage();
                y = margin + 5;
                addFooter();
            }
            
            doc.text(lines, margin, y);
            y += neededHeight + 2;
        };
        
        // Add title
        const addTitle = (text, fontSize = 18, color = colour) => {
            const cleaned = cleanForPDF(text);
            if (!cleaned) return;
            
            if (y > pageHeight - 30) {
                doc.addPage();
                y = margin + 5;
                addFooter();
            }
            
            doc.setFontSize(fontSize);
            doc.setTextColor(color);
            doc.text(cleaned, margin, y);
            y += fontSize * 0.4 + 2;
        };
        
        // Draw line
        const drawLine = () => {
            if (y > pageHeight - 15) {
                doc.addPage();
                y = margin + 5;
                addFooter();
            }
            doc.setDrawColor(colour);
            doc.setLineWidth(0.5);
            doc.line(margin, y, pageWidth - margin, y);
            y += 5;
        };
        
        // Add footer
        const addFooter = () => {
            doc.setDrawColor(colour);
            doc.setLineWidth(0.3);
            doc.line(margin, pageHeight - 12, pageWidth - margin, pageHeight - 12);
            doc.setFontSize(7);
            doc.setTextColor('#aaa');
            const id = cleanForPDF(inspection.id || 'N/A');
            doc.text(id, margin, pageHeight - 5);
            const date = Utils.formatDate(inspection.dateTime);
            doc.text(date, pageWidth - margin, pageHeight - 5, { align: 'right' });
            const pageNum = doc.internal.getCurrentPageInfo().pageNumber;
            doc.text(`Page ${pageNum}`, pageWidth/2, pageHeight - 5, { align: 'center' });
        };
        
        // ============================================================
        // COVER PAGE
        // ============================================================
        doc.setFillColor(colour);
        doc.rect(0, 0, pageWidth, 6, 'F');
        y = 30;
        
        doc.setFontSize(32);
        doc.setTextColor(colour);
        doc.text('ENVIRONMENTAL', margin, y);
        y += 14;
        doc.text('ASSESSMENT REPORT', margin, y);
        y += 12;
        drawLine();
        y += 6;
        
        doc.setFontSize(20);
        doc.setTextColor('#000000');
        const siteName = cleanForPDF(inspection.siteName || 'Site Assessment');
        doc.text(siteName, margin, y);
        y += 12;
        
        doc.setFontSize(11);
        doc.setTextColor('#000000');
        const org = cleanForPDF(inspection.organization || 'Environmental Client');
        doc.text(`Prepared for: ${org}`, margin, y);
        y += 6;
        const date = Utils.formatDate(inspection.dateTime);
        doc.text(`Date: ${date}`, margin, y);
        y += 6;
        const id = cleanForPDF(inspection.id || 'N/A');
        doc.text(`Report ID: ${id}`, margin, y);
        y += 6;
        const author = cleanForPDF(inspection.inspector || 'Environmental Consultant');
        doc.text(`Author: ${author}`, margin, y);
        y += 10;
        
        // Cover photo
        if (inspection.photos && inspection.photos.length > 0) {
            const hero = inspection.photos.find(p => p.isHero) || inspection.photos[0];
            try {
                const img = new Image();
                const imgData = await new Promise((resolve) => {
                    img.onload = () => resolve({ width: img.width, height: img.height });
                    img.onerror = () => resolve(null);
                    img.src = hero.dataURL;
                });
                
                if (imgData) {
                    const maxImgWidth = contentWidth - 20;
                    const maxImgHeight = 70;
                    let imgWidth = maxImgWidth;
                    let imgHeight = (imgData.height / imgData.width) * maxImgWidth;
                    if (imgHeight > maxImgHeight) {
                        imgHeight = maxImgHeight;
                        imgWidth = (imgData.width / imgData.height) * maxImgHeight;
                    }
                    const xOffset = margin + 10 + (maxImgWidth - imgWidth) / 2;
                    doc.addImage(hero.dataURL, 'JPEG', xOffset, y, imgWidth, imgHeight);
                    y += imgHeight + 8;
                    doc.setFontSize(7);
                    doc.setTextColor('#999');
                    const caption = cleanForPDF(inspection.siteName || 'Site Photo');
                    doc.text(`Cover Photo: ${caption}`, margin + 10, y);
                    y += 6;
                }
            } catch (e) {}
        }
        
        doc.setFillColor(colour);
        doc.rect(0, pageHeight - 6, pageWidth, 3, 'F');
        doc.setFontSize(7);
        doc.setTextColor('#999');
        doc.text('© EcoMaintenance Professional v4.0', margin, pageHeight - 3);
        doc.text('Environmental Assessment Report', pageWidth / 2, pageHeight - 3, { align: 'center' });
        doc.text('Page 1', pageWidth - margin, pageHeight - 3, { align: 'right' });
        
        // ============================================================
        // EXECUTIVE SUMMARY
        // ============================================================
        doc.addPage();
        y = margin + 5;
        addFooter();
        addTitle('EXECUTIVE SUMMARY', 22);
        drawLine();
        y += 4;
        
        doc.setFontSize(14);
        doc.setTextColor(colour);
        doc.text(`Overall Condition Score: ${eco.conditionScore}/10`, margin, y);
        y += 8;
        
        doc.setFontSize(11);
        doc.setTextColor(eco.colour);
        doc.text(`Risk Rating: ${eco.riskRating}`, margin, y);
        y += 6;
        doc.setTextColor('#000000');
        doc.text(`Management Priority: ${eco.priority}`, margin, y);
        y += 6;
        doc.text(`Conservation Significance: ${eco.significance}`, margin, y);
        y += 10;
        
        addText(`This report presents findings of an ecological assessment at "${cleanForPDF(inspection.siteName)}" conducted on ${Utils.formatDate(inspection.dateTime)}.`, 10);
        y += 4;
        
        doc.setFontSize(11);
