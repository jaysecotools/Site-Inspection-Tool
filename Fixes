                    const coords = inspection.coords || `${this.currentLat.toFixed(6)}, ${this.currentLng.toFixed(6)}`;
                    doc.text(`Center: ${coords}`, margin + 10, y);
                    y += 4;
                    const layerName = this.currentLayer.charAt(0).toUpperCase() + this.currentLayer.slice(1);
                    doc.text(`Basemap: ${layerName}`, margin + 10, y);
                } catch (e) {
                    console.warn('Could not add map image to PDF:', e);
                    // Add text fallback
                    doc.setFontSize(9);
                    doc.setTextColor('#666');
                    doc.text('Map image unavailable - check that markers and layers are visible on screen.', margin, y);
