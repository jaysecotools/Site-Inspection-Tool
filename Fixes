        const { total, done } = this.getChecklistCount();
        const summary = document.getElementById('checklistSummary');
        if (summary) {
            summary.innerHTML = `<span class="done">✓ ${done}/${total} completed</span> <span class="pending">${total - done} remaining</span>`;
        }
        const progress = document.getElementById('checklistProgress');
        if (progress) {
            const pct = total > 0 ? (done / total) * 100 : 0;
            progress.style.width = pct + '%';
            progress.style.background = pct >= 80 ? 'var(--success)' : pct >= 50 ? 'var(--warning)' : 'var(--danger)';
        }
    }
    
