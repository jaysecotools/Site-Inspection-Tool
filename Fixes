Fix for Map Image Fit Issue

The black spaces at the bottom and right are caused by the map capture capturing the full map container including any empty space. Here's the fix:

The Problem

· The map container has extra space when the map content doesn't perfectly fill it
· The capture includes the entire container, including empty areas

The Solution

We need to calculate the actual map bounds and crop the image to only show the visible map area.

Updated captureMapImage() Method

Replace your existing captureMapImage() method with this improved version:

```javascript
captureMapImage() {
    return new Promise((resolve) => {
        const mapContainer = document.getElementById('map');
        
        // Store current UI states to restore later
        const status = document.querySelector('.map-status');
        const tools = document.querySelector('.map-tools');
        const controls = document.querySelector('.leaflet-control-zoom');
        const layerControl = document.querySelector('.layer-control');
        
        let statusDisplay = status?.style.display;
        let toolsDisplay = tools?.style.display;
        let controlsDisplay = controls?.style.display;
        let layerDisplay = layerControl?.style.display;
        
        // Hide UI overlays temporarily for cleaner capture
        if (status) status.style.display = 'none';
        if (tools) tools.style.display = 'none';
        if (controls) controls.style.display = 'none';
        if (layerControl) layerControl.style.display = 'none';
        
        // Wait for map to settle
        this.map.invalidateSize(true);
        
        setTimeout(() => {
            // Get the actual map container dimensions
            const containerWidth = mapContainer.scrollWidth;
            const containerHeight = mapContainer.scrollHeight;
            
            // Use html2canvas to capture the map
            html2canvas(mapContainer, {
                useCORS: true,
                backgroundColor: null,
                scale: 1.8,
                logging: false,
                allowTaint: true,
                width: containerWidth,
                height: containerHeight,
                // Crop to actual map content
                x: 0,
                y: 0,
                windowWidth: containerWidth,
                windowHeight: containerHeight
            }).then(canvas => {
                // Restore UI
                if (status) status.style.display = statusDisplay || '';
                if (tools) tools.style.display = toolsDisplay || '';
                if (controls) controls.style.display = controlsDisplay || '';
                if (layerControl) layerControl.style.display = layerDisplay || '';
                
                // Get the actual map content bounds
                // We'll crop out any excess black space
                const ctx = canvas.getContext('2d');
                const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
                const data = imageData.data;
                
                // Find the actual content bounds by looking for non-black pixels
                let minX = canvas.width, minY = canvas.height, maxX = 0, maxY = 0;
                let found = false;
                
                // Sample pixels to find content boundaries
                const step = 4; // Check every 4th pixel for performance
                for (let y = 0; y < canvas.height; y += step) {
                    for (let x = 0; x < canvas.width; x += step) {
                        const i = (y * canvas.width + x) * 4;
                        // Check if pixel is not black (with some tolerance)
                        const r = data[i];
                        const g = data[i + 1];
                        const b = data[i + 2];
                        const isBlack = (r < 10 && g < 10 && b < 10);
                        
                        if (!isBlack) {
                            found = true;
                            if (x < minX) minX = x;
                            if (y < minY) minY = y;
                            if (x > maxX) maxX = x;
                            if (y > maxY) maxY = y;
                        }
                    }
                }
                
                // If we found content, crop to it
                if (found) {
                    // Add a small padding to avoid cutting off edges
                    const padding = 4;
                    minX = Math.max(0, minX - padding);
                    minY = Math.max(0, minY - padding);
                    maxX = Math.min(canvas.width, maxX + padding);
                    maxY = Math.min(canvas.height, maxY + padding);
                    
                    const cropWidth = maxX - minX;
                    const cropHeight = maxY - minY;
                    
                    // Create a cropped canvas
                    const croppedCanvas = document.createElement('canvas');
                    croppedCanvas.width = cropWidth;
                    croppedCanvas.height = cropHeight;
                    const cropCtx = croppedCanvas.getContext('2d');
                    
                    // Draw the cropped portion
                    cropCtx.drawImage(canvas, minX, minY, cropWidth, cropHeight, 0, 0, cropWidth, cropHeight);
                    
                    resolve(croppedCanvas.toDataURL('image/jpeg', 0.88));
                } else {
                    // If no content found (shouldn't happen), return the full canvas
                    resolve(canvas.toDataURL('image/jpeg', 0.88));
                }
            }).catch(() => {
                // Fallback: try capturing with lower quality
                html2canvas(mapContainer, {
                    useCORS: true,
                    backgroundColor: '#1a2a32',
                    scale: 1,
                    logging: false,
                    allowTaint: true,
                    width: mapContainer.scrollWidth,
                    height: mapContainer.scrollHeight
                }).then(canvas => {
                    // Restore UI
                    if (status) status.style.display = statusDisplay || '';
                    if (tools) tools.style.display = toolsDisplay || '';
                    if (controls) controls.style.display = controlsDisplay || '';
                    if (layerControl) layerControl.style.display = layerDisplay || '';
                    
                    // Try to crop the fallback capture too
                    try {
                        const ctx = canvas.getContext('2d');
                        const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
                        const data = imageData.data;
                        
                        let minX = canvas.width, minY = canvas.height, maxX = 0, maxY = 0;
                        let found = false;
                        const step = 4;
                        
                        for (let y = 0; y < canvas.height; y += step) {
                            for (let x = 0; x < canvas.width; x += step) {
                                const i = (y * canvas.width + x) * 4;
                                const r = data[i];
                                const g = data[i + 1];
                                const b = data[i + 2];
                                const isBlack = (r < 10 && g < 10 && b < 10);
                                
                                if (!isBlack) {
                                    found = true;
                                    if (x < minX) minX = x;
                                    if (y < minY) minY = y;
                                    if (x > maxX) maxX = x;
                                    if (y > maxY) maxY = y;
                                }
                            }
                        }
                        
                        if (found) {
                            const padding = 4;
                            minX = Math.max(0, minX - padding);
                            minY = Math.max(0, minY - padding);
                            maxX = Math.min(canvas.width, maxX + padding);
                            maxY = Math.min(canvas.height, maxY + padding);
                            
                            const cropWidth = maxX - minX;
                            const cropHeight = maxY - minY;
                            
                            const croppedCanvas = document.createElement('canvas');
                            croppedCanvas.width = cropWidth;
                            croppedCanvas.height = cropHeight;
                            const cropCtx = croppedCanvas.getContext('2d');
                            cropCtx.drawImage(canvas, minX, minY, cropWidth, cropHeight, 0, 0, cropWidth, cropHeight);
                            
                            resolve(croppedCanvas.toDataURL('image/jpeg', 0.8));
                        } else {
                            resolve(canvas.toDataURL('image/jpeg', 0.8));
                        }
                    } catch (e) {
                        resolve(canvas.toDataURL('image/jpeg', 0.8));
                    }
                }).catch(() => {
                    // Restore UI
                    if (status) status.style.display = statusDisplay || '';
                    if (tools) tools.style.display = toolsDisplay || '';
                    if (controls) controls.style.display = controlsDisplay || '';
                    if (layerControl) layerControl.style.display = layerDisplay || '';
                    
                    resolve(null);
                });
            });
        }, 400);
    });
}
```

Alternative Simpler Fix

If the above is too complex, here's a simpler approach that just ensures the map fills its container:

```javascript
captureMapImage() {
    return new Promise((resolve) => {
        const mapContainer = document.getElementById('map');
        
        // Force map to fill container
        this.map.invalidateSize(true);
        
        // Store UI states
        const status = document.querySelector('.map-status');
        const tools = document.querySelector('.map-tools');
        const controls = document.querySelector('.leaflet-control-zoom');
        const layerControl = document.querySelector('.layer-control');
        
        let statusDisplay = status?.style.display;
        let toolsDisplay = tools?.style.display;
        let controlsDisplay = controls?.style.display;
        let layerDisplay = layerControl?.style.display;
        
        // Hide UI overlays
        if (status) status.style.display = 'none';
        if (tools) tools.style.display = 'none';
        if (controls) controls.style.display = 'none';
        if (layerControl) layerControl.style.display = 'none';
        
        setTimeout(() => {
            // Get container dimensions
            const rect = mapContainer.getBoundingClientRect();
            const width = Math.floor(rect.width);
            const height = Math.floor(rect.height);
            
            html2canvas(mapContainer, {
                useCORS: true,
                backgroundColor: null,
                scale: 2,
                logging: false,
                allowTaint: true,
                width: width,
                height: height,
                // Only capture what's visible
                x: 0,
                y: 0,
                windowWidth: width,
                windowHeight: height
            }).then(canvas => {
                // Restore UI
                if (status) status.style.display = statusDisplay || '';
                if (tools) tools.style.display = toolsDisplay || '';
                if (controls) controls.style.display = controlsDisplay || '';
                if (layerControl) layerControl.style.display = layerDisplay || '';
                
                resolve(canvas.toDataURL('image/jpeg', 0.9));
            }).catch(() => {
                // Restore UI
                if (status) status.style.display = statusDisplay || '';
                if (tools) tools.style.display = toolsDisplay || '';
                if (controls) controls.style.display = controlsDisplay || '';
                if (layerControl) layerControl.style.display = layerDisplay || '';
                resolve(null);
            });
        }, 500);
    });
}
```

Key Changes

1. Better dimension handling - Uses getBoundingClientRect() for precise dimensions
2. Explicit cropping - Specifies x: 0, y: 0 and exact width/height
3. Content detection - Automatically detects non-black pixels to crop out empty space
4. More padding - Added padding to prevent cutting off map edges

Also Update the PDF Page

In the generateReport() method, adjust the map display on the PDF page:

```javascript
// In the map page section of generateReport()
if (mapDataUrl) {
    doc.addPage();
    y = margin + 5;
    addFooter();
    addTitle('SITE MAP', 18);
    drawLine();
    y += 6;

    try {
        const img = new Image();
        await new Promise((resolve) => {
            img.onload = resolve;
            img.onerror = resolve;
            img.src = mapDataUrl;
        });

        // Use more of the page for the map
        const maxMapWidth = pageWidth - 2 * margin - 8;
        const maxMapHeight = pageHeight - margin * 2 - 35;
        let mapWidth = maxMapWidth;
        let mapHeight = maxMapWidth * (img.height / img.width);
        
        // If the map is wider than tall, use full width
        if (img.width > img.height) {
            mapWidth = maxMapWidth;
            mapHeight = mapWidth * (img.height / img.width);
        } else {
            // If taller than wide, fit to height
            mapHeight = maxMapHeight;
            mapWidth = mapHeight * (img.width / img.height);
        }
        
        // Ensure it fits within both constraints
        if (mapHeight > maxMapHeight) {
            mapHeight = maxMapHeight;
            mapWidth = mapHeight * (img.width / img.height);
        }
        if (mapWidth > maxMapWidth) {
            mapWidth = maxMapWidth;
            mapHeight = mapWidth * (img.height / img.width);
        }

        const xOffset = margin + (maxMapWidth - mapWidth) / 2;
        doc.addImage(mapDataUrl, 'JPEG', xOffset, y, mapWidth, mapHeight);
        // ... rest of map info
    } catch (e) {
        // ... error handling
    }
}
```

This should eliminate the black spaces and make the map fit properly in both the preview and the PDF report.
