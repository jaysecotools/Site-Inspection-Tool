    bindForm() {
        const input = document.getElementById('photoInput');
        const drop = document.getElementById('photoDropZone');
        
        if (input) {
            input.onchange = (e) => this.handlePhotos(e.target.files);
        }
        if (drop) {
            drop.onclick = () => input?.click();
            drop.ondragover = (e) => { 
                e.preventDefault(); 
                drop.classList.add('dragover');
            };
            drop.ondragleave = () => { 
                drop.classList.remove('dragover');
            };
            drop.ondrop = (e) => {
                e.preventDefault();
                drop.classList.remove('dragover');
                if (e.dataTransfer.files.length) this.handlePhotos(e.dataTransfer.files);
            };
        }
        
        this.renderGallery();
        
        const saveBtn = document.getElementById('saveDraftBtn');
        const finalBtn = document.getElementById('finaliseBtn');
        const cancelBtn = document.getElementById('cancelBtn');
        
        if (saveBtn) saveBtn.onclick = () => this.saveDraft();
        if (finalBtn) finalBtn.onclick = () => this.finalise();
        if (cancelBtn) cancelBtn.onclick = () => this.closePanel();
        
        document.querySelectorAll('.section-header').forEach(h => {
            h.onclick = () => {
                h.classList.toggle('collapsed');
                if (h.nextElementSibling) h.nextElementSibling.classList.toggle('collapsed');
            };
        });
        
        ['vegHealth','speciesRichness','regeneration','weedCover','habitatQuality','disturbance'].forEach(id => {
            const el = document.getElementById(id);
            if (el) {
                el.oninput = () => {
                    const data = this.collectForm();
                    const eco = Utils.calculateScore(data);
                    const fill = document.querySelector('.health-fill');
                    const display = document.getElementById('scoreDisplay');
                    if (fill) { fill.style.width = `${eco.conditionScore*10}%`; fill.style.background = eco.colour; }
                    if (display) { 
                        display.innerHTML = `${eco.conditionScore}/10 <i class="fas ${eco.icon}" style="color:${eco.colour};font-size:0.9rem;"></i>`;
                    }
                    const valSpan = document.getElementById(id + 'Val');
                    if (valSpan) valSpan.textContent = el.value;
                };
            }
        });
        
        // Checklist checkbox listeners
        document.querySelectorAll('.checkbox-group input[type="checkbox"]').forEach(cb => {
            cb.addEventListener('change', () => this.updateChecklistDisplay());
        });
        
        // Initial checklist update
        this.updateChecklistDisplay();
    }
    
    // ================================================================
    // PHOTOS
    // ================================================================
    async handlePhotos(files) {
        const maxPhotos = 20;
        const remaining = maxPhotos - this.currentPhotos.length;
        const toProcess = Array.from(files).slice(0, remaining);
        
        if (Array.from(files).length > remaining) {
            Toast.warning(`Only ${remaining} more photos can be added`);
        }
        
        let added = 0;
        let errors = 0;
        
        for (const file of toProcess) {
            if (file.size > 5 * 1024 * 1024) {
                Toast.warning(`${file.name} is large (${Utils.formatFileSize(file.size)}), compressing...`);
            }
            
            try {
                const reader = new FileReader();
                const data = await new Promise((resolve) => {
                    reader.onload = async (e) => {
                        const compressed = await Utils.compressImage(e.target.result, 800, 800, 0.85);
                        resolve(compressed);
                    };
                    reader.onerror = () => resolve(null);
                    reader.readAsDataURL(file);
                });
                
                if (!data) { errors++; continue; }
                
                this.currentPhotos.push({
                    id: Utils.uuid(),
                    dataURL: data,
                    timestamp: new Date().toISOString(),
                    lat: this.currentLat,
                    lng: this.currentLng,
                    isHero: this.currentPhotos.length === 0,
                    filename: file.name
                });
                added++;
            } catch (e) {
                console.error('Photo processing error:', e);
                errors++;
            }
        }
        
        this.renderGallery();
        
        const countEl = document.querySelector('.photo-count');
        if (countEl) {
            countEl.textContent = `${this.currentPhotos.length} photos added`;
        }
        
        if (added > 0) Toast.success(`${added} photo(s) added`);
        if (errors > 0) Toast.warning(`${errors} photo(s) failed to process`);
    }
    
    renderGallery() {
        const g = document.getElementById('photoGallery');
        if (!g) return;
        
        if (this.currentPhotos.length === 0) {
            g.innerHTML = `
                <div style="padding:16px;text-align:center;color:var(--gray-400);grid-column:1/-1;">
                    <i class="fas fa-camera" style="font-size:18px;display:block;margin-bottom:2px;"></i>
                    No photos
                </div>
            `;
            return;
        }
        
        g.innerHTML = this.currentPhotos.map((p, i) => `
            <div class="photo-item" data-idx="${i}">
                <img src="${p.dataURL}" alt="Photo ${i+1}" loading="lazy">
                <button class="remove-photo" data-idx="${i}" title="Remove photo">×</button>
                ${p.isHero ? '<div class="hero-badge">Cover</div>' : ''}
            </div>
        `).join('');
        
        document.querySelectorAll('.remove-photo').forEach(el => {
            el.onclick = (e) => {
                e.stopPropagation();
                const idx = parseInt(el.dataset.idx);
                this.currentPhotos.splice(idx, 1);
                if (this.currentPhotos.length > 0 && !this.currentPhotos.some(p => p.isHero)) {
                    this.currentPhotos[0].isHero = true;
                }
                this.renderGallery();
                const countEl = document.querySelector('.photo-count');
                if (countEl) countEl.textContent = `${this.currentPhotos.length} photos added`;
            };
        });
        
        document.querySelectorAll('.photo-item').forEach((el, idx) => {
            el.onclick = () => {
                this.currentPhotos.forEach((p, i) => p.isHero = (i === idx));
                this.renderGallery();
                Toast.success('Cover photo set');
            };
        });
    }
    
