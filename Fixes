            { title: 'Site Conditions Notes:', text: inspection.siteConditionsNotes },
            { title: 'Environmental Notes:', text: inspection.environmentalNotes },
            { title: 'Work Practice Notes:', text: inspection.workPracticesNotes },
            { title: 'Equipment Notes:', text: inspection.equipmentNotes }
        ];
        
        let hasNotes = notes.some(n => n.text);
        if (hasNotes) {
            if (y > pageHeight - 50) {
                doc.addPage();
                y = margin + 5;
                addFooter();
            }
            addTitle('ADDITIONAL NOTES', 14);
            drawLine();
            y += 4;
            
            notes.forEach(note => {
                if (note.text) {
                    doc.setFontSize(10);
                    doc.setTextColor(colour);
                    doc.text(note.title, margin, y);
                    y += 4;
                    doc.setFontSize(9);
                    doc.setTextColor('#000000');
                    addText(note.text, 9);
                    y += 2;
                }
            });
        }
        
        // ============================================================
        // PHOTOS
        // ============================================================
        if (inspection.photos && inspection.photos.length > 0) {
            doc.addPage();
            y = margin + 5;
            addFooter();
            addTitle('PHOTO DOCUMENTATION', 18);
            drawLine();
            y += 6;
            
            const photos = inspection.photos.slice(0, 15);
            const photoSize = 50;
            const gap = 5;
            const maxCols = Math.floor((contentWidth + gap) / (photoSize + gap));
            let row = 0, col = 0;
            
            for (let i = 0; i < photos.length; i++) {
                const p = photos[i];
                const px = margin + col * (photoSize + gap);
                const py = y + row * (photoSize + gap + 8);
                
                if (py + photoSize + 10 > pageHeight - margin - 15) {
                    doc.addPage();
                    y = margin + 5;
                    addFooter();
                    addTitle('PHOTO DOCUMENTATION (continued)', 14);
                    drawLine();
                    y += 6;
                    row = 0;
                    col = 0;
                }
                
                try {
                    const img = new Image();
                    const imgData = await new Promise((resolve) => {
                        img.onload = () => resolve({ width: img.width, height: img.height });
                        img.onerror = () => resolve(null);
                        img.src = p.dataURL;
                    });
                    
                    let imgWidth = photoSize;
                    let imgHeight = photoSize * 0.75;
                    if (imgData) {
                        const aspectRatio = imgData.width / imgData.height;
                        if (aspectRatio > 1) {
                            imgWidth = photoSize;
                            imgHeight = photoSize / aspectRatio;
                        } else {
                            imgHeight = photoSize;
                            imgWidth = photoSize * aspectRatio;
                        }
                    }
                    
                    const xOffset = px + (photoSize - imgWidth) / 2;
                    const yOffset = py + (photoSize * 0.75 - imgHeight) / 2;
                    doc.addImage(p.dataURL, 'JPEG', xOffset, yOffset, imgWidth, imgHeight);
                    doc.setFontSize(6);
                    doc.setTextColor('#666');
                    doc.text(`Photo ${i+1}`, px + 2, py + photoSize * 0.75 + 4);
                } catch (e) {
                    doc.setFillColor('#f0f0f0');
                    doc.roundedRect(px, py, photoSize, photoSize * 0.75, 2, 2, 'F');
                    doc.setFontSize(8);
                    doc.setTextColor('#999');
                    doc.text(`Photo ${i+1}`, px + photoSize/2 - 10, py + photoSize * 0.375);
                }
                
                col++;
                if (col >= maxCols) {
                    col = 0;
                    row++;
                }
            }
        }
        
        // Save the PDF
        const fileName = `EcoMaintenance_Report_${inspection.id || Date.now()}.pdf`;
        doc.save(fileName);
        Toast.success('Professional report generated successfully');
        
    } catch (e) {
        console.error('Report generation error:', e);
        Toast.error('Failed to generate report: ' + e.message);
    } finally {
        this.isGenerating = false;
        if (finalBtn) {
            finalBtn.disabled = false;
            finalBtn.innerHTML = '<i class="fas fa-file-pdf"></i> Generate Report';
        }
    }
}
    
