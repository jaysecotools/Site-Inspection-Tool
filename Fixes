<script>
// ================================================================
// UTILITY
// ================================================================
const Utils = {
    uuid() {
        return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => {
            const r = Math.random() * 16 | 0;
            return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);
        });
    },
    
    escapeHtml(str) {
        if (!str) return '';
        const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' };
        return str.replace(/[&<>"']/g, m => map[m]);
    },
    
    cleanText(str) {
        if (!str) return '';
        return str.replace(/[^\w\s.,!?\-()'"]/g, ' ').trim();
    },
    
    // Simple text cleaner for PDF - just removes HTML and normalizes
    cleanForPdf(str) {
        if (!str) return '';
        let clean = String(str);
        // Decode common HTML entities
        clean = clean.replace(/&amp;/g, '&')
                     .replace(/&lt;/g, '<')
                     .replace(/&gt;/g, '>')
                     .replace(/&quot;/g, '"')
                     .replace(/&#039;/g, "'")
                     .replace(/&nbsp;/g, ' ');
        // Remove any HTML tags
        clean = clean.replace(/<[^>]*>/g, '');
        // Remove any remaining special characters
        clean = clean.replace(/[^\x20-\x7E]/g, ' ');
        // Normalize spaces
        clean = clean.replace(/\s+/g, ' ').trim();
        return clean;
    },
    
    formatDate(isoStr) {
        if (!isoStr) return '—';
        try {
            const d = new Date(isoStr);
            return d.toLocaleDateString('en-AU', { 
                year: 'numeric', month: 'short', day: 'numeric',
                hour: '2-digit', minute: '2-digit'
            });
        } catch { return isoStr; }
    },
    
    truncate(str, len = 40) {
        if (!str) return '';
        return str.length > len ? str.slice(0, len) + '…' : str;
    },
    
    clamp(val, min, max) { return Math.max(min, Math.min(max, val)); },
    round(val, d = 1) { return Number(val.toFixed(d)); },
    
    compressImage(dataURL, maxWidth = 800, maxHeight = 800, quality = 0.85) {
        return new Promise((resolve) => {
            const img = new Image();
            img.onload = () => {
                const canvas = document.createElement('canvas');
                let w = img.width, h = img.height;
                if (w > maxWidth) { h = (h * maxWidth) / w; w = maxWidth; }
                if (h > maxHeight) { w = (w * maxHeight) / h; h = maxHeight; }
                canvas.width = Math.round(w);
                canvas.height = Math.round(h);
                const ctx = canvas.getContext('2d');
                ctx.imageSmoothingEnabled = true;
                ctx.imageSmoothingQuality = 'high';
                ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
                resolve(canvas.toDataURL('image/jpeg', quality));
            };
            img.onerror = () => resolve(dataURL);
            img.src = dataURL;
        });
    },
    
    formatFileSize(bytes) {
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
        return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
    },
    
    calculateScore(data) {
        const vh = parseFloat(data.vegHealth || 6);
        const sr = parseFloat(data.speciesRichness || 5);
        const wc = parseFloat(data.weedCover || 30);
        const hq = parseFloat(data.habitatQuality || 5);
        const dist = parseFloat(data.disturbance || 3);
        const regen = parseFloat(data.regeneration || 5);
        
        const score = Utils.clamp(
            (vh * 0.25) + (sr * 0.2) + ((100 - wc) / 10 * 0.2) + 
            (hq * 0.15) + ((10 - dist) * 0.1) + (regen * 0.1),
            0, 10
        );
        
        let riskRating, priority, colour, icon;
        if (score < 3) { riskRating = 'Critical'; priority = 'Immediate Intervention'; colour = '#dc2626'; icon = 'fa-exclamation-triangle'; }
        else if (score < 5) { riskRating = 'High Risk'; priority = 'Urgent Management'; colour = '#f59e0b'; icon = 'fa-exclamation-circle'; }
        else if (score < 7) { riskRating = 'Medium Risk'; priority = 'Short-term Plan'; colour = '#f59e0b'; icon = 'fa-minus-circle'; }
        else if (score < 8.5) { riskRating = 'Low Risk'; priority = 'Regular Monitoring'; colour = '#3b82f6'; icon = 'fa-check-circle'; }
        else { riskRating = 'Excellent'; priority = 'Maintenance Only'; colour = '#10b981'; icon = 'fa-star'; }
        
        return {
            conditionScore: Utils.round(score, 1),
            riskRating, priority, colour, icon,
            significance: score > 7 ? 'High Conservation Value' : (score > 5 ? 'Moderate Conservation Value' : 'Low Conservation Value')
        };
    },
    
    getRatingClass(score) {
        if (score >= 8) return 'excellent';
        if (score >= 6.5) return 'good';
        if (score >= 4.5) return 'moderate';
        return 'poor';
    },
    
    getVegetationTypes() {
        return ['Dry Eucalypt Forest', 'Wet Eucalypt Forest', 'Rainforest', 'Moorland', 
                'Grassland', 'Coastal Heath', 'Saltmarsh', 'Alpine Vegetation', 
                'Riparian Forest', 'Plantation', 'Mixed Forest', 'Woodland'];
    },
    
    getThreatLevels() { return ['Low', 'Medium', 'High', 'Critical']; },
    getFeralOptions() { return ['Nil', 'Low', 'Medium', 'High']; },
    getHeritageOptions() { 
        return ['High – known cultural site', 'Moderate – potential heritage', 'Low – minimal evidence', 'Not Assessed']; 
    }
};

// ================================================================
// TOAST
// ================================================================
const Toast = {
    show(msg, type = 'info', duration = 3000) {
        const container = document.getElementById('toastContainer');
        const toast = document.createElement('div');
        const icons = { 
            success: 'fa-check-circle', 
            warning: 'fa-exclamation-triangle', 
            error: 'fa-times-circle', 
            info: 'fa-info-circle' 
        };
        toast.className = `toast ${type}`;
        toast.innerHTML = `<i class="fas ${icons[type] || icons.info}"></i> ${Utils.escapeHtml(msg)}`;
        container.appendChild(toast);
        setTimeout(() => { if (toast.parentNode) toast.remove(); }, duration);
    },
    success(msg) { this.show(msg, 'success'); },
    warning(msg) { this.show(msg, 'warning'); },
    error(msg) { this.show(msg, 'error'); },
    info(msg) { this.show(msg, 'info'); }
};

// ================================================================
// DATABASE
// ================================================================
class Database {
    constructor() {
        this.data = { inspections: [], drafts: [] };
        this.ready = true;
        this._loadFromStorage();
    }
    
    _loadFromStorage() {
        try {
            const saved = localStorage.getItem('EcoMaintenanceData');
            if (saved) {
                const parsed = JSON.parse(saved);
                this.data = parsed;
            }
        } catch (e) {}
    }
    
    _saveToStorage() {
        try {
            localStorage.setItem('EcoMaintenanceData', JSON.stringify(this.data));
        } catch (e) {}
    }
    
    async save(item, isDraft = false) {
        const store = isDraft ? 'drafts' : 'inspections';
        const existing = this.data[store].findIndex(i => i.id === item.id);
        if (existing >= 0) {
            this.data[store][existing] = item;
        } else {
            this.data[store].push(item);
        }
        this._saveToStorage();
        return item;
    }
    
    async getAll(store = 'inspections') {
        return this.data[store] || [];
    }
    
    async get(id, isDraft = false) {
        const store = isDraft ? 'drafts' : 'inspections';
        return this.data[store].find(i => i.id === id) || null;
    }
    
    async delete(id, isDraft = false) {
        const store = isDraft ? 'drafts' : 'inspections';
        this.data[store] = this.data[store].filter(i => i.id !== id);
        this._saveToStorage();
    }
    
    async count(store = 'inspections') {
        return (this.data[store] || []).length;
    }
    
    async clear(store = 'inspections') {
        this.data[store] = [];
        this._saveToStorage();
    }
}

// ================================================================
// MAIN APP
// ================================================================
class App {
    constructor() {
        this.db = new Database();
        this.map = null;
        this.drawnItems = null;
        this.currentId = null;
        this.currentPhotos = [];
        this.isDraft = false;
        this.currentLat = -42.8806;
        this.currentLng = 147.3250;
        this.polygonCount = 0;
        this.waypointCount = 0;
        this.measureMode = false;
        this.measurePoints = [];
        this.measureLine = null;
        this.measureMarkers = [];
        this.gpsMarker = null;
        this.initialized = false;
        this.currentLayer = 'streets';
        this.searchMarker = null;
        this.layers = {};
        this.isGenerating = false;
        this._mapImage = null; // Store captured map image for report
    }
    
    // ================================================================
    // INIT
    // ================================================================
    init() {
        if (this.initialized) return;
        this.initMap();
        this.initGPS();
        this.updateStatus();
        this.bindEvents();
        this.showDashboard();
        this.initialized = true;
        Toast.success('EcoMaintenance Professional Ready');
    }
    
    // ================================================================
    // MAP
    // ================================================================
    initMap() {
        this.map = L.map('map', { 
            center: [-42.8806, 147.3250], 
            zoom: 10, 
            zoomControl: false 
        });
        
        // Create layers
        this.layers = {
            streets: L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
            }),
            satellite: L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
                attribution: '&copy; <a href="https://www.esri.com">Esri</a>'
            }),
            topo: L.tileLayer('https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; <a href="https://opentopomap.org">OpenTopoMap</a>'
            })
        };
        
        // Error handling for tiles
        Object.values(this.layers).forEach(layer => {
            layer.on('tileerror', function(e) {
                console.warn('Tile loading error:', e);
                setTimeout(() => {
                    if (e.tile) {
                        e.tile.src = e.tile.src.split('?')[0] + '?retry=' + Date.now();
                    }
                }, 1000);
            });
        });
        
        // Add default layer
        this.layers.streets.addTo(this.map);
        
        L.control.zoom({ position: 'bottomright' }).addTo(this.map);
        
        this.drawnItems = L.featureGroup().addTo(this.map);
        
        const drawControl = new L.Control.Draw({
            position: 'topleft',
            draw: {
                polygon: { shapeOptions: { color: '#1a5f4a', weight: 3, opacity: 0.7 }, showArea: true },
                rectangle: { shapeOptions: { color: '#1a5f4a', weight: 3 } },
                marker: true,
                circle: false,
                polyline: false
            },
            edit: { featureGroup: this.drawnItems, remove: true }
        });
        this.map.addControl(drawControl);
        
        this.map.on(L.Draw.Event.CREATED, (e) => {
            const layer = e.layer;
            if (e.layerType === 'polygon' || e.layerType === 'rectangle') {
                this.polygonCount++;
                document.getElementById('polygonCount').textContent = this.polygonCount;
                try {
                    const area = turf.area(layer.toGeoJSON()) / 10000;
                    Toast.success(`Polygon: ${area.toFixed(2)} ha`);
                } catch {}
            } else if (e.layerType === 'marker') {
                this.waypointCount++;
                document.getElementById('waypointCount').textContent = this.waypointCount;
                Toast.success(`Waypoint ${this.waypointCount}`);
            }
            this.drawnItems.addLayer(layer);
            // Clear cached map image when map changes
            this._mapImage = null;
        });
        
        this.map.on('click', (e) => {
            this.currentLat = e.latlng.lat;
            this.currentLng = e.latlng.lng;
        });
        
        // Clear cached map image on any map interaction
        this.map.on('moveend zoomend', () => {
            this._mapImage = null;
        });
        
        document.getElementById('polygonCount').textContent = '0';
        document.getElementById('waypointCount').textContent = '0';
        document.getElementById('currentLayer').textContent = 'Streets';
    }
    
    // ================================================================
    // CAPTURE MAP IMAGE FOR PDF
    // ================================================================
    captureMapImage() {
        return new Promise((resolve) => {
            const mapContainer = document.getElementById('map');
            
            // Store current UI states to restore later
            const status = document.querySelector('.map-status');
            const tools = document.querySelector('.map-tools');
            const controls = document.querySelector('.leaflet-control-zoom');
            const layerControl = document.querySelector('.layer-control');
            
            let statusDisplay = status?.style.display;
            let toolsDisplay = tools?.style.display;
            let controlsDisplay = controls?.style.display;
            let layerDisplay = layerControl?.style.display;
            
            // Hide UI overlays temporarily for cleaner capture
            if (status) status.style.display = 'none';
            if (tools) tools.style.display = 'none';
            if (controls) controls.style.display = 'none';
            if (layerControl) layerControl.style.display = 'none';
            
            // Wait for map to settle
            this.map.invalidateSize(true);
            
            setTimeout(() => {
                // Get the actual map container dimensions
                const containerWidth = mapContainer.scrollWidth;
                const containerHeight = mapContainer.scrollHeight;
                
                // Use html2canvas to capture the map
                html2canvas(mapContainer, {
                    useCORS: true,
                    backgroundColor: null,
                    scale: 1.8,
                    logging: false,
                    allowTaint: true,
                    width: containerWidth,
                    height: containerHeight,
                    // Crop to actual map content
                    x: 0,
                    y: 0,
                    windowWidth: containerWidth,
                    windowHeight: containerHeight
                }).then(canvas => {
                    // Restore UI
                    if (status) status.style.display = statusDisplay || '';
                    if (tools) tools.style.display = toolsDisplay || '';
                    if (controls) controls.style.display = controlsDisplay || '';
                    if (layerControl) layerControl.style.display = layerDisplay || '';
                    
                    // Get the actual map content bounds
                    // We'll crop out any excess black space
                    const ctx = canvas.getContext('2d');
                    const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
                    const data = imageData.data;
                    
                    // Find the actual content bounds by looking for non-black pixels
                    let minX = canvas.width, minY = canvas.height, maxX = 0, maxY = 0;
                    let found = false;
                    
                    // Sample pixels to find content boundaries
                    const step = 4; // Check every 4th pixel for performance
                    for (let y = 0; y < canvas.height; y += step) {
                        for (let x = 0; x < canvas.width; x += step) {
                            const i = (y * canvas.width + x) * 4;
                            // Check if pixel is not black (with some tolerance)
                            const r = data[i];
                            const g = data[i + 1];
                            const b = data[i + 2];
                            const isBlack = (r < 10 && g < 10 && b < 10);
                            
                            if (!isBlack) {
                                found = true;
                                if (x < minX) minX = x;
                                if (y < minY) minY = y;
                                if (x > maxX) maxX = x;
                                if (y > maxY) maxY = y;
                            }
                        }
                    }
                    
                    // If we found content, crop to it
                    if (found) {
                        // Add a small padding to avoid cutting off edges
                        const padding = 4;
                        minX = Math.max(0, minX - padding);
                        minY = Math.max(0, minY - padding);
                        maxX = Math.min(canvas.width, maxX + padding);
                        maxY = Math.min(canvas.height, maxY + padding);
                        
                        const cropWidth = maxX - minX;
                        const cropHeight = maxY - minY;
                        
                        // Create a cropped canvas
                        const croppedCanvas = document.createElement('canvas');
                        croppedCanvas.width = cropWidth;
                        croppedCanvas.height = cropHeight;
                        const cropCtx = croppedCanvas.getContext('2d');
                        
                        // Draw the cropped portion
                        cropCtx.drawImage(canvas, minX, minY, cropWidth, cropHeight, 0, 0, cropWidth, cropHeight);
                        
                        resolve(croppedCanvas.toDataURL('image/jpeg', 0.88));
                    } else {
                        // If no content found (shouldn't happen), return the full canvas
                        resolve(canvas.toDataURL('image/jpeg', 0.88));
                    }
                }).catch(() => {
                    // Fallback: try capturing with lower quality
                    html2canvas(mapContainer, {
                        useCORS: true,
                        backgroundColor: '#1a2a32',
                        scale: 1,
                        logging: false,
                        allowTaint: true,
                        width: mapContainer.scrollWidth,
                        height: mapContainer.scrollHeight
                    }).then(canvas => {
                        // Restore UI
                        if (status) status.style.display = statusDisplay || '';
                        if (tools) tools.style.display = toolsDisplay || '';
                        if (controls) controls.style.display = controlsDisplay || '';
                        if (layerControl) layerControl.style.display = layerDisplay || '';
                        
                        // Try to crop the fallback capture too
                        try {
                            const ctx = canvas.getContext('2d');
                            const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
                            const data = imageData.data;
                            
                            let minX = canvas.width, minY = canvas.height, maxX = 0, maxY = 0;
                            let found = false;
                            const step = 4;
                            
                            for (let y = 0; y < canvas.height; y += step) {
                                for (let x = 0; x < canvas.width; x += step) {
                                    const i = (y * canvas.width + x) * 4;
                                    const r = data[i];
                                    const g = data[i + 1];
                                    const b = data[i + 2];
                                    const isBlack = (r < 10 && g < 10 && b < 10);
                                    
                                    if (!isBlack) {
                                        found = true;
                                        if (x < minX) minX = x;
                                        if (y < minY) minY = y;
                                        if (x > maxX) maxX = x;
                                        if (y > maxY) maxY = y;
                                    }
                                }
                            }
                            
                            if (found) {
                                const padding = 4;
                                minX = Math.max(0, minX - padding);
                                minY = Math.max(0, minY - padding);
                                maxX = Math.min(canvas.width, maxX + padding);
                                maxY = Math.min(canvas.height, maxY + padding);
                                
                                const cropWidth = maxX - minX;
                                const cropHeight = maxY - minY;
                                
                                const croppedCanvas = document.createElement('canvas');
                                croppedCanvas.width = cropWidth;
                                croppedCanvas.height = cropHeight;
                                const cropCtx = croppedCanvas.getContext('2d');
                                cropCtx.drawImage(canvas, minX, minY, cropWidth, cropHeight, 0, 0, cropWidth, cropHeight);
                                
                                resolve(croppedCanvas.toDataURL('image/jpeg', 0.8));
                            } else {
                                resolve(canvas.toDataURL('image/jpeg', 0.8));
                            }
                        } catch (e) {
                            resolve(canvas.toDataURL('image/jpeg', 0.8));
                        }
                    }).catch(() => {
                        // Restore UI
                        if (status) status.style.display = statusDisplay || '';
                        if (tools) tools.style.display = toolsDisplay || '';
                        if (controls) controls.style.display = controlsDisplay || '';
                        if (layerControl) layerControl.style.display = layerDisplay || '';
                        
                        resolve(null);
                    });
                });
            }, 400);
        });
    }
    
    switchLayer(name) {
        if (this.currentLayer === name) return;
        
        // Remove all layers from map
        Object.values(this.layers).forEach(layer => {
            if (this.map.hasLayer(layer)) {
                this.map.removeLayer(layer);
            }
        });
        
        // Add the selected layer
        this.currentLayer = name;
        const layer = this.layers[name];
        if (layer) {
            layer.addTo(this.map);
            setTimeout(() => this.map.invalidateSize(true), 100);
            
            // Update UI
            document.querySelectorAll('.layer-item').forEach(el => {
                el.classList.toggle('active', el.dataset.layer === name);
            });
            
            const layerNames = { streets: 'Streets', satellite: 'Satellite', topo: 'Topo' };
            document.getElementById('currentLayer').textContent = layerNames[name] || name;
            
            const satBtn = document.getElementById('toggleSatBtn');
            if (name === 'satellite') {
                satBtn.innerHTML = '<i class="fas fa-map"></i><span> Streets</span>';
                satBtn.style.background = 'var(--primary)';
                satBtn.style.color = 'white';
            } else {
                satBtn.innerHTML = '<i class="fas fa-satellite"></i><span> Satellite</span>';
                satBtn.style.background = '';
                satBtn.style.color = '';
            }
            
            // Clear cached map image when layer changes
            this._mapImage = null;
            
            Toast.info(`Switched to ${layerNames[name] || name} view`);
        }
    }
    
    // ================================================================
    // ADDRESS SEARCH
    // ================================================================
    async searchAddress(query) {
        if (!query || query.trim().length < 3) {
            Toast.warning('Please enter at least 3 characters');
            return;
        }
        
        Toast.info('Searching...');
        
        try {
            const response = await fetch(
                `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}&limit=1&addressdetails=1`
            );
            const data = await response.json();
            
            if (!data || data.length === 0) {
                Toast.warning('Address not found');
                return;
            }
            
            const result = data[0];
            const lat = parseFloat(result.lat);
            const lon = parseFloat(result.lon);
            const displayName = result.display_name || query;
            
            if (this.searchMarker) {
                this.map.removeLayer(this.searchMarker);
            }
            
            this.searchMarker = L.marker([lat, lon], {
                icon: L.divIcon({
                    html: '<div style="background:#3b82f6;width:16px;height:16px;border-radius:50%;border:3px solid white;box-shadow:0 2px 8px rgba(0,0,0,0.3);"></div>',
                    iconSize: [16, 16],
                    className: 'search-marker'
                })
            }).addTo(this.map);
            
            this.searchMarker.bindPopup(`<strong>${Utils.escapeHtml(displayName)}</strong>`).openPopup();
            
            this.map.flyTo([lat, lon], 15, { duration: 1.5 });
            
            this.currentLat = lat;
            this.currentLng = lon;
            
            // Clear cached map image
            this._mapImage = null;
            
            Toast.success(`Found: ${Utils.truncate(displayName, 50)}`);
            
        } catch (error) {
            console.error('Search error:', error);
            Toast.error('Search failed. Please try again.');
        }
    }
    
    // ================================================================
    // LOCATION
    // ================================================================
    locateUser() {
        if (!navigator.geolocation) { 
            Toast.warning('Geolocation not supported'); 
            return; 
        }
        
        Toast.info('Getting your location...');
        
        navigator.geolocation.getCurrentPosition(
            pos => { 
                const lat = pos.coords.latitude;
                const lng = pos.coords.longitude;
                this.map.flyTo([lat, lng], 16, { duration: 1 });
                this.currentLat = lat;
                this.currentLng = lng;
                
                if (this.searchMarker) {
                    this.map.removeLayer(this.searchMarker);
                }
                this.searchMarker = L.marker([lat, lng], {
                    icon: L.divIcon({
                        html: '<div style="background:#dc2626;width:16px;height:16px;border-radius:50%;border:3px solid white;box-shadow:0 0 0 4px rgba(220,38,38,0.3);"></div>',
                        iconSize: [16, 16],
                        className: 'locate-marker'
                    })
                }).addTo(this.map);
                this.searchMarker.bindPopup('Your Location').openPopup();
                
                // Clear cached map image
                this._mapImage = null;
                
                Toast.success('Location found');
            },
            () => Toast.warning('Location unavailable. Please enable GPS.'),
            { enableHighAccuracy: true, timeout: 10000 }
        );
    }
    
    initGPS() {
        if (!navigator.geolocation) { 
            document.getElementById('gpsStatus').textContent = 'Unavailable'; 
            return; 
        }
        navigator.geolocation.watchPosition(
            pos => {
                this.currentLat = pos.coords.latitude;
                this.currentLng = pos.coords.longitude;
                document.getElementById('gpsStatus').textContent = `±${Math.round(pos.coords.accuracy)}m`;
                if (!this.gpsMarker) {
                    this.gpsMarker = L.marker([this.currentLat, this.currentLng], {
                        icon: L.divIcon({
                            html: '<div style="background:#dc2626;width:12px;height:12px;border-radius:50%;border:2px solid white;box-shadow:0 0 0 4px rgba(220,38,38,0.3);animation:pulse 2s infinite;"></div>',
                            iconSize: [12, 12],
                            className: 'gps-marker'
                        }),
                        zIndexOffset: 1000
                    }).addTo(this.map);
                    const style = document.createElement('style');
                    style.textContent = `
                        @keyframes pulse {
                            0% { box-shadow: 0 0 0 0 rgba(220,38,38,0.4); }
