            } else {
                // No map image available - add placeholder
                doc.addPage();
                y = margin + 5;
                addFooter();
                addTitle('SITE MAP', 18);
                drawLine();
                y += 6;
                
                doc.setFontSize(10);
                doc.setTextColor('#666');
                doc.text('Map image not available. Please ensure the map is visible', margin, y);
                y += 6;
                doc.text('and use the "Refresh Map" button before generating the report.', margin, y);
                y += 6;
                const geoInfo = this.getGeometry().length || inspection.geometry?.length || 0;
                const waypoints = this.getWaypoints().length || inspection.waypoints?.length || 0;
                doc.text(`Site contains: ${geoInfo} polygon(s) and ${waypoints} waypoint(s)`, margin, y);
            }
            
            // ============================================================
            // EXECUTIVE SUMMARY
            // ============================================================
            doc.addPage();
            y = margin + 5;
            addFooter();
            addTitle('EXECUTIVE SUMMARY', 22);
            drawLine();
            y += 4;
            
            doc.setFontSize(14);
            doc.setTextColor(colour);
            doc.text(`Overall Condition Score: ${eco.conditionScore}/10`, margin, y);
            y += 8;
            
            doc.setFontSize(11);
            doc.setTextColor(eco.colour);
            doc.text(`Risk Rating: ${eco.riskRating}`, margin, y);
            y += 6;
            doc.setTextColor('#000000');
            doc.text(`Management Priority: ${eco.priority}`, margin, y);
            y += 6;
            doc.text(`Conservation Significance: ${eco.significance}`, margin, y);
            y += 10;
            
            const summaryText = `This report presents findings of an ecological assessment at "${cleanText(inspection.siteName)}" conducted on ${Utils.formatDate(inspection.dateTime)}.`;
            addText(summaryText, 10);
            y += 4;
            
            doc.setFontSize(11);
            doc.setTextColor(colour);
            doc.text('Key Findings:', margin, y);
            y += 5;
            doc.setFontSize(9);
            doc.setTextColor('#000000');
            const findings = [
                `Vegetation Health: ${inspection.vegHealth || 6}/10`,
                `Species Richness: ${inspection.speciesRichness || 5} species recorded`,
                `Weed Cover: ${inspection.weedCover || 30}%`,
                `Habitat Quality: ${inspection.habitatQuality || 5}/10`,
                `Disturbance Level: ${inspection.disturbance || 3}/10`
            ];
            findings.forEach(f => {
                doc.text(`• ${f}`, margin + 4, y);
                y += 5;
            });
            y += 6;
            
            // ============================================================
            // CHECKLIST SUMMARY
            // ============================================================
            if (y > pageHeight - 60) {
                doc.addPage();
                y = margin + 5;
                addFooter();
            }
            addTitle('CHECKLIST SUMMARY', 16);
            drawLine();
            y += 4;
            
            const checklistItems = [
                { section: 'General Site Conditions', label: 'Verified site location and boundaries', value: inspection.siteLocation },
                { section: 'General Site Conditions', label: 'Assessed accessibility and entry points', value: inspection.accessibility },
                { section: 'General Site Conditions', label: 'Evaluated site conditions', value: inspection.siteConditions },
                { section: 'General Site Conditions', label: 'Identified existing infrastructure or features', value: inspection.infrastructure },
                
                { section: 'Environmental Considerations', label: 'Assessed presence of protected flora or fauna', value: inspection.protectedSpecies },
                { section: 'Environmental Considerations', label: 'Evaluated potential environmental impacts', value: inspection.environmentalImpacts },
                { section: 'Environmental Considerations', label: 'Verified compliance with environmental regulations', value: inspection.compliance },
                { section: 'Environmental Considerations', label: 'Noted areas of conservation significance', value: inspection.conservation },
                
                { section: 'Work Practices and Procedures', label: 'Observed and evaluated work practices', value: inspection.workPractices },
                { section: 'Work Practices and Procedures', label: 'Assessed compliance with health and safety regulations', value: inspection.healthSafety },
                { section: 'Work Practices and Procedures', label: 'Identified potential risks and hazards', value: inspection.risksHazards },
                { section: 'Work Practices and Procedures', label: 'Reviewed implementation of control measures', value: inspection.controlMeasures },
                
                { section: 'Equipment and Machinery', label: 'Inspected equipment and machinery', value: inspection.equipmentInspected },
                { section: 'Equipment and Machinery', label: 'Ensured equipment in safe working condition', value: inspection.safeCondition },
                { section: 'Equipment and Machinery', label: 'Checked maintenance and service records', value: inspection.maintenanceRecords },
                { section: 'Equipment and Machinery', label: 'Verified compliance with industry standards', value: inspection.industryStandards }
            ];
            
            let total = checklistItems.length;
            let completed = checklistItems.filter(item => item.value === true || item.value === 'true' || item.value === 1).length;
            
            doc.setFontSize(9);
            doc.setTextColor('#000000');
            doc.text(`Completion: ${completed}/${total} items (${Math.round((completed/total)*100)}%)`, margin, y);
            y += 6;
            
            let currentSection = '';
            checklistItems.forEach(item => {
                if (y > pageHeight - 25) {
                    doc.addPage();
                    y = margin + 5;
                    addFooter();
                    doc.setFontSize(9);
                    doc.setTextColor('#000000');
                    doc.text(`Completion: ${completed}/${total} items (${Math.round((completed/total)*100)}%)`, margin, y);
                    y += 6;
                }
                
                if (item.section !== currentSection) {
                    currentSection = item.section;
                    doc.setFontSize(11);
                    doc.setTextColor(colour);
                    doc.text(currentSection, margin, y);
                    y += 5;
                }
                
                const isChecked = (item.value === true || item.value === 'true' || item.value === 1);
                const symbol = isChecked ? 'v' : 'x';
                const color = isChecked ? '#10b981' : '#dc2626';
                
                doc.setFontSize(8);
                doc.setTextColor(color);
                doc.text(`${symbol}  ${item.label}`, margin + 4, y);
                y += 5;
            });
            y += 3;
            
            // ============================================================
            // SITE INFORMATION DETAILS
            // ============================================================
            if (y > pageHeight - 50) {
                doc.addPage();
                y = margin + 5;
                addFooter();
            }
            addTitle('SITE INFORMATION', 16);
            drawLine();
            y += 4;
            
            const siteInfo = [
                ['Site Name:', cleanText(inspection.siteName || 'Not specified')],
                ['Inspector:', cleanText(inspection.inspector || 'Not specified')],
                ['Organization:', cleanText(inspection.organization || 'Not specified')],
                ['Date/Time:', Utils.formatDate(inspection.dateTime)],
                ['Coordinates:', cleanText(inspection.coords || 'Not recorded')],
                ['Vegetation Type:', cleanText(inspection.vegetationType || 'Not specified')],
                ['Tenure:', cleanText(inspection.tenure || 'Not specified')],
                ['Weather:', cleanText(inspection.weather || 'Not recorded')],
                ['Soil Condition:', cleanText(inspection.soilCondition || 'Not recorded')]
            ];
            
            doc.setFontSize(9);
            doc.setTextColor('#000000');
            const maxWidth = pageWidth - 2 * margin;
            
            siteInfo.forEach(([label, value]) => {
                if (y > pageHeight - 20) {
                    doc.addPage();
                    y = margin + 5;
                    addFooter();
                    doc.setFontSize(9);
                    doc.setTextColor('#000000');
                }
                
                const fullText = `${label} ${value}`;
                const lines = doc.splitTextToSize(fullText, maxWidth);
                doc.text(lines, margin, y);
                y += (lines.length * 4.5) + 2;
            });
            y += 3;
            
            // ============================================================
            // SPECIES AND THREATS
            // ============================================================
            if (y > pageHeight - 50) {
                doc.addPage();
                y = margin + 5;
                addFooter();
            }
            addTitle('SPECIES AND THREATS', 16);
            drawLine();
            y += 4;
            
            doc.setFontSize(9);
            doc.setTextColor('#000000');
            const threats = [
                ['Declared Weeds Present:', cleanText(inspection.weedsList || 'None recorded')],
                ['Feral Animals:', cleanText(inspection.feralAnimals || 'Not assessed')],
                ['Fire History:', cleanText(inspection.fireHistory || 'Not recorded')],
                ['Overall Threat Level:', cleanText(inspection.threatLevel || 'Not assessed')]
            ];
            
            threats.forEach(([label, value]) => {
                if (y > pageHeight - 20) {
                    doc.addPage();
                    y = margin + 5;
                    addFooter();
                    doc.setFontSize(9);
                }
                const fullText = `${label} ${value}`;
                const lines = doc.splitTextToSize(fullText, pageWidth - 2 * margin);
                doc.text(lines, margin, y);
                y += (lines.length * 4.5) + 2;
            });
            y += 3;
            
            // ============================================================
            // ABORIGINAL HERITAGE
            // ============================================================
            if (y > pageHeight - 50) {
                doc.addPage();
                y = margin + 5;
                addFooter();
            }
            addTitle('ABORIGINAL HERITAGE', 16);
            drawLine();
            y += 4;
            
            doc.setFontSize(10);
            doc.setTextColor('#000000');
            const heritageSig = cleanText(inspection.heritageSignificance || 'Not Assessed');
            doc.text(`Heritage Significance: ${heritageSig}`, margin, y);
            y += 6;
            
            doc.text('Cultural Sites / Artefacts:', margin, y);
            y += 4;
            const culturalSites = cleanText(inspection.culturalSites || 'No cultural sites recorded.');
            addText(culturalSites, 9);
            y += 4;
            
            doc.text('Heritage Management Notes:', margin, y);
            y += 4;
            const heritageNotes = cleanText(inspection.aboriginalHeritage || 'No heritage management notes.');
            addText(heritageNotes, 9);
            y += 6;
            
            // ============================================================
            // OBSERVATIONS
            // ============================================================
            if (y > pageHeight - 40) {
                doc.addPage();
                y = margin + 5;
                addFooter();
            }
            addTitle('OBSERVATIONS', 14);
            drawLine();
            y += 4;

            doc.setFontSize(10);
            doc.setTextColor('#000000');
            const observations = cleanText(inspection.observations || 'No observations recorded.');
            if (observations) {
                const obsLines = doc.splitTextToSize(observations, pageWidth - 2 * margin);
                const lineHeight = 5.5;
                for (let i = 0; i < obsLines.length; i++) {
                    if (y + lineHeight > pageHeight - margin - 10) {
                        doc.addPage();
                        y = margin + 5;
                        addFooter();
                        doc.setFontSize(10);
                        doc.setTextColor('#000000');
                    }
                    doc.text(obsLines[i], margin, y);
                    y += lineHeight;
                }
                y += 3;
            }

            // ============================================================
            // RECOMMENDATIONS
            // ============================================================
            if (y > pageHeight - 40) {
                doc.addPage();
                y = margin + 5;
                addFooter();
            }
            addTitle('RECOMMENDATIONS', 14);
            drawLine();
            y += 4;

            doc.setFontSize(10);
            doc.setTextColor('#000000');
            const recommendations = cleanText(inspection.recommendations || 'No specific recommendations recorded.');
            if (recommendations) {
                const recLines = doc.splitTextToSize(recommendations, pageWidth - 2 * margin);
                const lineHeight = 5.5;
                for (let i = 0; i < recLines.length; i++) {
                    if (y + lineHeight > pageHeight - margin - 10) {
                        doc.addPage();
                        y = margin + 5;
                        addFooter();
                        doc.setFontSize(10);
                        doc.setTextColor('#000000');
                    }
                    doc.text(recLines[i], margin, y);
                    y += lineHeight;
                }
                y += 3;
            }

            // ============================================================
            // ECOLOGICAL HEALTH DETAILS
            // ============================================================
            if (y > pageHeight - 50) {
                doc.addPage();
                y = margin + 5;
                addFooter();
            }
            addTitle('ECOLOGICAL HEALTH METRICS', 14);
            drawLine();
            y += 4;
            
            doc.setFontSize(9);
            doc.setTextColor('#000000');
            const metrics = [
                ['Vegetation Health:', `${inspection.vegHealth || 6}/10`],
                ['Species Richness:', `${inspection.speciesRichness || 5}/10`],
                ['Weed Cover:', `${inspection.weedCover || 30}%`],
                ['Habitat Quality:', `${inspection.habitatQuality || 5}/10`],
                ['Disturbance Level:', `${inspection.disturbance || 3}/10`],
                ['Regeneration:', `${inspection.regeneration || 5}/10`],
                ['Overall Score:', `${eco.conditionScore}/10`]
            ];
            
            metrics.forEach(([label, value]) => {
                if (y > pageHeight - 20) {
                    doc.addPage();
                    y = margin + 5;
                    addFooter();
                    doc.setFontSize(9);
                }
                const fullText = `${label} ${value}`;
                const lines = doc.splitTextToSize(fullText, pageWidth - 2 * margin);
                doc.text(lines, margin, y);
                y += (lines.length * 4.5) + 2;
            });
            y += 3;
            
            // ============================================================
            // CHECKLIST NOTES
            // ============================================================
            const notes = [
                { title: 'Site Conditions Notes:', text: inspection.siteConditionsNotes },
                { title: 'Environmental Notes:', text: inspection.environmentalNotes },
                { title: 'Work Practice Notes:', text: inspection.workPracticesNotes },
                { title: 'Equipment Notes:', text: inspection.equipmentNotes }
            ];
            
            let hasNotes = notes.some(n => n.text);
            if (hasNotes) {
                if (y > pageHeight - 50) {
                    doc.addPage();
                    y = margin + 5;
                    addFooter();
                }
                addTitle('ADDITIONAL NOTES', 14);
                drawLine();
                y += 4;
                
                notes.forEach(note => {
                    if (note.text) {
                        doc.setFontSize(10);
                        doc.setTextColor(colour);
                        doc.text(note.title, margin, y);
                        y += 4;
                        doc.setFontSize(9);
                        doc.setTextColor('#000000');
                        addText(note.text, 9);
                        y += 2;
                    }
                });
            }
            
            // ============================================================
            // PHOTOS
            // ============================================================
            if (inspection.photos && inspection.photos.length > 0) {
                doc.addPage();
                y = margin + 5;
                addFooter();
                addTitle('PHOTO DOCUMENTATION', 18);
                drawLine();
                y += 6;
                
                const photos = inspection.photos.slice(0, 15);
                const photoSize = 50;
                const gap = 5;
                const maxCols = Math.floor((pageWidth - 2 * margin + gap) / (photoSize + gap));
                let row = 0, col = 0;
                
                for (let i = 0; i < photos.length; i++) {
                    const p = photos[i];
                    const px = margin + col * (photoSize + gap);
                    const py = y + row * (photoSize + gap + 8);
                    
                    if (py + photoSize + 10 > pageHeight - margin - 15) {
                        doc.addPage();
                        y = margin + 5;
                        addFooter();
                        addTitle('PHOTO DOCUMENTATION (continued)', 14);
                        drawLine();
                        y += 6;
                        row = 0;
                        col = 0;
                    }
                    
                    try {
                        const img = new Image();
                        const imgData = await new Promise((resolve) => {
                            img.onload = () => resolve({ width: img.width, height: img.height });
                            img.onerror = () => resolve(null);
                            img.src = p.dataURL;
                        });
                        
                        let imgWidth = photoSize;
                        let imgHeight = photoSize * 0.75;
                        if (imgData) {
                            const aspectRatio = imgData.width / imgData.height;
                            if (aspectRatio > 1) {
                                imgWidth = photoSize;
                                imgHeight = photoSize / aspectRatio;
                            } else {
                                imgHeight = photoSize;
                                imgWidth = photoSize * aspectRatio;
                            }
                        }
                        
                        const xOffset = px + (photoSize - imgWidth) / 2;
                        const yOffset = py + (photoSize * 0.75 - imgHeight) / 2;
                        doc.addImage(p.dataURL, 'JPEG', xOffset, yOffset, imgWidth, imgHeight);
                        doc.setFontSize(6);
                        doc.setTextColor('#666');
                        doc.text(`Photo ${i+1}`, px + 2, py + photoSize * 0.75 + 4);
                    } catch (e) {
                        doc.setFillColor('#f0f0f0');
                        doc.roundedRect(px, py, photoSize, photoSize * 0.75, 2, 2, 'F');
                        doc.setFontSize(8);
                        doc.setTextColor('#999');
                        doc.text(`Photo ${i+1}`, px + photoSize/2 - 10, py + photoSize * 0.375);
                    }
                    
                    col++;
                    if (col >= maxCols) {
                        col = 0;
                        row++;
                    }
                }
            }
            
            // Save the PDF
            const fileName = `EcoMaintenance_Report_${inspection.id || Date.now()}.pdf`;
            doc.save(fileName);
            Toast.success('Professional report generated successfully');
            
        } catch (e) {
            console.error('Report generation error:', e);
            Toast.error('Failed to generate report: ' + e.message);
        }
    }
    
