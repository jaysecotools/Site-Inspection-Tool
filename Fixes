                            <button class="btn btn-secondary btn-sm view-insp" data-id="${ins.id}"><i class="fas fa-eye"></i> View</button>
                            <button class="btn btn-primary btn-sm pdf-insp" data-id="${ins.id}"><i class="fas fa-file-pdf"></i> Report</button>
                            <button class="btn btn-danger btn-sm del-insp" data-id="${ins.id}"><i class="fas fa-trash"></i></button>
                        </div>
                        <div class="card-badge" style="background:${eco.colour}20;color:${eco.colour};">${eco.riskRating}</div>
                    </div>
                `;
            });
            
            this.setPanel(html, 'Inspections');
            
            const searchInput = document.getElementById('searchInspections');
            if (searchInput) {
                searchInput.oninput = () => {
                    const q = searchInput.value.toLowerCase();
                    document.querySelectorAll('.inspection-card').forEach(card => {
                        const searchData = card.dataset.search || '';
                        card.style.display = searchData.includes(q) ? '' : 'none';
                    });
                };
            }
            
            document.querySelectorAll('.view-insp').forEach(el => {
                el.onclick = () => this.loadInspection(el.dataset.id, false);
            });
            document.querySelectorAll('.pdf-insp').forEach(el => {
                el.onclick = async () => {
                    const ins = await this.db.get(el.dataset.id, false);
                    if (ins) this.generateReport(ins);
                };
            });
            document.querySelectorAll('.del-insp').forEach(el => {
                el.onclick = async () => {
                    if (confirm('Delete this report permanently?')) {
                        await this.db.delete(el.dataset.id, false);
                        Toast.success('Deleted');
                        await this.updateStatus();
                        this.showInspections();
                    }
                };
            });
        } catch (e) { console.error('Inspections error:', e); Toast.error('Failed to load'); }
    }
    
    async showDrafts() {
        try {
            const drafts = await this.db.getAll('drafts');
            if (drafts.length === 0) {
                this.setPanel(`
                    <div class="text-center" style="padding:30px 20px;">
                        <i class="fas fa-save" style="font-size:36px;opacity:0.3;display:block;margin-bottom:10px;"></i>
                        <h3>No Drafts</h3>
                        <p class="text-muted">Start a new assessment to create a draft.</p>
                        <button class="btn btn-primary mt-3" onclick="app.newInspection()"><i class="fas fa-plus"></i> Start New</button>
                    </div>
                `, 'Drafts');
                return;
            }
            
            drafts.sort((a, b) => new Date(b.updatedAt) - new Date(a.updatedAt));
            let html = `
                <div class="flex-between mb-2">
                    <span><strong>${drafts.length}</strong> drafts</span>
                    <div class="flex gap-2">
                        <button class="btn btn-secondary btn-sm" onclick="app.showInspections()"><i class="fas fa-folder-open"></i> Reports</button>
                        <button class="btn btn-primary btn-sm" onclick="app.newInspection()"><i class="fas fa-plus"></i> New</button>
                    </div>
                </div>
            `;
            
            drafts.forEach(d => {
                const age = Math.round((Date.now() - new Date(d.updatedAt).getTime()) / (1000 * 60 * 60 * 24));
                const checklist = d.checklistCount || { done: 0, total: 16 };
                html += `
                    <div class="inspection-card" style="border-left-color:var(--warning);">
                        <div class="card-title">${Utils.escapeHtml(d.siteName || 'Unnamed Draft')}</div>
                        <div class="card-meta">
                            <span><i class="fas fa-clock"></i> ${age > 0 ? `${age} days ago` : 'Today'}</span>
                            <span><i class="fas fa-user"></i> ${d.inspector || 'No inspector'}</span>
                            <span><i class="fas fa-camera"></i> ${d.photos?.length || 0} photos</span>
                            <span><i class="fas fa-check-double"></i> ${checklist.done}/${checklist.total}</span>
                        </div>
                        <div class="card-actions">
                            <button class="btn btn-secondary btn-sm resume-draft" data-id="${d.id}"><i class="fas fa-pen"></i> Resume</button>
                            <button class="btn btn-danger btn-sm del-draft" data-id="${d.id}"><i class="fas fa-trash"></i></button>
                        </div>
                        <div class="card-badge" style="background:rgba(212,168,67,0.15);color:var(--warning);">Draft</div>
                    </div>
                `;
            });
            
            this.setPanel(html, 'Drafts');
            
            document.querySelectorAll('.resume-draft').forEach(el => {
                el.onclick = () => this.loadInspection(el.dataset.id, true);
            });
            document.querySelectorAll('.del-draft').forEach(el => {
                el.onclick = async () => {
                    if (confirm('Delete this draft?')) {
                        await this.db.delete(el.dataset.id, true);
                        Toast.success('Deleted');
                        await this.updateStatus();
                        this.showDrafts();
                    }
                };
            });
        } catch (e) { console.error('Drafts error:', e); Toast.error('Failed to load'); }
    }
    
    async showDataManager() {
        try {
            const insp = await this.db.count('inspections');
            const drafts = await this.db.count('drafts');
            const allInsp = await this.db.getAll('inspections');
            const totalPhotos = allInsp.reduce((s, i) => s + (i.photos?.length || 0), 0);
            
            const html = `
                <div style="max-width:420px;margin:0 auto;">
                    <div class="dashboard-grid" style="grid-template-columns:1fr 1fr 1fr;">
                        <div class="stat-card text-center"><div class="stat-value">${insp}</div><div class="stat-label">Reports</div></div>
                        <div class="stat-card text-center"><div class="stat-value">${drafts}</div><div class="stat-label">Drafts</div></div>
                        <div class="stat-card text-center"><div class="stat-value">${totalPhotos}</div><div class="stat-label">Photos</div></div>
                    </div>
                    
                    <h4 class="mb-2"><i class="fas fa-download"></i> Export Data</h4>
                    <button class="btn btn-primary w-full mb-2" onclick="app.exportCSV()"><i class="fas fa-file-excel"></i> Export Excel</button>
                    <button class="btn btn-secondary w-full mb-2" onclick="app.exportJSON()"><i class="fas fa-code"></i> Export JSON</button>
                    <button class="btn btn-secondary w-full mb-4" onclick="app.exportGeoJSON()"><i class="fas fa-map"></i> Export GeoJSON</button>
                    
                    <h4 class="mb-2"><i class="fas fa-upload"></i> Import Data</h4>
                    <input type="file" id="importFile" accept=".json" style="margin-bottom:4px;">
                    <button class="btn btn-secondary w-full mb-4" onclick="app.importJSON()"><i class="fas fa-upload"></i> Import JSON</button>
                    
                    <hr style="margin:10px 0;border-color:var(--gray-200);">
                    
                    <button class="btn btn-danger w-full" onclick="app.clearAll()"><i class="fas fa-trash"></i> Clear All Data</button>
                    
                    <div style="margin-top:10px;padding:8px 10px;background:var(--gray-50);border-radius:var(--radius-sm);border:1px solid var(--gray-200);">
                        <div class="text-xs text-muted">
                            <div class="flex-between">
                                <span><strong>Storage:</strong> localStorage</span>
                                <span><strong>Reports:</strong> ${insp}</span>
                                <span><strong>Drafts:</strong> ${drafts}</span>
                            </div>
                            <div class="flex-between mt-2">
                                <span><strong>Photos:</strong> ${totalPhotos}</span>
                                <span><strong>Version:</strong> 4.0</span>
                                <span><strong>Data size:</strong> ${Utils.formatFileSize(new Blob([localStorage.getItem('EcoMaintenanceData') || '']).size)}</span>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            this.setPanel(html, 'Data Manager');
        } catch (e) { console.error('Data manager error:', e); Toast.error('Failed to load'); }
    }
    
    // ================================================================
    // EXPORT/IMPORT - ENHANCED WITH MAP STATE
    // ================================================================
    async exportCSV() {
        try {
            const insp = await this.db.getAll('inspections');
            if (!insp.length) { Toast.warning('No data to export'); return; }
            const data = insp.map(i => ({
                'ID': i.id,
                'Site': i.siteName,
                'Inspector': i.inspector,
                'Organization': i.organization,
                'Date': i.dateTime,
                'Score': i.ecologicalScore?.conditionScore || '',
                'Risk': i.ecologicalScore?.riskRating || '',
                'Priority': i.ecologicalScore?.priority || '',
                'Vegetation': i.vegetationType || '',
                'Weed Cover': i.weedCover || '',
                'Heritage Significance': i.heritageSignificance || '',
                'Cultural Sites': i.culturalSites || '',
                'Photos': i.photos?.length || 0,
                'Location Verified': i.siteLocation ? 'Yes' : 'No',
                'Accessibility': i.accessibility ? 'Yes' : 'No',
                'Site Conditions': i.siteConditions ? 'Yes' : 'No',
                'Infrastructure': i.infrastructure ? 'Yes' : 'No',
                'Protected Species': i.protectedSpecies ? 'Yes' : 'No',
                'Environmental Impacts': i.environmentalImpacts ? 'Yes' : 'No',
                'Compliance': i.compliance ? 'Yes' : 'No',
                'Conservation': i.conservation ? 'Yes' : 'No',
                'Work Practices': i.workPractices ? 'Yes' : 'No',
                'Health & Safety': i.healthSafety ? 'Yes' : 'No',
                'Risks': i.risksHazards ? 'Yes' : 'No',
                'Control Measures': i.controlMeasures ? 'Yes' : 'No',
                'Equipment Inspected': i.equipmentInspected ? 'Yes' : 'No',
                'Safe Condition': i.safeCondition ? 'Yes' : 'No',
                'Maintenance': i.maintenanceRecords ? 'Yes' : 'No',
                'Industry Standards': i.industryStandards ? 'Yes' : 'No'
            }));
            const ws = XLSX.utils.json_to_sheet(data);
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, 'Inspections');
            XLSX.writeFile(wb, `EcoMaintenance_${new Date().toISOString().slice(0,10)}.xlsx`);
            Toast.success('Excel export complete');
        } catch (e) { console.error('Export error:', e); Toast.error('Export failed'); }
    }
    
    async exportJSON() {
        try {
            const insp = await this.db.getAll('inspections');
            const drafts = await this.db.getAll('drafts');
            
            // Get current map state
            const center = this.map.getCenter();
            const data = { 
                exportDate: new Date().toISOString(), 
                version: '4.0',
                app: 'EcoMaintenance Professional',
                inspections: insp, 
                drafts: drafts,
                mapState: {
                    center: { lat: center.lat, lng: center.lng },
                    zoom: this.map.getZoom(),
                    layer: this.currentLayer
                }
            };
            
            // Include map image if available (will make file larger but preserves the captured map)
            if (this._mapImage) {
                data.mapImage = this._mapImage;
            }
            
            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = `EcoMaintenance_Data_${new Date().toISOString().slice(0,10)}.json`;
            a.click();
            URL.revokeObjectURL(a.href);
            Toast.success('JSON export complete with map state');
        } catch (e) { console.error('Export error:', e); Toast.error('Export failed'); }
    }
    
    exportGeoJSON() {
        try {
            const features = [
                ...this.getGeometry(),
                ...this.getWaypoints().map(w => ({
                    type: 'Feature',
                    geometry: { type: 'Point', coordinates: [w.lng, w.lat] },
                    properties: { label: w.label, type: 'waypoint' }
                }))
            ];
            const fc = { type: 'FeatureCollection', features };
            const blob = new Blob([JSON.stringify(fc, null, 2)], { type: 'application/json' });
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = `EcoMaintenance_Map_${Date.now()}.geojson`;
            a.click();
            URL.revokeObjectURL(a.href);
            Toast.success('GeoJSON exported');
        } catch (e) { console.error('Export error:', e); Toast.error('Export failed'); }
    }
    
    async importJSON() {
        const file = document.getElementById('importFile')?.files[0];
        if (!file) { Toast.warning('Select a JSON file to import'); return; }
        
        const reader = new FileReader();
        reader.onload = async (e) => {
            try {
                const data = JSON.parse(e.target.result);
                let count = 0;
                
                // Import inspections
                if (data.inspections) {
                    for (const insp of data.inspections) { 
                        await this.db.save(insp, false); 
                        count++; 
                    }
                }
                
                // Import drafts
                if (data.drafts) {
                    for (const draft of data.drafts) { 
                        await this.db.save(draft, true); 
                        count++; 
                    }
                }
                
                // Restore map state if available
                if (data.mapState) {
                    const { center, zoom, layer } = data.mapState;
                    if (center && zoom) {
                        this.map.setView([center.lat, center.lng], zoom);
                    }
                    if (layer) {
                        this.switchLayer(layer);
                    }
                    Toast.info('Map state restored');
                }
                
                // Restore map image if available
                if (data.mapImage) {
                    this._mapImage = data.mapImage;
                    // Show preview if form is open
                    const img = document.getElementById('mapPreviewImg');
                    const container = document.getElementById('mapPreviewContainer');
                    if (img && container) {
                        img.src = data.mapImage;
                        container.style.display = 'block';
                        const statusEl = document.getElementById('mapStatus');
                        if (statusEl) {
                            statusEl.innerHTML = `<i class="fas fa-check-circle" style="color:var(--success);"></i> Map image restored from import.`;
                        }
                    }
                }
                
                Toast.success(`Imported ${count} records successfully with map state`);
                await this.updateStatus();
                this.showDataManager();
            } catch (err) { 
                Toast.error('Invalid JSON file format'); 
                console.error('Import error:', err);
            }
        };
        reader.readAsText(file);
    }
    
    async clearAll() {
        if (!confirm('⚠️ Delete ALL data? This cannot be undone.')) return;
        if (!confirm('Are you absolutely sure? All reports, drafts and photos will be permanently deleted.')) return;
        try {
            await this.db.clear('inspections');
            await this.db.clear('drafts');
            Toast.success('All data cleared successfully');
            await this.updateStatus();
            this.showDashboard();
        } catch (e) { Toast.error('Failed to clear data'); }
    }
    
    // ================================================================
    // EVENTS
    // ================================================================
    bindEvents() {
        // Navigation
        document.querySelectorAll('.nav-item').forEach(item => {
            item.addEventListener('click', () => {
                document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
                item.classList.add('active');
                const view = item.dataset.view;
                switch(view) {
                    case 'dashboard': this.showDashboard(); break;
                    case 'inspections': this.showInspections(); break;
                    case 'new': this.newInspection(); break;
                    case 'mapview': this.closePanel(); break;
                    case 'drafts': this.showDrafts(); break;
                    case 'data': this.showDataManager(); break;
                }
            });
        });
        
        // Search
        const searchInput = document.getElementById('searchAddress');
        const searchBtn = document.getElementById('searchBtn');
        
        const doSearch = () => {
            const query = searchInput?.value || '';
            if (query.trim()) {
                this.searchAddress(query);
            }
        };
        
        if (searchBtn) searchBtn.addEventListener('click', doSearch);
        if (searchInput) {
            searchInput.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') doSearch();
            });
        }
        
        // Toolbar buttons
        document.getElementById('newInspectionBtn').addEventListener('click', () => this.newInspection());
        document.getElementById('listInspectionsBtn').addEventListener('click', () => this.showInspections());
        document.getElementById('closePanelBtn').addEventListener('click', () => this.closePanel());
        document.getElementById('clearMapBtn').addEventListener('click', () => this.clearMap());
        document.getElementById('exportGeoJsonBtn').addEventListener('click', () => this.exportGeoJSON());
        document.getElementById('exportCSVBtn').addEventListener('click', () => this.exportCSV());
        document.getElementById('measureBtn').addEventListener('click', () => this.startMeasure());
        document.getElementById('locateBtn').addEventListener('click', () => this.locateUser());
        document.getElementById('resetMapBtn').addEventListener('click', () => this.resetView());
        document.getElementById('fullscreenBtn').addEventListener('click', () => this.toggleFullscreen());
        document.getElementById('sidebarToggle').addEventListener('click', () => {
            document.getElementById('sidebar').classList.toggle('open');
        });
        
        // Layer control
        document.querySelectorAll('.layer-item').forEach(el => {
            el.addEventListener('click', () => {
                this.switchLayer(el.dataset.layer);
            });
        });
        
        // Satellite toggle
        document.getElementById('toggleSatBtn').addEventListener('click', () => {
            if (this.currentLayer === 'satellite') {
                this.switchLayer('streets');
            } else {
                this.switchLayer('satellite');
            }
        });
        
        // Close sidebar on mobile
        document.querySelector('.main').addEventListener('click', () => {
            if (window.innerWidth <= 768) {
                document.getElementById('sidebar').classList.remove('open');
            }
        });
        
        // Keyboard shortcuts
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                this.closePanel();
                if (document.fullscreenElement) document.exitFullscreen();
            }
            if (e.ctrlKey && e.key === 'n') { 
                e.preventDefault(); 
                this.newInspection(); 
            }
            if (e.ctrlKey && e.key === 's' && this.panelOpen) { 
                e.preventDefault(); 
                this.saveDraft(); 
            }
            if (e.key === 'm' && !e.ctrlKey && !e.metaKey) {
                this.startMeasure();
            }
        });
    }
}

