    async newInspection() {
        this.currentId = Utils.uuid();
        this.currentPhotos = [];
        this.isDraft = false;
        this._mapImage = null;
        this.clearMap();
        this.setPanel(this.renderForm({ id: this.currentId }), 'New Ecological Assessment');
        this.bindForm();
    }
    
    async loadInspection(id, draft = false) {
        try {
            const data = await this.db.get(id, draft);
            if (!data) { Toast.error('Not found'); return; }
            this.currentId = data.id;
            this.currentPhotos = data.photos || [];
            this.isDraft = draft;
            this._mapImage = null;
            this.clearMap();
            this.loadGeometry(data.geometry || []);
            (data.waypoints || []).forEach(w => {
                this.drawnItems.addLayer(
                    L.marker([w.lat, w.lng])
                        .bindPopup(`<strong>${Utils.escapeHtml(w.label)}</strong>`)
                );
            });
            
            // Restore map state if available
            if (data.mapState) {
                const { center, zoom, layer } = data.mapState;
                if (center && zoom) {
                    this.map.setView([center.lat, center.lng], zoom);
                }
                if (layer) {
                    this.switchLayer(layer);
                }
            }
            
            // Restore map image if available
            if (data.mapImage) {
                this._mapImage = data.mapImage;
                // Show preview if form is open
                const img = document.getElementById('mapPreviewImg');
                const container = document.getElementById('mapPreviewContainer');
                if (img && container) {
                    img.src = data.mapImage;
                    container.style.display = 'block';
                    const statusEl = document.getElementById('mapStatus');
                    if (statusEl) {
                        const geoCount = data.geometry?.length || 0;
                        const wpCount = data.waypoints?.length || 0;
                        statusEl.innerHTML = `<i class="fas fa-check-circle" style="color:var(--success);"></i> Map restored with ${geoCount} polygon(s) and ${wpCount} waypoint(s).`;
                    }
                }
            }
            
            this.setPanel(this.renderForm(data), draft ? 'Edit Draft' : 'View Inspection');
            this.bindForm();
            
            const countEl = document.querySelector('.photo-count');
            if (countEl) countEl.textContent = `${this.currentPhotos.length} photos added`;
            
            // Update checklist state from saved data
            this.updateChecklistDisplay();
        } catch (e) { console.error('Load error:', e); Toast.error('Failed to load'); }
    }
    
    async saveDraft() {
        try {
            const data = this.collectForm();
            if (!data.siteName) { Toast.warning('Site name required'); return; }
            data.status = 'draft';
            await this.db.save(data, true);
            this.isDraft = true;
            Toast.success('Draft saved');
            await this.updateStatus();
        } catch (e) { console.error('Save draft error:', e); Toast.error('Failed to save draft'); }
    }
    
    async finalise() {
        if (this.isGenerating) return;
        
        try {
            const data = this.collectForm();
            if (!data.siteName) { Toast.warning('Site name required'); return; }
            data.status = 'finalised';
            data.ecologicalScore = Utils.calculateScore(data);
            await this.db.save(data, false);
            await this.db.delete(data.id, true);
            await this.generateReport(data);
            this.closePanel();
            await this.updateStatus();
            this.showInspections();
        } catch (e) { console.error('Finalise error:', e); Toast.error('Failed to finalise'); }
    }
    
    // ================================================================
    // REPORT GENERATION - WITH MAP IMAGE SUPPORT
    // ================================================================
    async generateReport(inspection) {
        try {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF('p', 'mm', 'a4');
            const pageWidth = 210, pageHeight = 297, margin = 18;
            let y = margin;
            const eco = inspection.ecologicalScore || Utils.calculateScore(inspection);
            const colour = '#1a5f4a';
            
            // CRITICAL FIX: Complete text cleaning
            const cleanText = (text) => {
                if (!text) return '';
                let clean = String(text);
                // Remove HTML tags
                clean = clean.replace(/<[^>]*>/g, '');
                // Remove all Unicode special characters including zero-width spaces
                clean = clean.replace(/[\u2713\u2717\u2611\u2610\u2714\u274c\u25a0\u25cf\u2022\u25e6\uFEFF\u200B\u200C\u200D\u00A0]/g, '');
                // Remove any non-ASCII characters (keep only printable ASCII)
                clean = clean.replace(/[^\x20-\x7E]/g, ' ');
                // Remove multiple spaces
                clean = clean.replace(/\s+/g, ' ');
                // Trim
                clean = clean.trim();
                return clean;
            };
            
            // Helper: Add text with auto-page breaks
            const addText = (text, size = 10, color = '#000000') => {
                if (!text) return;
                const clean = cleanText(text);
                if (!clean) return;
                doc.setFontSize(size);
                doc.setTextColor(color);
                const lines = doc.splitTextToSize(clean, pageWidth - 2 * margin);
                const lineHeight = size * 0.45;
                const totalHeight = lines.length * lineHeight + 1.5;
                if (y + totalHeight > pageHeight - margin - 8) {
                    doc.addPage();
                    y = margin + 5;
                    addFooter();
                }
                doc.text(lines, margin, y);
                y += totalHeight;
            };
            
            // Helper: Add title
            const addTitle = (text, size = 18, color = colour) => {
                const clean = cleanText(text);
                if (!clean) return;
                doc.setFontSize(size);
                doc.setTextColor(color);
                doc.text(clean, margin, y);
                y += size * 0.4 + 2;
            };
            
            // Helper: Draw line
            const drawLine = () => {
                doc.setDrawColor(colour);
                doc.setLineWidth(0.5);
                doc.line(margin, y, pageWidth - margin, y);
                y += 5;
            };
            
            // Helper: Add footer
            const addFooter = () => {
                doc.setDrawColor(colour);
                doc.setLineWidth(0.3);
                doc.line(margin, pageHeight - 12, pageWidth - margin, pageHeight - 12);
                doc.setFontSize(7);
                doc.setTextColor('#aaa');
                const id = cleanText(inspection.id || 'N/A');
                doc.text(id, margin, pageHeight - 5);
                const date = Utils.formatDate(inspection.dateTime);
                doc.text(date, pageWidth - margin, pageHeight - 5, { align: 'right' });
                const pageNum = doc.internal.getCurrentPageInfo().pageNumber;
                doc.text(`Page ${pageNum}`, pageWidth/2, pageHeight - 5, { align: 'center' });
            };
            
            // ============================================================
            // COVER PAGE
            // ============================================================
            doc.setFillColor(colour);
            doc.rect(0, 0, pageWidth, 6, 'F');
            y = 30;
            
            doc.setFontSize(32);
            doc.setTextColor(colour);
            doc.text('ENVIRONMENTAL', margin, y);
            y += 14;
            doc.text('ASSESSMENT REPORT', margin, y);
            y += 12;
            drawLine();
            y += 6;
            
            doc.setFontSize(20);
            doc.setTextColor('#000000');
            const siteName = cleanText(inspection.siteName || 'Site Assessment');
            doc.text(siteName, margin, y);
            y += 12;
            
            doc.setFontSize(11);
            doc.setTextColor('#000000');
            const org = cleanText(inspection.organization || 'Environmental Client');
            doc.text(`Prepared for: ${org}`, margin, y);
            y += 6;
            const date = Utils.formatDate(inspection.dateTime);
            doc.text(`Date: ${date}`, margin, y);
            y += 6;
            const id = cleanText(inspection.id || 'N/A');
            doc.text(`Report ID: ${id}`, margin, y);
            y += 6;
            const author = cleanText(inspection.inspector || 'Environmental Consultant');
            doc.text(`Author: ${author}`, margin, y);
            y += 10;
            
            // Cover photo
            if (inspection.photos && inspection.photos.length > 0) {
                const hero = inspection.photos.find(p => p.isHero) || inspection.photos[0];
                try {
                    const img = new Image();
                    const imgData = await new Promise((resolve) => {
                        img.onload = () => resolve({ width: img.width, height: img.height });
                        img.onerror = () => resolve(null);
                        img.src = hero.dataURL;
                    });
                    
                    if (imgData) {
                        const maxImgWidth = pageWidth - 2 * margin - 20;
                        const maxImgHeight = 70;
                        let imgWidth = maxImgWidth;
                        let imgHeight = (imgData.height / imgData.width) * maxImgWidth;
                        if (imgHeight > maxImgHeight) {
                            imgHeight = maxImgHeight;
                            imgWidth = (imgData.width / imgData.height) * maxImgHeight;
                        }
                        const xOffset = margin + 10 + (maxImgWidth - imgWidth) / 2;
                        doc.addImage(hero.dataURL, 'JPEG', xOffset, y, imgWidth, imgHeight);
                        y += imgHeight + 8;
                        doc.setFontSize(7);
                        doc.setTextColor('#999');
                        const caption = cleanText(inspection.siteName || 'Site Photo');
                        doc.text(`Cover Photo: ${caption}`, margin + 10, y);
                        y += 6;
                    }
                } catch (e) {
                    // Skip photo on error
                }
            }
            
            doc.setFillColor(colour);
            doc.rect(0, pageHeight - 6, pageWidth, 3, 'F');
            doc.setFontSize(7);
            doc.setTextColor('#999');
            doc.text('© EcoMaintenance Professional v4.0', margin, pageHeight - 3);
            doc.text('Environmental Assessment Report', pageWidth / 2, pageHeight - 3, { align: 'center' });
            doc.text('Page 1', pageWidth - margin, pageHeight - 3, { align: 'right' });
            
            // ============================================================
            // MAP PAGE
            // ============================================================
            // Try to get map image from cache or capture fresh
            let mapDataUrl = this._mapImage;
            if (!mapDataUrl) {
                // Try to capture the map now
                const captured = await this.captureMapImage();
                if (captured) {
                    mapDataUrl = captured;
                    this._mapImage = captured;
                }
            }
            
            if (mapDataUrl) {
                doc.addPage();
                y = margin + 5;
                addFooter();
                addTitle('SITE MAP', 18);
                drawLine();
                y += 6;

                try {
                    // Load image to get dimensions
                    const img = new Image();
                    await new Promise((resolve) => {
                        img.onload = resolve;
                        img.onerror = resolve;
                        img.src = mapDataUrl;
                    });

                    const maxMapWidth = pageWidth - 2 * margin - 10;
                    const maxMapHeight = pageHeight - margin * 2 - 45;
                    let mapWidth = maxMapWidth;
                    let mapHeight = maxMapWidth * (img.height / img.width);
                    
                    if (mapHeight > maxMapHeight) {
                        mapHeight = maxMapHeight;
                        mapWidth = maxMapHeight * (img.width / img.height);
                    }

                    const xOffset = margin + (maxMapWidth - mapWidth) / 2;
                    doc.addImage(mapDataUrl, 'JPEG', xOffset, y, mapWidth, mapHeight);
                    y += mapHeight + 8;

                    // Add map info legend
                    doc.setFontSize(8);
                    doc.setTextColor('#444');
                    const geoInfo = this.getGeometry().length || inspection.geometry?.length || 0;
                    const waypoints = this.getWaypoints().length || inspection.waypoints?.length || 0;
                    doc.text(`Map includes: ${geoInfo} polygon(s) and ${waypoints} waypoint(s)`, margin + 10, y);
