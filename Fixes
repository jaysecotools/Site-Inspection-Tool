1. Fix Map Layer Switching (Replace the switchLayer function):

```javascript
switchLayer(name) {
    // First, remove ALL layers from the map
    if (this.layers.base && this.map.hasLayer(this.layers.base)) {
        this.map.removeLayer(this.layers.base);
    }
    if (this.layers.satellite && this.map.hasLayer(this.layers.satellite)) {
        this.map.removeLayer(this.layers.satellite);
    }
    if (this.layers.topo && this.map.hasLayer(this.layers.topo)) {
        this.map.removeLayer(this.layers.topo);
    }
    
    // Set active layer
    this.activeLayer = name;
    
    // Add the selected layer
    const layer = this.layers[name];
    if (layer) {
        layer.addTo(this.map);
        
        // Force a redraw
        this.map.invalidateSize();
        
        // Update layer control UI
        document.querySelectorAll('.layer-item').forEach(el => {
            el.classList.toggle('active', el.dataset.layer === name);
        });
        
        // Update status bar
        const layerNames = { streets: 'Streets', satellite: 'Satellite', topo: 'Topo' };
        document.getElementById('currentLayer').textContent = layerNames[name] || name;
        
        // Update satellite toggle button
        const satBtn = document.getElementById('toggleSatBtn');
        if (name === 'satellite') {
            satBtn.innerHTML = '<i class="fas fa-map"></i><span> Streets</span>';
            satBtn.classList.add('active');
            satBtn.style.background = 'var(--primary)';
            satBtn.style.color = 'white';
        } else {
            satBtn.innerHTML = '<i class="fas fa-satellite"></i><span> Satellite</span>';
            satBtn.classList.remove('active');
            satBtn.style.background = '';
            satBtn.style.color = '';
        }
        
        Toast.info(`Switched to ${layerNames[name] || name} view`);
    }
}
```

